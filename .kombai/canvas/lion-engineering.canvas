      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { font-family: 'Inter', sans-serif; box-sizing: border-box; }\n</style>\n\n\n<nav style=\"background:#ffffff; height:64px; border-bottom:1px solid #e2e6eb; display:flex; align-items:center; padding:0 64px; justify-content:space-between;\" data-kid=\"1\">\n  <div style=\"display:flex; align-items:center; gap:8px;\" data-kid=\"2\">\n    <span style=\"font-size:22px; font-weight:800; color:#0c1e35; letter-spacing:-0.5px;\" data-kid=\"3\">LION</span>\n    <span style=\"font-size:10px; font-weight:500; color:#5a6a7e; letter-spacing:2px; margin-top:2px;\" data-kid=\"4\">ENGINEERING</span>\n  </div>\n  <div style=\"display:flex; align-items:center; gap:36px;\" data-kid=\"5\">\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"6\">Startseite</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"7\">Leistungen</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"8\">Über uns</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"9\">Karriere</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"10\">Kontakt</a>\n    <span style=\"font-size:12px; font-weight:500; color:#5a6a7e; letter-spacing:0.3px;\" data-kid=\"11\"><strong style=\"color:#0c1e35;\" data-kid=\"99\">DE</strong>&nbsp;|&nbsp;EN</span>\n  </div>\n</nav>\n\n\n<section style=\"background:#f6f7f9; padding:96px 64px; text-align:center;\" data-kid=\"12\">\n  <div style=\"display:inline-block; font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:20px;\" data-kid=\"13\">KONTAKT</div>\n  <h1 style=\"font-size:40px; font-weight:800; color:#0c1e35; margin:0 0 20px; letter-spacing:-0.5px; line-height:1.12;\" data-kid=\"14\">Gemeinsam zum Ziel</h1>\n  <p style=\"font-size:18px; font-weight:300; color:#5a6a7e; max-width:540px; margin:0 auto; line-height:1.6;\" data-kid=\"15\">Erzählen Sie uns von Ihrem Engineering-Projekt – wir melden uns innerhalb eines Werktages.</p>\n</section>\n\n\n<section style=\"display:flex; background:#ffffff; min-height:700px;\" data-kid=\"16\">\n\n  \n  <div style=\"width:60%; padding:96px 64px 96px 96px; background:#ffffff;\" data-kid=\"17\">\n    <div style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"18\">SCHREIBEN SIE UNS</div>\n    <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; margin:0 0 40px; letter-spacing:0;\" data-kid=\"19\">Kontaktformular</h2>\n\n    \n    <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;\" data-kid=\"20\">\n      <div data-kid=\"21\">\n        <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"22\">Vollständiger Name <span style=\"color:#ef4444;\" data-kid=\"23\">*</span></label>\n        <input type=\"text\" placeholder=\"Max Mustermann\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"24\">\n      </div>\n      <div data-kid=\"25\">\n        <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"26\">E-Mail-Adresse <span style=\"color:#ef4444;\" data-kid=\"27\">*</span></label>\n        <input type=\"email\" placeholder=\"max@unternehmen.de\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"28\">\n      </div>\n    </div>\n\n    \n    <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;\" data-kid=\"29\">\n      <div data-kid=\"30\">\n        <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"31\">Unternehmen</label>\n        <input type=\"text\" placeholder=\"Musterfirma GmbH\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"32\">\n      </div>\n      <div data-kid=\"33\">\n        <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"34\">Telefon</label>\n        <input type=\"tel\" placeholder=\"+49 ...\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"35\">\n      </div>\n    </div>\n\n    \n    <div style=\"margin-bottom:32px;\" data-kid=\"36\">\n      <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"37\">Nachricht</label>\n      <textarea placeholder=\"Beschreiben Sie Ihr Projekt oder Ihre Anfrage...\" style=\"width:100%; min-height:160px; border:1.5px solid #e2e6eb; border-radius:4px; padding:14px 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none; resize:vertical; font-family:'Inter',sans-serif; line-height:1.6;\" data-kid=\"38\"></textarea>\n    </div>\n\n    <button style=\"width:100%; height:48px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; letter-spacing:0.2px; border:none; border-radius:4px; cursor:pointer;\" data-kid=\"39\">Anfrage senden →</button>\n\n    <p style=\"font-size:13px; font-weight:400; color:#8a96a6; margin-top:16px;\" data-kid=\"40\">* Pflichtfeld &nbsp;·&nbsp; Wir antworten in der Regel innerhalb eines Werktages. Ihre Daten werden gemäß unserer Datenschutzerklärung behandelt.</p>\n  </div>\n\n  \n  <div style=\"width:40%; background:#f6f7f9; padding:96px 64px;\" data-kid=\"41\">\n    <div style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"42\">UNSER BÜRO</div>\n    <h3 style=\"font-size:22px; font-weight:700; color:#0c1e35; margin:0 0 32px;\" data-kid=\"43\">Lion Engineering GmbH</h3>\n\n    <div style=\"display:flex; flex-direction:column; gap:20px; margin-bottom:40px;\" data-kid=\"44\">\n      <div style=\"display:flex; align-items:flex-start; gap:14px;\" data-kid=\"45\">\n        <span style=\"font-size:18px; line-height:1.4; flex-shrink:0;\" data-kid=\"46\">📍</span>\n        <div data-kid=\"47\">\n          <div style=\"font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:3px;\" data-kid=\"48\">Adresse</div>\n          <div style=\"font-size:15px; font-weight:300; color:#2d3a4a; line-height:1.6;\" data-kid=\"49\">Einsteinstr. 10<br data-kid=\"50\">85521 Ottobrunn, Deutschland</div>\n        </div>\n      </div>\n      <div style=\"display:flex; align-items:flex-start; gap:14px;\" data-kid=\"51\">\n        <span style=\"font-size:18px; line-height:1.4; flex-shrink:0;\" data-kid=\"52\">📞</span>\n        <div data-kid=\"53\">\n          <div style=\"font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:3px;\" data-kid=\"54\">Telefon</div>\n          <div style=\"font-size:15px; font-weight:300; color:#2d3a4a;\" data-kid=\"55\">+49 89 6146572-0</div>\n        </div>\n      </div>\n      <div style=\"display:flex; align-items:flex-start; gap:14px;\" data-kid=\"56\">\n        <span style=\"font-size:18px; line-height:1.4; flex-shrink:0;\" data-kid=\"57\">✉️</span>\n        <div data-kid=\"58\">\n          <div style=\"font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:3px;\" data-kid=\"59\">E-Mail</div>\n          <div style=\"font-size:15px; font-weight:300; color:#1a6dd4;\" data-kid=\"60\">info@lion-engineering.de</div>\n        </div>\n      </div>\n      <div style=\"display:flex; align-items:flex-start; gap:14px;\" data-kid=\"61\">\n        <span style=\"font-size:18px; line-height:1.4; flex-shrink:0;\" data-kid=\"62\">🕐</span>\n        <div data-kid=\"63\">\n          <div style=\"font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:3px;\" data-kid=\"64\">Öffnungszeiten</div>\n          <div style=\"font-size:15px; font-weight:300; color:#2d3a4a;\" data-kid=\"65\">Mo–Fr: 08:00–17:00 Uhr</div>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"width:100%; height:280px; overflow:hidden;\" data-kid=\"66\">\n      <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5329.6!2d11.6662!3d48.0657!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x479ddf35c6f26ae7%3A0xb7b15b5c32e1ca35!2sOttobrunn!5e0!3m2!1sde!2sde!4v1717000000000\" width=\"100%\" height=\"280\" style=\"border:0; display:block;\" allowfullscreen loading=\"lazy\" data-kid=\"67\"></iframe>\n    </div>\n  </div>\n\n</section>\n\n\n<footer style=\"background:#0c1e35; padding:64px 96px 32px;\" data-kid=\"68\">\n  <div style=\"display:flex; align-items:center; margin-bottom:48px;\" data-kid=\"69\">\n    <div style=\"display:flex; align-items:center; gap:8px;\" data-kid=\"70\">\n      <span style=\"font-size:22px; font-weight:800; color:#ffffff; letter-spacing:-0.5px;\" data-kid=\"71\">LION</span>\n      <span style=\"font-size:10px; font-weight:500; color:#b8c4d4; letter-spacing:2px; margin-top:2px;\" data-kid=\"72\">ENGINEERING</span>\n    </div>\n  </div>\n\n  <div style=\"display:grid; grid-template-columns:1fr 1fr 1fr; gap:48px; margin-bottom:48px;\" data-kid=\"73\">\n    <div data-kid=\"74\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:20px; letter-spacing:0.2px;\" data-kid=\"75\">Unternehmen</div>\n      <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"76\">\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"77\">Über uns</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"78\">Karriere</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"79\">Zertifizierungen</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"80\">Aktuelles</a>\n      </div>\n    </div>\n    <div data-kid=\"81\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:20px; letter-spacing:0.2px;\" data-kid=\"82\">Leistungen</div>\n      <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"83\">\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"84\">Luft- und Raumfahrt</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"85\">Automotive</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"86\">Technologie & F&E</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"87\">Projektmanagement</a>\n      </div>\n    </div>\n    <div data-kid=\"88\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:20px; letter-spacing:0.2px;\" data-kid=\"89\">Kontakt</div>\n      <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"90\">\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"91\">Einsteinstr. 10, 85521 Ottobrunn</span>\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"92\">+49 89 6146572-0</span>\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"93\">info@lion-engineering.de</span>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"border-top:1px solid #132d4f; padding-top:28px; display:flex; justify-content:space-between; align-items:center;\" data-kid=\"94\">\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e;\" data-kid=\"95\">© 2026 Lion Engineering GmbH</span>\n    <div style=\"display:flex; gap:24px;\" data-kid=\"96\">\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#5a6a7e; text-decoration:none;\" data-kid=\"97\">Impressum</a>\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#5a6a7e; text-decoration:none;\" data-kid=\"98\">Datenschutz</a>\n    </div>\n  </div>\n</footer>\n",
