      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { font-family: 'Inter', sans-serif; box-sizing: border-box; }\n</style>\n\n\n<nav style=\"background:#ffffff; height:64px; border-bottom:1px solid #e2e6eb; display:flex; align-items:center; padding:0 24px; justify-content:space-between;\" data-kid=\"1\">\n  <div style=\"display:flex; align-items:center; gap:6px;\" data-kid=\"2\">\n    <span style=\"font-size:18px; font-weight:800; color:#0c1e35; letter-spacing:-0.5px;\" data-kid=\"3\">LION</span>\n    <span style=\"font-size:9px; font-weight:500; color:#5a6a7e; letter-spacing:2px; margin-top:1px;\" data-kid=\"4\">ENGINEERING</span>\n  </div>\n  <div style=\"display:flex; flex-direction:column; gap:5px; cursor:pointer;\" data-kid=\"5\">\n    <span style=\"display:block; width:24px; height:2px; background:#0c1e35; border-radius:2px;\" data-kid=\"6\"></span>\n    <span style=\"display:block; width:24px; height:2px; background:#0c1e35; border-radius:2px;\" data-kid=\"7\"></span>\n    <span style=\"display:block; width:18px; height:2px; background:#0c1e35; border-radius:2px;\" data-kid=\"8\"></span>\n  </div>\n</nav>\n\n\n<section style=\"background:#f6f7f9; padding:64px 24px; text-align:center;\" data-kid=\"9\">\n  <div style=\"display:inline-block; font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"10\">KONTAKT</div>\n  <h1 style=\"font-size:32px; font-weight:800; color:#0c1e35; margin:0 0 16px; letter-spacing:-0.5px; line-height:1.15;\" data-kid=\"11\">Gemeinsam zum Ziel</h1>\n  <p style=\"font-size:16px; font-weight:300; color:#5a6a7e; margin:0; line-height:1.6;\" data-kid=\"12\">Erzählen Sie uns von Ihrem Engineering-Projekt – wir melden uns innerhalb eines Werktages.</p>\n</section>\n\n\n<section style=\"background:#ffffff; padding:48px 24px;\" data-kid=\"13\">\n  <div style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:12px;\" data-kid=\"14\">SCHREIBEN SIE UNS</div>\n  <h2 style=\"font-size:20px; font-weight:700; color:#0c1e35; margin:0 0 32px;\" data-kid=\"15\">Kontaktformular</h2>\n\n  <div style=\"margin-bottom:20px;\" data-kid=\"16\">\n    <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"17\">Vollständiger Name <span style=\"color:#ef4444;\" data-kid=\"18\">*</span></label>\n    <input type=\"text\" placeholder=\"Max Mustermann\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"19\">\n  </div>\n\n  <div style=\"margin-bottom:20px;\" data-kid=\"20\">\n    <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"21\">E-Mail-Adresse <span style=\"color:#ef4444;\" data-kid=\"22\">*</span></label>\n    <input type=\"email\" placeholder=\"max@unternehmen.de\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"23\">\n  </div>\n\n  <div style=\"margin-bottom:20px;\" data-kid=\"24\">\n    <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"25\">Unternehmen</label>\n    <input type=\"text\" placeholder=\"Musterfirma GmbH\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"26\">\n  </div>\n\n  <div style=\"margin-bottom:20px;\" data-kid=\"27\">\n    <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"28\">Telefon</label>\n    <input type=\"tel\" placeholder=\"+49 ...\" style=\"width:100%; height:48px; border:1.5px solid #e2e6eb; border-radius:4px; padding:0 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none;\" data-kid=\"29\">\n  </div>\n\n  <div style=\"margin-bottom:28px;\" data-kid=\"30\">\n    <label style=\"display:block; font-size:14px; font-weight:600; color:#0c1e35; margin-bottom:8px;\" data-kid=\"31\">Nachricht</label>\n    <textarea placeholder=\"Beschreiben Sie Ihr Projekt oder Ihre Anfrage...\" style=\"width:100%; min-height:160px; border:1.5px solid #e2e6eb; border-radius:4px; padding:14px 16px; font-size:16px; font-weight:300; color:#0c1e35; background:#ffffff; outline:none; resize:vertical; font-family:'Inter',sans-serif; line-height:1.6;\" data-kid=\"32\"></textarea>\n  </div>\n\n  <button style=\"width:100%; height:48px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; letter-spacing:0.2px; border:none; border-radius:4px; cursor:pointer;\" data-kid=\"33\">Anfrage senden →</button>\n\n  <p style=\"font-size:13px; font-weight:400; color:#8a96a6; margin-top:14px; line-height:1.5;\" data-kid=\"34\">* Pflichtfeld &nbsp;·&nbsp; Wir antworten in der Regel innerhalb eines Werktages.</p>\n</section>\n\n\n<section style=\"background:#f6f7f9; padding:48px 24px;\" data-kid=\"35\">\n  <div style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:12px;\" data-kid=\"36\">UNSER BÜRO</div>\n  <h3 style=\"font-size:20px; font-weight:700; color:#0c1e35; margin:0 0 28px;\" data-kid=\"37\">Lion Engineering GmbH</h3>\n\n  <div style=\"display:flex; flex-direction:column; gap:18px; margin-bottom:32px;\" data-kid=\"38\">\n    <div style=\"display:flex; align-items:flex-start; gap:12px;\" data-kid=\"39\">\n      <span style=\"font-size:16px; line-height:1.5; flex-shrink:0;\" data-kid=\"40\">📍</span>\n      <div data-kid=\"41\">\n        <div style=\"font-size:13px; font-weight:600; color:#0c1e35; margin-bottom:2px;\" data-kid=\"42\">Adresse</div>\n        <div style=\"font-size:14px; font-weight:300; color:#2d3a4a; line-height:1.6;\" data-kid=\"43\">Einsteinstr. 10<br data-kid=\"44\">85521 Ottobrunn, Deutschland</div>\n      </div>\n    </div>\n    <div style=\"display:flex; align-items:flex-start; gap:12px;\" data-kid=\"45\">\n      <span style=\"font-size:16px; line-height:1.5; flex-shrink:0;\" data-kid=\"46\">📞</span>\n      <div data-kid=\"47\">\n        <div style=\"font-size:13px; font-weight:600; color:#0c1e35; margin-bottom:2px;\" data-kid=\"48\">Telefon</div>\n        <div style=\"font-size:14px; font-weight:300; color:#2d3a4a;\" data-kid=\"49\">+49 89 6146572-0</div>\n      </div>\n    </div>\n    <div style=\"display:flex; align-items:flex-start; gap:12px;\" data-kid=\"50\">\n      <span style=\"font-size:16px; line-height:1.5; flex-shrink:0;\" data-kid=\"51\">✉️</span>\n      <div data-kid=\"52\">\n        <div style=\"font-size:13px; font-weight:600; color:#0c1e35; margin-bottom:2px;\" data-kid=\"53\">E-Mail</div>\n        <div style=\"font-size:14px; font-weight:300; color:#1a6dd4;\" data-kid=\"54\">info@lion-engineering.de</div>\n      </div>\n    </div>\n    <div style=\"display:flex; align-items:flex-start; gap:12px;\" data-kid=\"55\">\n      <span style=\"font-size:16px; line-height:1.5; flex-shrink:0;\" data-kid=\"56\">🕐</span>\n      <div data-kid=\"57\">\n        <div style=\"font-size:13px; font-weight:600; color:#0c1e35; margin-bottom:2px;\" data-kid=\"58\">Öffnungszeiten</div>\n        <div style=\"font-size:14px; font-weight:300; color:#2d3a4a;\" data-kid=\"59\">Mo–Fr: 08:00–17:00 Uhr</div>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"width:100%; height:220px; overflow:hidden;\" data-kid=\"60\">\n    <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5329.6!2d11.6662!3d48.0657!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x479ddf35c6f26ae7%3A0xb7b15b5c32e1ca35!2sOttobrunn!5e0!3m2!1sde!2sde!4v1717000000000\" width=\"100%\" height=\"220\" style=\"border:0; display:block;\" allowfullscreen loading=\"lazy\" data-kid=\"61\"></iframe>\n  </div>\n</section>\n\n\n<footer style=\"background:#0c1e35; padding:48px 24px 28px;\" data-kid=\"62\">\n  <div style=\"display:flex; align-items:center; gap:6px; margin-bottom:40px;\" data-kid=\"63\">\n    <span style=\"font-size:18px; font-weight:800; color:#ffffff; letter-spacing:-0.5px;\" data-kid=\"64\">LION</span>\n    <span style=\"font-size:9px; font-weight:500; color:#b8c4d4; letter-spacing:2px; margin-top:1px;\" data-kid=\"65\">ENGINEERING</span>\n  </div>\n\n  <div style=\"display:flex; flex-direction:column; gap:36px; margin-bottom:40px;\" data-kid=\"66\">\n    <div data-kid=\"67\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:14px;\" data-kid=\"68\">Unternehmen</div>\n      <div style=\"display:flex; flex-direction:column; gap:8px;\" data-kid=\"69\">\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"70\">Über uns</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"71\">Karriere</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"72\">Zertifizierungen</a>\n      </div>\n    </div>\n    <div data-kid=\"73\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:14px;\" data-kid=\"74\">Leistungen</div>\n      <div style=\"display:flex; flex-direction:column; gap:8px;\" data-kid=\"75\">\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"76\">Luft- und Raumfahrt</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"77\">Automotive</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"78\">Technologie & F&E</a>\n      </div>\n    </div>\n    <div data-kid=\"79\">\n      <div style=\"font-size:14px; font-weight:700; color:#ffffff; margin-bottom:14px;\" data-kid=\"80\">Kontakt</div>\n      <div style=\"display:flex; flex-direction:column; gap:8px;\" data-kid=\"81\">\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"82\">Einsteinstr. 10, 85521 Ottobrunn</span>\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"83\">+49 89 6146572-0</span>\n        <span style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"84\">info@lion-engineering.de</span>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"border-top:1px solid #132d4f; padding-top:24px; display:flex; flex-direction:column; gap:12px;\" data-kid=\"85\">\n    <span style=\"font-size:12px; font-weight:400; color:#5a6a7e;\" data-kid=\"86\">© 2026 Lion Engineering GmbH</span>\n    <div style=\"display:flex; gap:20px;\" data-kid=\"87\">\n      <a href=\"#\" style=\"font-size:12px; font-weight:400; color:#5a6a7e; text-decoration:none;\" data-kid=\"88\">Impressum</a>\n      <a href=\"#\" style=\"font-size:12px; font-weight:400; color:#5a6a7e; text-decoration:none;\" data-kid=\"89\">Datenschutz</a>\n    </div>\n  </div>\n</footer>\n",
