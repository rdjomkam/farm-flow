      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { box-sizing: border-box; }\n  body { font-family: 'Inter', -apple-system, sans-serif; margin: 0; padding: 0; background: #ffffff; color: #0c1e35; }\n</style>\n\n<nav style=\"background:#ffffff; height:64px; border-bottom:1px solid #e2e6eb; display:flex; align-items:center; justify-content:space-between; padding:0 64px; position:relative; z-index:10;\" data-kid=\"1\">\n  <div style=\"display:flex; align-items:center; gap:8px;\" data-kid=\"2\">\n    <span style=\"font-size:11px; font-weight:800; letter-spacing:3px; color:#0c1e35;\" data-kid=\"3\">LION</span>\n    <span style=\"width:1px; height:20px; background:#e2e6eb;\" data-kid=\"4\"></span>\n    <span style=\"font-size:11px; font-weight:500; letter-spacing:1.5px; color:#5a6a7e;\" data-kid=\"5\">ENGINEERING</span>\n  </div>\n  <div style=\"display:flex; align-items:center; gap:32px;\" data-kid=\"6\">\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"7\">Startseite</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"8\">Leistungen</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"9\">Über uns</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"10\">Karriere</a>\n    <a href=\"#\" style=\"display:inline-flex; align-items:center; height:40px; padding:0 20px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; letter-spacing:0.2px;\" data-kid=\"11\">Kontakt</a>\n  </div>\n  <div style=\"font-size:12px; font-weight:500; color:#5a6a7e; letter-spacing:0.3px;\" data-kid=\"12\"><strong style=\"color:#0c1e35;\" data-kid=\"119\">DE</strong>&nbsp;|&nbsp;EN</div>\n</nav>\n\n<section style=\"position:relative; min-height:780px; background:#091627; overflow:hidden; display:flex; align-items:center;\" data-kid=\"13\">\n  <img src=\"https://images.pexels.com/photos/72593/hangar-jet-aircraft-fighter-72593.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Kampfjet in Hangar – Luft- und Raumfahrttechnik\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"14\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(90deg, rgba(9,22,39,0.92) 0%, rgba(9,22,39,0.55) 65%, rgba(9,22,39,0.25) 100%);\" data-kid=\"15\"></div>\n  <div style=\"position:relative; z-index:2; max-width:560px; padding:96px 0 96px 96px;\" data-kid=\"16\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 20px 0; line-height:1;\" data-kid=\"17\">ENGINEERING-PARTNER SEIT 2006</p>\n    <h1 style=\"font-size:56px; font-weight:800; color:#ffffff; line-height:1.08; letter-spacing:-1px; margin:0 0 24px 0;\" data-kid=\"18\">Von der Idee<br data-kid=\"19\">zur Zulassung</h1>\n    <p style=\"font-size:18px; font-weight:300; color:#b8c4d4; line-height:1.6; margin:0 0 40px 0; max-width:480px;\" data-kid=\"20\">Umfassende Engineering-Lösungen für Luft- und Raumfahrt, Automotive und Technologie – von der Machbarkeitsstudie bis zur Serienproduktion.</p>\n    <div style=\"display:flex; gap:16px; flex-wrap:wrap;\" data-kid=\"21\">\n      <a href=\"#\" style=\"display:inline-flex; align-items:center; height:48px; padding:0 28px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; letter-spacing:0.2px; white-space:nowrap;\" data-kid=\"22\">Beratung anfragen</a>\n      <a href=\"#\" style=\"display:inline-flex; align-items:center; height:48px; padding:0 28px; background:transparent; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; border:1.5px solid rgba(255,255,255,0.35); letter-spacing:0.2px; white-space:nowrap;\" data-kid=\"23\">Unsere Leistungen</a>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; padding:48px 64px; text-align:center;\" data-kid=\"24\">\n  <p style=\"font-size:12px; font-weight:500; color:#5a6a7e; letter-spacing:1px; text-transform:uppercase; margin:0 0 28px 0;\" data-kid=\"25\">Vertrauen von</p>\n  <div style=\"display:flex; align-items:center; justify-content:center; gap:48px; flex-wrap:wrap;\" data-kid=\"26\">\n    <span style=\"font-size:16px; font-weight:800; letter-spacing:2px; filter:grayscale(100%); opacity:0.5; color:#0c1e35;\" data-kid=\"27\">AIRBUS</span>\n    <span style=\"font-size:13px; font-weight:700; letter-spacing:1.5px; filter:grayscale(100%); opacity:0.5; color:#0c1e35;\" data-kid=\"28\">AIRBUS HELICOPTERS</span>\n    <span style=\"font-size:18px; font-weight:800; letter-spacing:3px; filter:grayscale(100%); opacity:0.5; color:#0c1e35;\" data-kid=\"29\">BMW</span>\n    <span style=\"font-size:15px; font-weight:700; letter-spacing:2px; filter:grayscale(100%); opacity:0.5; color:#0c1e35;\" data-kid=\"30\">MAGNA</span>\n    <span style=\"font-size:15px; font-weight:700; letter-spacing:2px; filter:grayscale(100%); opacity:0.5; color:#0c1e35;\" data-kid=\"31\">IABG</span>\n  </div>\n</section>\n\n<section style=\"position:relative; height:400px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"32\">\n  <img src=\"https://images.pexels.com/photos/5052062/pexels-photo-5052062.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Nahaufnahme Hubschrauber – Luft- und Raumfahrttechnik\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"33\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(90deg, rgba(9,22,39,0.88) 0%, rgba(9,22,39,0.6) 55%, rgba(9,22,39,0.0) 100%);\" data-kid=\"34\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 96px; max-width:600px;\" data-kid=\"35\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 12px 0; line-height:1;\" data-kid=\"36\">LUFT- UND RAUMFAHRT</p>\n    <h2 style=\"font-size:22px; font-weight:700; color:#ffffff; margin:0 0 12px 0; line-height:1.3;\" data-kid=\"37\">Strukturauslegung &amp; Simulation</h2>\n    <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; margin:0 0 24px 0; line-height:1.6;\" data-kid=\"38\">Primär- und Sekundärstrukturen, FEM-Analyse und Systemintegration für die Luft- und Raumfahrtindustrie.</p>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"39\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"position:relative; height:400px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"40\">\n  <img src=\"https://images.pexels.com/photos/19233057/pexels-photo-19233057.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Hochmoderne Automotive-Robotik in der Fertigung\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"41\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(90deg, rgba(9,22,39,0.88) 0%, rgba(9,22,39,0.6) 55%, rgba(9,22,39,0.0) 100%);\" data-kid=\"42\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 96px; max-width:600px;\" data-kid=\"43\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 12px 0; line-height:1;\" data-kid=\"44\">AUTOMOTIVE</p>\n    <h2 style=\"font-size:22px; font-weight:700; color:#ffffff; margin:0 0 12px 0; line-height:1.3;\" data-kid=\"45\">Karosserie &amp; Antriebsstrangtechnik</h2>\n    <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; margin:0 0 24px 0; line-height:1.6;\" data-kid=\"46\">Fahrzeugkarosserie, Antriebsstrangintegration und Serienbetreuung für Automotive-OEMs.</p>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"47\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"position:relative; height:400px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"48\">\n  <img src=\"https://images.pexels.com/photos/5506047/pexels-photo-5506047.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Modernes Technologielabor für Ingenieure\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"49\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(90deg, rgba(9,22,39,0.88) 0%, rgba(9,22,39,0.6) 55%, rgba(9,22,39,0.0) 100%);\" data-kid=\"50\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 96px; max-width:600px;\" data-kid=\"51\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 12px 0; line-height:1;\" data-kid=\"52\">TECHNOLOGIE</p>\n    <h2 style=\"font-size:22px; font-weight:700; color:#ffffff; margin:0 0 12px 0; line-height:1.3;\" data-kid=\"53\">F&amp;E und Prüftechnik</h2>\n    <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; margin:0 0 24px 0; line-height:1.6;\" data-kid=\"54\">Forschung, Entwicklung und Prüftechnik für fortschrittliche Technologieanwendungen und neue Produktentwicklung.</p>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"55\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; padding:0; border-top:1px solid #e2e6eb; border-bottom:1px solid #e2e6eb;\" data-kid=\"56\">\n  <div style=\"display:grid; grid-template-columns:repeat(4,1fr);\" data-kid=\"57\">\n    <div style=\"padding:48px 24px; text-align:center; border-right:1px solid #e2e6eb;\" data-kid=\"58\">\n      <div style=\"font-size:28px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"59\">18+</div>\n      <div style=\"font-size:13px; font-weight:500; color:#5a6a7e; margin-top:6px; letter-spacing:0.3px;\" data-kid=\"60\">Jahre Erfahrung</div>\n    </div>\n    <div style=\"padding:48px 24px; text-align:center; border-right:1px solid #e2e6eb;\" data-kid=\"61\">\n      <div style=\"font-size:28px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"62\">EN 9100</div>\n      <div style=\"font-size:13px; font-weight:500; color:#5a6a7e; margin-top:6px; letter-spacing:0.3px;\" data-kid=\"63\">Luftfahrt-Zertifiziert</div>\n    </div>\n    <div style=\"padding:48px 24px; text-align:center; border-right:1px solid #e2e6eb;\" data-kid=\"64\">\n      <div style=\"font-size:28px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"65\">25+</div>\n      <div style=\"font-size:13px; font-weight:500; color:#5a6a7e; margin-top:6px; letter-spacing:0.3px;\" data-kid=\"66\">Ingenieure</div>\n    </div>\n    <div style=\"padding:48px 24px; text-align:center;\" data-kid=\"67\">\n      <div style=\"font-size:28px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"68\">7+</div>\n      <div style=\"font-size:13px; font-weight:500; color:#5a6a7e; margin-top:6px; letter-spacing:0.3px;\" data-kid=\"69\">Schlüsselkunden</div>\n    </div>\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:560px;\" data-kid=\"70\">\n  <div style=\"width:55%; padding:96px 64px 96px 96px; background:#ffffff; display:flex; flex-direction:column; justify-content:center;\" data-kid=\"71\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 16px 0; line-height:1;\" data-kid=\"72\">ÜBER UNS</p>\n    <h2 style=\"font-size:28px; font-weight:700; color:#0c1e35; margin:0 0 20px 0; line-height:1.2; letter-spacing:-0.3px;\" data-kid=\"73\">Präzision. Geliefert.</h2>\n    <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin:0 0 32px 0; max-width:500px;\" data-kid=\"74\">Seit 2006 liefert Lion Engineering hochpräzise Engineering-Dienstleistungen an führende Unternehmen in der Luft- und Raumfahrt und im Automotive-Bereich. Von unserem Standort in Ottobrunn bei München begleiten unsere 25+ Ingenieure Projekte von der ersten Machbarkeitsstudie bis zur abgeschlossenen Serienzulassung.</p>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; align-self:flex-start;\" data-kid=\"75\">Mehr über uns →</a>\n  </div>\n  <div style=\"width:45%; overflow:hidden;\" data-kid=\"76\">\n    <img src=\"https://images.pexels.com/photos/3862373/pexels-photo-3862373.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Ingenieure prüfen technische Zeichnungen im Büro\" style=\"width:100%; height:100%; object-fit:cover; object-position:center; display:block;\" data-kid=\"77\">\n  </div>\n</section>\n\n<section style=\"background:#0c1e35; padding:80px 64px; text-align:center;\" data-kid=\"78\">\n  <h2 style=\"font-size:28px; font-weight:700; color:#ffffff; margin:0 0 16px 0; line-height:1.2;\" data-kid=\"79\">Bereit für Ihr nächstes Projekt?</h2>\n  <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; margin:0 0 32px 0; max-width:480px; display:inline-block; line-height:1.6;\" data-kid=\"80\">Sprechen Sie mit uns darüber, wie unsere Ingenieure Ihr nächstes Projekt unterstützen können.</p>\n  <div data-kid=\"81\">\n    <a href=\"#\" style=\"display:inline-flex; align-items:center; height:48px; padding:0 32px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; letter-spacing:0.2px;\" data-kid=\"82\">Kontakt aufnehmen</a>\n  </div>\n</section>\n\n<footer style=\"background:#0c1e35; padding:64px 96px 0;\" data-kid=\"83\">\n  <div style=\"margin-bottom:48px;\" data-kid=\"84\">\n    <span style=\"font-size:12px; font-weight:800; letter-spacing:3px; color:#ffffff;\" data-kid=\"85\">LION ENGINEERING</span>\n    <span style=\"display:block; font-size:10px; font-weight:400; color:#b8c4d4; letter-spacing:1px; margin-top:4px;\" data-kid=\"86\">GmbH · Ottobrunn · München</span>\n  </div>\n  <div style=\"display:grid; grid-template-columns:repeat(3,1fr); gap:48px; padding-bottom:48px;\" data-kid=\"87\">\n    <div data-kid=\"88\">\n      <h4 style=\"font-size:16px; font-weight:700; color:#ffffff; margin:0 0 20px 0;\" data-kid=\"89\">Unternehmen</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;\" data-kid=\"90\">\n        <li data-kid=\"91\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"92\">Über uns</a></li>\n        <li data-kid=\"93\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"94\">Karriere</a></li>\n        <li data-kid=\"95\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"96\">Zertifizierungen</a></li>\n        <li data-kid=\"97\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"98\">Impressum</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"99\">\n      <h4 style=\"font-size:16px; font-weight:700; color:#ffffff; margin:0 0 20px 0;\" data-kid=\"100\">Leistungen</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;\" data-kid=\"101\">\n        <li data-kid=\"102\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"103\">Luft- und Raumfahrt</a></li>\n        <li data-kid=\"104\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"105\">Automotive</a></li>\n        <li data-kid=\"106\"><a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"107\">Technologie</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"108\">\n      <h4 style=\"font-size:16px; font-weight:700; color:#ffffff; margin:0 0 20px 0;\" data-kid=\"109\">Kontakt</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px;\" data-kid=\"110\">\n        <li style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"111\">+49 89 6146572-0</li>\n        <li style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"112\">info@lion-engineering.de</li>\n        <li style=\"font-size:14px; font-weight:400; color:#b8c4d4;\" data-kid=\"113\">Einsteinstr. 10<br data-kid=\"114\">85521 Ottobrunn</li>\n      </ul>\n    </div>\n  </div>\n  <div style=\"border-top:1px solid #132d4f; padding:24px 0;\" data-kid=\"115\">\n    <p style=\"font-size:13px; font-weight:400; color:#5a6a7e; margin:0;\" data-kid=\"116\">© 2026 Lion Engineering GmbH &nbsp;·&nbsp; <a href=\"#\" style=\"color:#5a6a7e; text-decoration:none;\" data-kid=\"117\">Impressum</a> &nbsp;·&nbsp; <a href=\"#\" style=\"color:#5a6a7e; text-decoration:none;\" data-kid=\"118\">Datenschutz</a></p>\n  </div>\n</footer>\n",
