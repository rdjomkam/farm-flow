      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n* { font-family: 'Inter', sans-serif; box-sizing: border-box; margin: 0; padding: 0; }\n</style>\n\n\n<nav style=\"background:#fff;height:64px;border-bottom:1px solid #e2e6eb;display:flex;align-items:center;justify-content:space-between;padding:0 24px;\" data-kid=\"1\">\n  <div style=\"font-size:20px;font-weight:800;color:#0c1e35;letter-spacing:-0.5px;\" data-kid=\"2\">LION<span style=\"color:#1a6dd4;\" data-kid=\"3\">.</span></div>\n  <div style=\"display:flex;flex-direction:column;gap:5px;cursor:pointer;\" data-kid=\"4\">\n    <div style=\"width:22px;height:2px;background:#0c1e35;border-radius:1px;\" data-kid=\"5\"></div>\n    <div style=\"width:22px;height:2px;background:#0c1e35;border-radius:1px;\" data-kid=\"6\"></div>\n    <div style=\"width:16px;height:2px;background:#0c1e35;border-radius:1px;\" data-kid=\"7\"></div>\n  </div>\n</nav>\n\n\n<div style=\"background:#f6f7f9;padding:64px 24px;\" data-kid=\"8\">\n  <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px;\" data-kid=\"9\">ÜBER LION ENGINEERING</div>\n  <h1 style=\"font-size:32px;font-weight:800;color:#0c1e35;line-height:1.12;letter-spacing:-0.5px;margin-bottom:16px;\" data-kid=\"10\">Engineering-Exzellenz seit 2006</h1>\n  <p style=\"font-size:16px;font-weight:300;color:#5a6a7e;line-height:1.6;\" data-kid=\"11\">Ein Team von Präzisionsingenieuren – Engineering auf Luftfahrt-Niveau aus dem Herzen Bayerns.</p>\n</div>\n\n\n<div style=\"background:#fff;padding:64px 24px;\" data-kid=\"12\">\n  <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px;\" data-kid=\"13\">UNSER ANSATZ</div>\n  <h2 style=\"font-size:24px;font-weight:700;color:#0c1e35;line-height:1.2;letter-spacing:-0.3px;margin-bottom:16px;\" data-kid=\"14\">Von der Idee bis zur Serienproduktion</h2>\n  <p style=\"font-size:15px;font-weight:300;color:#2d3a4a;line-height:1.6;margin-bottom:40px;\" data-kid=\"15\">Wir begleiten unsere Kunden durch alle Phasen des Engineering-Lebenszyklus – von der ersten Machbarkeitsstudie bis zur finalen Qualifikation und Serienübergabe. Mit EN 9100-Zertifizierung und 18+ Jahren Projekterfahrung überbrücken wir die Lücke zwischen Konzept und Zulassung.</p>\n  \n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:24px;\" data-kid=\"16\">\n    <div style=\"display:flex;flex-direction:column;align-items:center;gap:10px;\" data-kid=\"17\">\n      <div style=\"width:56px;height:56px;border-radius:50%;background:rgba(212,136,26,0.10);border:2px solid rgba(212,136,26,0.3);display:flex;align-items:center;justify-content:center;\" data-kid=\"18\">\n        <span style=\"font-size:18px;font-weight:800;color:#d4881a;\" data-kid=\"19\">01</span>\n      </div>\n      <span style=\"font-size:11px;font-weight:700;color:#0c1e35;text-transform:uppercase;letter-spacing:1.5px;text-align:center;\" data-kid=\"20\">MACHBARKEIT</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;gap:10px;\" data-kid=\"21\">\n      <div style=\"width:56px;height:56px;border-radius:50%;background:rgba(212,136,26,0.10);border:2px solid rgba(212,136,26,0.3);display:flex;align-items:center;justify-content:center;\" data-kid=\"22\">\n        <span style=\"font-size:18px;font-weight:800;color:#d4881a;\" data-kid=\"23\">02</span>\n      </div>\n      <span style=\"font-size:11px;font-weight:700;color:#0c1e35;text-transform:uppercase;letter-spacing:1.5px;text-align:center;\" data-kid=\"24\">KONSTRUKTION</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;gap:10px;\" data-kid=\"25\">\n      <div style=\"width:56px;height:56px;border-radius:50%;background:rgba(212,136,26,0.10);border:2px solid rgba(212,136,26,0.3);display:flex;align-items:center;justify-content:center;\" data-kid=\"26\">\n        <span style=\"font-size:18px;font-weight:800;color:#d4881a;\" data-kid=\"27\">03</span>\n      </div>\n      <span style=\"font-size:11px;font-weight:700;color:#0c1e35;text-transform:uppercase;letter-spacing:1.5px;text-align:center;\" data-kid=\"28\">PROTOTYP</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;gap:10px;\" data-kid=\"29\">\n      <div style=\"width:56px;height:56px;border-radius:50%;background:rgba(26,109,212,0.10);border:2px solid rgba(26,109,212,0.4);display:flex;align-items:center;justify-content:center;\" data-kid=\"30\">\n        <span style=\"font-size:18px;font-weight:800;color:#1a6dd4;\" data-kid=\"31\">04</span>\n      </div>\n      <span style=\"font-size:11px;font-weight:700;color:#0c1e35;text-transform:uppercase;letter-spacing:1.5px;text-align:center;\" data-kid=\"32\">SERIE</span>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"border-top:1px solid #e2e6eb;border-bottom:1px solid #e2e6eb;\" data-kid=\"33\">\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;\" data-kid=\"34\">\n    <div style=\"padding:32px 16px;text-align:center;border-right:1px solid #e2e6eb;border-bottom:1px solid #e2e6eb;\" data-kid=\"35\">\n      <div style=\"font-size:24px;font-weight:800;color:#0c1e35;line-height:1;\" data-kid=\"36\">18+</div>\n      <div style=\"font-size:12px;font-weight:500;color:#5a6a7e;margin-top:6px;text-transform:uppercase;letter-spacing:0.3px;\" data-kid=\"37\">Jahre</div>\n    </div>\n    <div style=\"padding:32px 16px;text-align:center;border-bottom:1px solid #e2e6eb;\" data-kid=\"38\">\n      <div style=\"font-size:20px;font-weight:800;color:#0c1e35;line-height:1;\" data-kid=\"39\">EN 9100</div>\n      <div style=\"font-size:12px;font-weight:500;color:#5a6a7e;margin-top:6px;text-transform:uppercase;letter-spacing:0.3px;\" data-kid=\"40\">Zertifiziert</div>\n    </div>\n    <div style=\"padding:32px 16px;text-align:center;border-right:1px solid #e2e6eb;\" data-kid=\"41\">\n      <div style=\"font-size:24px;font-weight:800;color:#0c1e35;line-height:1;\" data-kid=\"42\">25+</div>\n      <div style=\"font-size:12px;font-weight:500;color:#5a6a7e;margin-top:6px;text-transform:uppercase;letter-spacing:0.3px;\" data-kid=\"43\">Ingenieure</div>\n    </div>\n    <div style=\"padding:32px 16px;text-align:center;\" data-kid=\"44\">\n      <div style=\"font-size:24px;font-weight:800;color:#0c1e35;line-height:1;\" data-kid=\"45\">7+</div>\n      <div style=\"font-size:12px;font-weight:500;color:#5a6a7e;margin-top:6px;text-transform:uppercase;letter-spacing:0.3px;\" data-kid=\"46\">Kunden</div>\n    </div>\n  </div>\n</div>\n\n\n<div data-kid=\"47\">\n  <img src=\"https://images.pexels.com/photos/3862373/pexels-photo-3862373.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Ingenieurteam prüft technische Zeichnungen\" loading=\"lazy\" decoding=\"async\" style=\"width:100%;height:280px;object-fit:cover;display:block;\" data-kid=\"48\">\n  <div style=\"background:#f6f7f9;padding:48px 24px;\" data-kid=\"49\">\n    <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px;\" data-kid=\"50\">UNSER TEAM</div>\n    <h2 style=\"font-size:22px;font-weight:700;color:#0c1e35;line-height:1.25;margin-bottom:16px;\" data-kid=\"51\">Spezialisten in jedem Fachbereich</h2>\n    <p style=\"font-size:15px;font-weight:300;color:#2d3a4a;line-height:1.6;margin-bottom:14px;\" data-kid=\"52\">Unser Ingenieurteam vereint Spezialisten für Strukturmechanik, Systemintegration, CAD/CAM und Projektmanagement.</p>\n    <p style=\"font-size:15px;font-weight:300;color:#2d3a4a;line-height:1.6;margin-bottom:24px;\" data-kid=\"53\">Wir arbeiten als nahtlose Erweiterung der Teams unserer Kunden – vor Ort oder von unserem Standort in Ottobrunn aus.</p>\n    <a style=\"font-size:14px;font-weight:400;color:#1a6dd4;text-decoration:none;\" data-kid=\"54\">Unsere Kompetenzen entdecken →</a>\n  </div>\n</div>\n\n\n<div style=\"background:#fff;padding:64px 24px;\" data-kid=\"55\">\n  <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;\" data-kid=\"56\">QUALITÄT & ZERTIFIZIERUNG</div>\n  <h2 style=\"font-size:22px;font-weight:700;color:#0c1e35;line-height:1.2;margin-bottom:40px;\" data-kid=\"57\">Zertifiziert für Luftfahrt-Standards</h2>\n  <div data-kid=\"58\">\n    <div style=\"padding-bottom:32px;margin-bottom:32px;border-bottom:1px solid #e2e6eb;\" data-kid=\"59\">\n      <div style=\"font-size:36px;font-weight:800;color:#0c1e35;line-height:1;margin-bottom:6px;\" data-kid=\"60\">EN 9100</div>\n      <div style=\"font-size:15px;font-weight:600;color:#0c1e35;margin-bottom:12px;\" data-kid=\"61\">Luft- und Raumfahrt-Qualitätsmanagement</div>\n      <p style=\"font-size:14px;font-weight:300;color:#2d3a4a;line-height:1.6;\" data-kid=\"62\">Internationaler Standard für Luft-, Raumfahrt- und Verteidigungsorganisationen. Unsere Prozesse erfüllen höchste Qualitätsmanagement-Anforderungen.</p>\n    </div>\n    <div data-kid=\"63\">\n      <div style=\"font-size:36px;font-weight:800;color:#0c1e35;line-height:1;margin-bottom:6px;\" data-kid=\"64\">ISO 9001</div>\n      <div style=\"font-size:15px;font-weight:600;color:#0c1e35;margin-bottom:12px;\" data-kid=\"65\">Qualitätsmanagementsystem</div>\n      <p style=\"font-size:14px;font-weight:300;color:#2d3a4a;line-height:1.6;\" data-kid=\"66\">Grundlage unseres Qualitätsmanagementsystems – konsistente Prozesskontrolle und kontinuierliche Verbesserung in allen Leistungsbereichen.</p>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background:#f6f7f9;padding:48px 24px;text-align:center;\" data-kid=\"67\">\n  <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;\" data-kid=\"68\">UNSERE KUNDEN</div>\n  <h2 style=\"font-size:20px;font-weight:700;color:#0c1e35;margin-bottom:32px;\" data-kid=\"69\">Vertrauen führender Industrieunternehmen</h2>\n  <div style=\"display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;margin-bottom:32px;\" data-kid=\"70\">\n    <span style=\"font-size:20px;font-weight:800;color:#003591;\" data-kid=\"71\">AIRBUS</span>\n    <span style=\"font-size:15px;font-weight:600;color:#4a5568;\" data-kid=\"72\">Airbus Helicopters</span>\n    <span style=\"font-size:18px;font-weight:800;color:#1c69d3;\" data-kid=\"73\">BMW</span>\n    <span style=\"font-size:16px;font-weight:700;color:#d01a25;\" data-kid=\"74\">MAGNA</span>\n    <span style=\"font-size:16px;font-weight:700;color:#0c1e35;\" data-kid=\"75\">IABG</span>\n  </div>\n  <div style=\"width:80px;height:1px;background:#e2e6eb;margin:0 auto 20px;\" data-kid=\"76\"></div>\n  <div style=\"font-size:12px;font-weight:600;color:#5a6a7e;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;\" data-kid=\"77\">Kooperationspartner</div>\n  <div style=\"display:flex;flex-direction:column;gap:8px;align-items:center;\" data-kid=\"78\">\n    <span style=\"font-size:13px;font-weight:400;color:#5a6a7e;\" data-kid=\"79\">Formenbau Jäger</span>\n    <span style=\"font-size:13px;font-weight:400;color:#5a6a7e;\" data-kid=\"80\">IABG</span>\n    <span style=\"font-size:13px;font-weight:400;color:#5a6a7e;\" data-kid=\"81\">Airbus Safran Launchers</span>\n  </div>\n</div>\n\n\n<div style=\"background:#fff;padding:64px 24px;\" data-kid=\"82\">\n  <div style=\"font-size:12px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;\" data-kid=\"83\">UNSERE STANDORTE</div>\n  <h2 style=\"font-size:22px;font-weight:700;color:#0c1e35;margin-bottom:32px;\" data-kid=\"84\">München und Umgebung</h2>\n  <div style=\"margin-bottom:32px;\" data-kid=\"85\">\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:6px;\" data-kid=\"86\">\n      <h3 style=\"font-size:17px;font-weight:700;color:#0c1e35;\" data-kid=\"87\">Ottobrunn</h3>\n      <span style=\"font-size:11px;font-weight:700;color:#d4881a;text-transform:uppercase;letter-spacing:1px;\" data-kid=\"88\">Hauptsitz</span>\n    </div>\n    <p style=\"font-size:14px;font-weight:300;color:#5a6a7e;line-height:1.6;\" data-kid=\"89\">Einsteinstr. 10, 85521 Ottobrunn</p>\n  </div>\n  <div style=\"padding-top:24px;border-top:1px solid #e2e6eb;margin-bottom:32px;\" data-kid=\"90\">\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:6px;\" data-kid=\"91\">\n      <h3 style=\"font-size:17px;font-weight:700;color:#0c1e35;\" data-kid=\"92\">Donauwörth</h3>\n      <span style=\"font-size:11px;font-weight:700;color:#5a6a7e;text-transform:uppercase;letter-spacing:1px;\" data-kid=\"93\">Projektstandort</span>\n    </div>\n    <p style=\"font-size:14px;font-weight:300;color:#5a6a7e;line-height:1.6;\" data-kid=\"94\">Airbus Helicopters Standort, 86609 Donauwörth</p>\n  </div>\n  <div style=\"background:#e8edf2;height:200px;width:100%;display:flex;align-items:center;justify-content:center;\" data-kid=\"95\">\n    <div style=\"text-align:center;\" data-kid=\"96\">\n      <div style=\"font-size:14px;font-weight:300;color:#5a6a7e;\" data-kid=\"97\">Ottobrunn · Donauwörth · München</div>\n      <div style=\"font-size:12px;color:#8a96a6;margin-top:6px;\" data-kid=\"98\">Bayern, Süddeutschland</div>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background:#0c1e35;padding:64px 24px;text-align:center;\" data-kid=\"99\">\n  <h2 style=\"font-size:22px;font-weight:700;color:#fff;margin-bottom:20px;line-height:1.3;\" data-kid=\"100\">Bereit für Ihr nächstes Projekt?</h2>\n  <a style=\"display:inline-block;background:#1a6dd4;color:#fff;font-size:14px;font-weight:600;padding:14px 28px;border-radius:4px;text-decoration:none;letter-spacing:0.2px;\" data-kid=\"101\">Kontakt aufnehmen</a>\n</div>\n\n\n<div style=\"background:#0c1e35;padding:48px 24px 24px;\" data-kid=\"102\">\n  <div style=\"font-size:20px;font-weight:800;color:#fff;letter-spacing:-0.5px;margin-bottom:32px;\" data-kid=\"103\">LION<span style=\"color:#1a6dd4;\" data-kid=\"104\">.</span></div>\n  <div style=\"display:flex;flex-direction:column;gap:32px;margin-bottom:40px;\" data-kid=\"105\">\n    <div data-kid=\"106\">\n      <div style=\"font-size:14px;font-weight:700;color:#fff;margin-bottom:12px;\" data-kid=\"107\">Unternehmen</div>\n      <div style=\"display:flex;flex-direction:column;gap:8px;\" data-kid=\"108\">\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"109\">Über uns</a>\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"110\">Karriere</a>\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"111\">Zertifizierungen</a>\n      </div>\n    </div>\n    <div data-kid=\"112\">\n      <div style=\"font-size:14px;font-weight:700;color:#fff;margin-bottom:12px;\" data-kid=\"113\">Leistungen</div>\n      <div style=\"display:flex;flex-direction:column;gap:8px;\" data-kid=\"114\">\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"115\">Luft- und Raumfahrt</a>\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"116\">Automotive</a>\n        <a style=\"font-size:13px;color:#b8c4d4;text-decoration:none;\" data-kid=\"117\">Technologie</a>\n      </div>\n    </div>\n    <div data-kid=\"118\">\n      <div style=\"font-size:14px;font-weight:700;color:#fff;margin-bottom:12px;\" data-kid=\"119\">Kontakt</div>\n      <div style=\"display:flex;flex-direction:column;gap:8px;\" data-kid=\"120\">\n        <span style=\"font-size:13px;font-weight:300;color:#b8c4d4;\" data-kid=\"121\">+49 89 6146572-0</span>\n        <span style=\"font-size:13px;font-weight:300;color:#b8c4d4;\" data-kid=\"122\">info@lion-engineering.de</span>\n      </div>\n    </div>\n  </div>\n  <div style=\"border-top:1px solid #132d4f;padding-top:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1