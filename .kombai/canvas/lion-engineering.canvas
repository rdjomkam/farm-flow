      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { box-sizing: border-box; }\n  body { font-family: 'Inter', -apple-system, sans-serif; margin: 0; padding: 0; background: #ffffff; color: #0c1e35; }\n</style>\n\n<nav style=\"background:#ffffff; height:64px; border-bottom:1px solid #e2e6eb; display:flex; align-items:center; justify-content:space-between; padding:0 24px;\" data-kid=\"1\">\n  <div style=\"display:flex; align-items:center; gap:6px;\" data-kid=\"2\">\n    <span style=\"font-size:10px; font-weight:800; letter-spacing:2.5px; color:#0c1e35;\" data-kid=\"3\">LION</span>\n    <span style=\"width:1px; height:16px; background:#e2e6eb;\" data-kid=\"4\"></span>\n    <span style=\"font-size:9px; font-weight:500; letter-spacing:1px; color:#5a6a7e;\" data-kid=\"5\">ENGINEERING</span>\n  </div>\n  <div style=\"display:flex; flex-direction:column; gap:5px; cursor:pointer;\" data-kid=\"6\">\n    <span style=\"display:block; width:22px; height:2px; background:#0c1e35;\" data-kid=\"7\"></span>\n    <span style=\"display:block; width:22px; height:2px; background:#0c1e35;\" data-kid=\"8\"></span>\n    <span style=\"display:block; width:16px; height:2px; background:#0c1e35;\" data-kid=\"9\"></span>\n  </div>\n</nav>\n\n<section style=\"position:relative; min-height:520px; background:#091627; overflow:hidden; display:flex; align-items:center;\" data-kid=\"10\">\n  <img src=\"https://images.pexels.com/photos/72593/hangar-jet-aircraft-fighter-72593.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Kampfjet in Hangar – Luft- und Raumfahrttechnik\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"11\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,22,39,0.85) 0%, rgba(9,22,39,0.7) 60%, rgba(9,22,39,0.5) 100%);\" data-kid=\"12\"></div>\n  <div style=\"position:relative; z-index:2; padding:64px 24px 64px;\" data-kid=\"13\">\n    <p style=\"font-size:10px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 16px 0; line-height:1;\" data-kid=\"14\">ENGINEERING-PARTNER SEIT 2006</p>\n    <h1 style=\"font-size:32px; font-weight:800; color:#ffffff; line-height:1.1; letter-spacing:-0.5px; margin:0 0 16px 0;\" data-kid=\"15\">Von der Idee<br data-kid=\"16\">zur Zulassung</h1>\n    <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; line-height:1.6; margin:0 0 32px 0;\" data-kid=\"17\">Umfassende Engineering-Lösungen für Luft- und Raumfahrt, Automotive und Technologie – von der Machbarkeitsstudie bis zur Serienproduktion.</p>\n    <div style=\"display:flex; flex-direction:column; gap:12px;\" data-kid=\"18\">\n      <a href=\"#\" style=\"display:flex; align-items:center; justify-content:center; height:48px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; letter-spacing:0.2px;\" data-kid=\"19\">Beratung anfragen</a>\n      <a href=\"#\" style=\"display:flex; align-items:center; justify-content:center; height:48px; background:transparent; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px; border:1.5px solid rgba(255,255,255,0.35); letter-spacing:0.2px;\" data-kid=\"20\">Unsere Leistungen</a>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; padding:32px 24px; text-align:center; border-bottom:1px solid #e2e6eb;\" data-kid=\"21\">\n  <p style=\"font-size:11px; font-weight:500; color:#5a6a7e; letter-spacing:1px; text-transform:uppercase; margin:0 0 20px 0;\" data-kid=\"22\">Vertrauen von</p>\n  <div style=\"display:flex; align-items:center; gap:28px; overflow-x:auto; padding-bottom:4px; -webkit-overflow-scrolling:touch; scrollbar-width:none;\" data-kid=\"23\">\n    <span style=\"font-size:13px; font-weight:800; letter-spacing:2px; filter:grayscale(100%); opacity:0.5; color:#0c1e35; white-space:nowrap; flex-shrink:0;\" data-kid=\"24\">AIRBUS</span>\n    <span style=\"font-size:11px; font-weight:700; letter-spacing:1px; filter:grayscale(100%); opacity:0.5; color:#0c1e35; white-space:nowrap; flex-shrink:0;\" data-kid=\"25\">AIRBUS HELICOPTERS</span>\n    <span style=\"font-size:15px; font-weight:800; letter-spacing:2.5px; filter:grayscale(100%); opacity:0.5; color:#0c1e35; white-space:nowrap; flex-shrink:0;\" data-kid=\"26\">BMW</span>\n    <span style=\"font-size:13px; font-weight:700; letter-spacing:1.5px; filter:grayscale(100%); opacity:0.5; color:#0c1e35; white-space:nowrap; flex-shrink:0;\" data-kid=\"27\">MAGNA</span>\n    <span style=\"font-size:13px; font-weight:700; letter-spacing:1.5px; filter:grayscale(100%); opacity:0.5; color:#0c1e35; white-space:nowrap; flex-shrink:0;\" data-kid=\"28\">IABG</span>\n  </div>\n</section>\n\n<section style=\"position:relative; height:320px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"29\">\n  <img src=\"https://images.pexels.com/photos/5052062/pexels-photo-5052062.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Nahaufnahme Hubschrauber – Luft- und Raumfahrttechnik\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"30\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,22,39,0.82) 0%, rgba(9,22,39,0.6) 60%, rgba(9,22,39,0.2) 100%);\" data-kid=\"31\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 24px;\" data-kid=\"32\">\n    <p style=\"font-size:10px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 10px 0; line-height:1;\" data-kid=\"33\">LUFT- UND RAUMFAHRT</p>\n    <h2 style=\"font-size:20px; font-weight:700; color:#ffffff; margin:0 0 10px 0; line-height:1.3;\" data-kid=\"34\">Strukturauslegung &amp; Simulation</h2>\n    <p style=\"font-size:14px; font-weight:300; color:#b8c4d4; margin:0 0 20px 0; line-height:1.6;\" data-kid=\"35\">Primär- und Sekundärstrukturen, FEM-Analyse und Systemintegration.</p>\n    <a href=\"#\" style=\"font-size:13px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"36\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"position:relative; height:320px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"37\">\n  <img src=\"https://images.pexels.com/photos/19233057/pexels-photo-19233057.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Hochmoderne Automotive-Robotik in der Fertigung\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"38\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,22,39,0.82) 0%, rgba(9,22,39,0.6) 60%, rgba(9,22,39,0.2) 100%);\" data-kid=\"39\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 24px;\" data-kid=\"40\">\n    <p style=\"font-size:10px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 10px 0; line-height:1;\" data-kid=\"41\">AUTOMOTIVE</p>\n    <h2 style=\"font-size:20px; font-weight:700; color:#ffffff; margin:0 0 10px 0; line-height:1.3;\" data-kid=\"42\">Karosserie &amp; Antriebsstrangtechnik</h2>\n    <p style=\"font-size:14px; font-weight:300; color:#b8c4d4; margin:0 0 20px 0; line-height:1.6;\" data-kid=\"43\">Fahrzeugkarosserie, Antriebsstrangintegration und Serienbetreuung für Automotive-OEMs.</p>\n    <a href=\"#\" style=\"font-size:13px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"44\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"position:relative; height:320px; overflow:hidden; display:flex; align-items:center;\" data-kid=\"45\">\n  <img src=\"https://images.pexels.com/photos/5506047/pexels-photo-5506047.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Modernes Technologielabor für Ingenieure\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"46\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,22,39,0.82) 0%, rgba(9,22,39,0.6) 60%, rgba(9,22,39,0.2) 100%);\" data-kid=\"47\"></div>\n  <div style=\"position:relative; z-index:2; padding:0 24px;\" data-kid=\"48\">\n    <p style=\"font-size:10px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 10px 0; line-height:1;\" data-kid=\"49\">TECHNOLOGIE</p>\n    <h2 style=\"font-size:20px; font-weight:700; color:#ffffff; margin:0 0 10px 0; line-height:1.3;\" data-kid=\"50\">F&amp;E und Prüftechnik</h2>\n    <p style=\"font-size:14px; font-weight:300; color:#b8c4d4; margin:0 0 20px 0; line-height:1.6;\" data-kid=\"51\">Forschung, Entwicklung und Prüftechnik für fortschrittliche Technologieanwendungen.</p>\n    <a href=\"#\" style=\"font-size:13px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"52\">Entdecken →</a>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; border-top:1px solid #e2e6eb; border-bottom:1px solid #e2e6eb;\" data-kid=\"53\">\n  <div style=\"display:grid; grid-template-columns:repeat(2,1fr);\" data-kid=\"54\">\n    <div style=\"padding:32px 16px; text-align:center; border-right:1px solid #e2e6eb; border-bottom:1px solid #e2e6eb;\" data-kid=\"55\">\n      <div style=\"font-size:26px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"56\">18+</div>\n      <div style=\"font-size:12px; font-weight:500; color:#5a6a7e; margin-top:4px;\" data-kid=\"57\">Jahre Erfahrung</div>\n    </div>\n    <div style=\"padding:32px 16px; text-align:center; border-bottom:1px solid #e2e6eb;\" data-kid=\"58\">\n      <div style=\"font-size:22px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"59\">EN 9100</div>\n      <div style=\"font-size:12px; font-weight:500; color:#5a6a7e; margin-top:4px;\" data-kid=\"60\">Luftfahrt-Zertifiziert</div>\n    </div>\n    <div style=\"padding:32px 16px; text-align:center; border-right:1px solid #e2e6eb;\" data-kid=\"61\">\n      <div style=\"font-size:26px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"62\">25+</div>\n      <div style=\"font-size:12px; font-weight:500; color:#5a6a7e; margin-top:4px;\" data-kid=\"63\">Ingenieure</div>\n    </div>\n    <div style=\"padding:32px 16px; text-align:center;\" data-kid=\"64\">\n      <div style=\"font-size:26px; font-weight:800; color:#0c1e35; line-height:1.2;\" data-kid=\"65\">7+</div>\n      <div style=\"font-size:12px; font-weight:500; color:#5a6a7e; margin-top:4px;\" data-kid=\"66\">Schlüsselkunden</div>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:#ffffff;\" data-kid=\"67\">\n  <div style=\"padding:48px 24px;\" data-kid=\"68\">\n    <p style=\"font-size:10px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin:0 0 14px 0; line-height:1;\" data-kid=\"69\">ÜBER UNS</p>\n    <h2 style=\"font-size:24px; font-weight:700; color:#0c1e35; margin:0 0 16px 0; line-height:1.2; letter-spacing:-0.3px;\" data-kid=\"70\">Präzision. Geliefert.</h2>\n    <p style=\"font-size:15px; font-weight:300; color:#2d3a4a; line-height:1.6; margin:0 0 24px 0;\" data-kid=\"71\">Seit 2006 liefert Lion Engineering hochpräzise Engineering-Dienstleistungen an führende Unternehmen in der Luft- und Raumfahrt und im Automotive-Bereich. Von unserem Standort in Ottobrunn bei München begleiten unsere 25+ Ingenieure Projekte von der ersten Machbarkeitsstudie bis zur abgeschlossenen Serienzulassung.</p>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"72\">Mehr über uns →</a>\n  </div>\n  <img src=\"https://images.pexels.com/photos/3862373/pexels-photo-3862373.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" decoding=\"async\" loading=\"lazy\" alt=\"Ingenieure prüfen technische Zeichnungen\" style=\"width:100%; height:280px; object-fit:cover; object-position:center; display:block;\" data-kid=\"73\">\n</section>\n\n<section style=\"background:#0c1e35; padding:60px 24px; text-align:center;\" data-kid=\"74\">\n  <h2 style=\"font-size:22px; font-weight:700; color:#ffffff; margin:0 0 12px 0; line-height:1.3;\" data-kid=\"75\">Bereit für Ihr nächstes Projekt?</h2>\n  <p style=\"font-size:15px; font-weight:300; color:#b8c4d4; margin:0 0 28px 0; line-height:1.6;\" data-kid=\"76\">Sprechen Sie mit uns darüber, wie unsere Ingenieure Ihr Vorhaben unterstützen können.</p>\n  <a href=\"#\" style=\"display:flex; align-items:center; justify-content:center; height:48px; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; text-decoration:none; border-radius:4px;\" data-kid=\"77\">Kontakt aufnehmen</a>\n</section>\n\n<footer style=\"background:#0c1e35; padding:48px 24px 0;\" data-kid=\"78\">\n  <div style=\"margin-bottom:36px;\" data-kid=\"79\">\n    <span style=\"font-size:10px; font-weight:800; letter-spacing:2.5px; color:#ffffff;\" data-kid=\"80\">LION ENGINEERING</span>\n    <span style=\"display:block; font-size:9px; font-weight:400; color:#b8c4d4; letter-spacing:0.8px; margin-top:4px;\" data-kid=\"81\">GmbH · Ottobrunn · München</span>\n  </div>\n  <div style=\"display:flex; flex-direction:column; gap:32px; padding-bottom:36px;\" data-kid=\"82\">\n    <div data-kid=\"83\">\n      <h4 style=\"font-size:14px; font-weight:700; color:#ffffff; margin:0 0 16px 0;\" data-kid=\"84\">Unternehmen</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;\" data-kid=\"85\">\n        <li data-kid=\"86\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"87\">Über uns</a></li>\n        <li data-kid=\"88\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"89\">Karriere</a></li>\n        <li data-kid=\"90\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"91\">Zertifizierungen</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"92\">\n      <h4 style=\"font-size:14px; font-weight:700; color:#ffffff; margin:0 0 16px 0;\" data-kid=\"93\">Leistungen</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;\" data-kid=\"94\">\n        <li data-kid=\"95\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"96\">Luft- und Raumfahrt</a></li>\n        <li data-kid=\"97\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"98\">Automotive</a></li>\n        <li data-kid=\"99\"><a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"100\">Technologie</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"101\">\n      <h4 style=\"font-size:14px; font-weight:700; color:#ffffff; margin:0 0 16px 0;\" data-kid=\"102\">Kontakt</h4>\n      <ul style=\"list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;\" data-kid=\"103\">\n        <li style=\"font-size:13px; color:#b8c4d4;\" data-kid=\"104\">+49 89 6146572-0</li>\n        <li style=\"font-size:13px; color:#b8c4d4;\" data-kid=\"105\">info@lion-engineering.de</li>\n        <li style=\"font-size:13px; color:#b8c4d4; line-height:1.5;\" data-kid=\"106\">Einsteinstr. 10<br data-kid=\"107\">85521 Ottobrunn</li>\n      </ul>\n    </div>\n  </div>\n  <div style=\"border-top:1px solid #132d4f; padding:20px 0;\" data-kid=\"108\">\n    <p style=\"font-size:12px; color:#5a6a7e; margin:0; line-height:1.6;\" data-kid=\"109\">© 2026 Lion Engineering GmbH<br data-kid=\"110\"><a href=\"#\" style=\"color:#5a6a7e; text-decoration:none;\" data-kid=\"111\">Impressum</a> · <a href=\"#\" style=\"color:#5a6a7e; text-decoration:none;\" data-kid=\"112\">Datenschutz</a></p>\n  </div>\n</footer>\n",
