      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: 'Inter', sans-serif; background: #ffffff; color: #0c1e35; }\n</style>\n\n<nav style=\"background:#ffffff; border-bottom:1px solid #e2e6eb; height:64px; display:flex; align-items:center; justify-content:space-between; padding:0 24px;\" data-kid=\"1\">\n  <div style=\"font-size:18px; font-weight:800; color:#0c1e35; letter-spacing:-0.5px;\" data-kid=\"2\">LION <span style=\"font-weight:300; font-size:11px; color:#5a6a7e; letter-spacing:1px;\" data-kid=\"3\">ENGINEERING</span></div>\n  <div style=\"display:flex; flex-direction:column; gap:5px; cursor:pointer;\" data-kid=\"4\">\n    <span style=\"display:block; width:24px; height:2px; background:#0c1e35; border-radius:1px;\" data-kid=\"5\"></span>\n    <span style=\"display:block; width:24px; height:2px; background:#0c1e35; border-radius:1px;\" data-kid=\"6\"></span>\n    <span style=\"display:block; width:18px; height:2px; background:#0c1e35; border-radius:1px;\" data-kid=\"7\"></span>\n  </div>\n</nav>\n\n<section style=\"position:relative; min-height:480px; display:flex; align-items:center; overflow:hidden; background:#091627;\" data-kid=\"8\">\n  <img src=\"https://images.pexels.com/photos/6285142/pexels-photo-6285142.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Ingenieurteam bei der Überprüfung technischer Pläne\" decoding=\"async\" loading=\"lazy\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center top;\" data-kid=\"9\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,22,39,0.7) 0%, rgba(9,22,39,0.92) 60%, rgba(9,22,39,0.98) 100%);\" data-kid=\"10\"></div>\n  <div style=\"position:relative; z-index:2; padding:60px 24px 56px;\" data-kid=\"11\">\n    <p style=\"font-size:11px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"12\">WERDEN SIE TEIL UNSERES TEAMS</p>\n    <h1 style=\"font-size:32px; font-weight:800; color:#ffffff; line-height:1.1; letter-spacing:-0.5px; margin-bottom:20px;\" data-kid=\"13\">Gestalten Sie die Zukunft<br data-kid=\"14\">des Engineerings</h1>\n    <p style=\"font-size:16px; font-weight:300; color:#b8c4d4; line-height:1.6; margin-bottom:32px;\" data-kid=\"15\">Wir suchen Ingenieure, die technische Tiefe mit Leidenschaft für Präzision verbinden. Arbeiten Sie an echten Luft- und Raumfahrt- sowie Automotive-Projekten – gemeinsam mit erfahrenen Spezialisten.</p>\n    <a href=\"#positions\" style=\"display:inline-block; font-size:14px; font-weight:600; color:#ffffff; background:#1a6dd4; padding:14px 24px; border-radius:4px; text-decoration:none;\" data-kid=\"16\">Offene Stellen ansehen</a>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; padding:64px 24px;\" data-kid=\"17\">\n  <span style=\"font-size:72px; font-weight:800; color:#d4881a; line-height:1; opacity:0.2; display:block; margin-bottom:16px;\" data-kid=\"18\">01</span>\n  <h2 style=\"font-size:20px; font-weight:700; color:#0c1e35; margin-bottom:14px;\" data-kid=\"19\">Anspruchsvolle Projekte</h2>\n  <p style=\"font-size:15px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:20px;\" data-kid=\"20\">Arbeiten Sie an echten Luft- und Raumfahrt- und Automotive-Projekten für Kunden wie Airbus, BMW und Magna. Jeder Auftrag bringt von Beginn an echte Engineering-Verantwortung.</p>\n  <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"21\">\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"22\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"23\"></span>Airbus H145/H175 Strukturprogramme</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"24\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"25\"></span>BMW EV Antriebsstrangintegration</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"26\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"27\"></span>IABG Qualifikationskampagnen</span>\n  </div>\n</section>\n\n<section style=\"background:#f6f7f9; padding:64px 24px;\" data-kid=\"28\">\n  <span style=\"font-size:72px; font-weight:800; color:#d4881a; line-height:1; opacity:0.2; display:block; margin-bottom:16px;\" data-kid=\"29\">02</span>\n  <h2 style=\"font-size:20px; font-weight:700; color:#0c1e35; margin-bottom:14px;\" data-kid=\"30\">Karriereentwicklung</h2>\n  <p style=\"font-size:15px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:20px;\" data-kid=\"31\">Lion investiert in Ihre Entwicklung. Wir unterstützen Fachzertifizierungen, Konferenzteilnahmen und internes Mentoring durch Senior-Ingenieure mit 20+ Jahren Erfahrung in der Luft- und Raumfahrt.</p>\n  <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"32\">\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"33\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"34\"></span>CATIA V5/V6 Schulungen</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"35\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"36\"></span>EASA-Regelwerkskurse</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"37\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"38\"></span>Direkte Projektverantwortung</span>\n  </div>\n</section>\n\n<section style=\"background:#ffffff; padding:64px 24px;\" data-kid=\"39\">\n  <span style=\"font-size:72px; font-weight:800; color:#d4881a; line-height:1; opacity:0.2; display:block; margin-bottom:16px;\" data-kid=\"40\">03</span>\n  <h2 style=\"font-size:20px; font-weight:700; color:#0c1e35; margin-bottom:14px;\" data-kid=\"41\">Attraktive Konditionen</h2>\n  <p style=\"font-size:15px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:20px;\" data-kid=\"42\">Wir bieten faire, am Münchner Luftfahrtmarkt orientierte Gehälter, flexible Arbeitsmodelle und eine Teamkultur, die auf gegenseitigem Respekt und technischer Exzellenz basiert.</p>\n  <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"43\">\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"44\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"45\"></span>Wettbewerbsfähiges Münchner Gehalt</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"46\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"47\"></span>Hybrides Arbeiten</span>\n    <span style=\"font-size:13px; font-weight:400; color:#5a6a7e; display:flex; align-items:center; gap:10px;\" data-kid=\"48\"><span style=\"width:4px; height:4px; border-radius:50%; background:#d4881a; flex-shrink:0; display:inline-block;\" data-kid=\"49\"></span>Kleines Team, große Wirkung</span>\n  </div>\n</section>\n\n<section id=\"positions\" style=\"background:#ffffff; padding:64px 24px; border-top:1px solid #e2e6eb;\" data-kid=\"50\">\n  <p style=\"font-size:11px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:10px;\" data-kid=\"51\">OFFENE STELLEN</p>\n  <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; margin-bottom:32px; letter-spacing:-0.3px;\" data-kid=\"52\">Verstärken Sie unser Ingenieurteam</h2>\n\n  <div style=\"display:flex; justify-content:space-between; align-items:center; padding:20px 0; border-bottom:1px solid #e2e6eb;\" data-kid=\"53\">\n    <div data-kid=\"54\">\n      <p style=\"font-size:15px; font-weight:600; color:#2d3a4a; margin-bottom:4px;\" data-kid=\"55\">Berechnungsingenieur (m/w/d)</p>\n      <p style=\"font-size:13px; font-weight:400; color:#5a6a7e;\" data-kid=\"56\">Luft- und Raumfahrt · FEM/Strukturen</p>\n    </div>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; flex-shrink:0; margin-left:12px;\" data-kid=\"57\">Bewerben →</a>\n  </div>\n\n  <div style=\"display:flex; justify-content:space-between; align-items:center; padding:20px 0; border-bottom:1px solid #e2e6eb;\" data-kid=\"58\">\n    <div data-kid=\"59\">\n      <p style=\"font-size:15px; font-weight:600; color:#2d3a4a; margin-bottom:4px;\" data-kid=\"60\">Konstruktionsingenieur (m/w/d)</p>\n      <p style=\"font-size:13px; font-weight:400; color:#5a6a7e;\" data-kid=\"61\">Luft- und Raumfahrt · CATIA V5</p>\n    </div>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; flex-shrink:0; margin-left:12px;\" data-kid=\"62\">Bewerben →</a>\n  </div>\n\n  <div style=\"display:flex; justify-content:space-between; align-items:center; padding:20px 0; border-bottom:1px solid #e2e6eb;\" data-kid=\"63\">\n    <div data-kid=\"64\">\n      <p style=\"font-size:15px; font-weight:600; color:#2d3a4a; margin-bottom:4px;\" data-kid=\"65\">Projektleiter (m/w/d)</p>\n      <p style=\"font-size:13px; font-weight:400; color:#5a6a7e;\" data-kid=\"66\">Luft- und Raumfahrt · Systeme</p>\n    </div>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; flex-shrink:0; margin-left:12px;\" data-kid=\"67\">Bewerben →</a>\n  </div>\n\n  <div style=\"display:flex; justify-content:space-between; align-items:center; padding:20px 0; border-bottom:1px solid #e2e6eb;\" data-kid=\"68\">\n    <div data-kid=\"69\">\n      <p style=\"font-size:15px; font-weight:600; color:#2d3a4a; margin-bottom:4px;\" data-kid=\"70\">Systemintegrationsingenieur (m/w/d)</p>\n      <p style=\"font-size:13px; font-weight:400; color:#5a6a7e;\" data-kid=\"71\">Automotive · Integration</p>\n    </div>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; flex-shrink:0; margin-left:12px;\" data-kid=\"72\">Bewerben →</a>\n  </div>\n\n  <p style=\"font-size:13px; font-weight:300; color:#5a6a7e; margin-top:24px; line-height:1.6;\" data-kid=\"73\">Kein passendes Profil? Initiativbewerbungen an <a href=\"mailto:karriere@lion-engineering.de\" style=\"color:#1a6dd4; text-decoration:none;\" data-kid=\"74\">karriere@lion-engineering.de</a></p>\n</section>\n\n<section style=\"background:#0c1e35; padding:64px 24px; text-align:center;\" data-kid=\"75\">\n  <p style=\"font-size:11px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:14px;\" data-kid=\"76\">INITIATIVBEWERBUNG</p>\n  <h2 style=\"font-size:24px; font-weight:700; color:#ffffff; margin-bottom:14px; letter-spacing:-0.3px;\" data-kid=\"77\">Kein passendes Angebot gefunden?</h2>\n  <p style=\"font-size:15px; font-weight:300; color:#b8c4d4; margin-bottom:28px; line-height:1.6;\" data-kid=\"78\">Senden Sie uns Ihren Lebenslauf und erzählen Sie uns, wie Sie zum Team beitragen möchten.</p>\n  <a href=\"#\" style=\"display:block; font-size:14px; font-weight:600; color:#ffffff; background:#1a6dd4; padding:16px 24px; border-radius:4px; text-decoration:none; text-align:center;\" data-kid=\"79\">Bewerbung senden</a>\n</section>\n\n<footer style=\"background:#0c1e35; padding:48px 24px 28px;\" data-kid=\"80\">\n  <div style=\"font-size:18px; font-weight:800; color:#ffffff; letter-spacing:-0.5px; margin-bottom:6px;\" data-kid=\"81\">LION <span style=\"font-weight:300; font-size:11px; color:#b8c4d4; letter-spacing:1px;\" data-kid=\"82\">ENGINEERING</span></div>\n  <p style=\"font-size:12px; font-weight:400; color:#b8c4d4; margin-bottom:36px;\" data-kid=\"83\">Ottobrunn · München · EN 9100 zertifiziert</p>\n\n  <div style=\"margin-bottom:32px;\" data-kid=\"84\">\n    <p style=\"font-size:13px; font-weight:700; color:#ffffff; margin-bottom:16px;\" data-kid=\"85\">Unternehmen</p>\n    <div style=\"display:flex; flex-direction:column; gap:12px;\" data-kid=\"86\">\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"87\">Über Lion</a>\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"88\">Zertifizierungen</a>\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"89\">Karriere</a>\n    </div>\n  </div>\n\n  <div style=\"margin-bottom:32px;\" data-kid=\"90\">\n    <p style=\"font-size:13px; font-weight:700; color:#ffffff; margin-bottom:16px;\" data-kid=\"91\">Leistungen</p>\n    <div style=\"display:flex; flex-direction:column; gap:12px;\" data-kid=\"92\">\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"93\">Luft- und Raumfahrt</a>\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"94\">Automotive</a>\n      <a href=\"#\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"95\">Technologie</a>\n    </div>\n  </div>\n\n  <div style=\"margin-bottom:36px;\" data-kid=\"96\">\n    <p style=\"font-size:13px; font-weight:700; color:#ffffff; margin-bottom:16px;\" data-kid=\"97\">Kontakt</p>\n    <div style=\"display:flex; flex-direction:column; gap:10px;\" data-kid=\"98\">\n      <span style=\"font-size:13px; font-weight:400; color:#b8c4d4;\" data-kid=\"99\">Einsteinstr. 10, 85521 Ottobrunn</span>\n      <a href=\"tel:+4989614657200\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"100\">+49 89 6146572-0</a>\n      <a href=\"mailto:info@lion-engineering.de\" style=\"font-size:13px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"101\">info@lion-engineering.de</a>\n    </div>\n  </div>\n\n  <div style=\"border-top:1px solid #132d4f; padding-top:20px;\" data-kid=\"102\">\n    <p style=\"font-size:12px; font-weight:400; color:#b8c4d4; margin-bottom:10px;\" data-kid=\"103\">© 2026 Lion Engineering GmbH.</p>\n    <div style=\"display:flex; gap:20px;\" data-kid=\"104\">\n      <a href=\"#\" style=\"font-size:12px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"105\">Impressum</a>\n      <a href=\"#\" style=\"font-size:12px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"106\">Datenschutz</a>\n    </div>\n  </div>\n</footer>\n",
