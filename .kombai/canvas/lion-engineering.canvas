      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: 'Inter', sans-serif; background: #ffffff; color: #0c1e35; }\n</style>\n\n<nav style=\"background:#ffffff; border-bottom:1px solid #e2e6eb; height:64px; display:flex; align-items:center; padding:0 80px; justify-content:space-between;\" data-kid=\"1\">\n  <div style=\"font-size:20px; font-weight:800; color:#0c1e35; letter-spacing:-0.5px;\" data-kid=\"2\">LION<span style=\"color:#1a6dd4;\" data-kid=\"3\">.</span></div>\n  <div style=\"display:flex; align-items:center; gap:40px;\" data-kid=\"4\">\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"5\">Startseite</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"6\">Leistungen</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"7\">Über uns</a>\n    <a href=\"#\" style=\"font-size:14px; font-weight:500; color:#0c1e35; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"8\">Karriere</a>\n    <a href=\"#\" style=\"background:#1a6dd4; color:#fff; font-size:14px; font-weight:600; padding:12px 20px; border-radius:4px; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"9\">Kontakt</a>\n    <span style=\"font-size:13px; color:#5a6a7e; letter-spacing:0.3px;\" data-kid=\"10\"><strong style=\"color:#0c1e35;\" data-kid=\"11\">DE</strong>&nbsp;|&nbsp;EN</span>\n  </div>\n</nav>\n\n<section style=\"position:relative; min-height:500px; display:flex; align-items:center; overflow:hidden;\" data-kid=\"12\">\n  <img src=\"https://images.pexels.com/photos/30841308/pexels-photo-30841308.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" alt=\"Detailansicht der Helikopter-Rotormechanik\" decoding=\"async\" loading=\"lazy\" style=\"position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;\" data-kid=\"13\">\n  <div style=\"position:absolute; inset:0; background:linear-gradient(90deg, rgba(9,22,39,0.92) 0%, rgba(9,22,39,0.6) 55%, rgba(9,22,39,0.2) 100%);\" data-kid=\"14\"></div>\n  <div style=\"position:relative; z-index:1; padding:96px 96px;\" data-kid=\"15\">\n    <div style=\"max-width:560px;\" data-kid=\"16\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:20px;\" data-kid=\"17\">LEISTUNGEN</p>\n      <h1 style=\"font-size:40px; font-weight:800; color:#ffffff; line-height:1.12; letter-spacing:-0.5px; margin-bottom:24px;\" data-kid=\"18\">Luft- und Raumfahrttechnik</h1>\n      <p style=\"font-size:18px; font-weight:300; color:#b8c4d4; line-height:1.6; max-width:480px;\" data-kid=\"19\">Primär- und Sekundärstrukturen, Simulation, Systemintegration und Projektmanagement für die Luft- und Raumfahrtindustrie.</p>\n    </div>\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#ffffff;\" data-kid=\"20\">\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"21\">\n    <div style=\"max-width:560px;\" data-kid=\"22\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"23\">STRUKTURAUSLEGUNG</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"24\">Primär- und Sekundärstrukturen</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"25\">Auslegung und Analyse von Rumpf, Spanten, Halterungen und Verbundstrukturen für Dreh- und Starrflügler.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"26\">Mehr erfahren →</a>\n    </div>\n  </div>\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"27\">\n    <img src=\"https://images.pexels.com/photos/13316850/pexels-photo-13316850.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Nahaufnahme von Flugzeugstruktur-Nieten und -Paneelen\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"28\">\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#f6f7f9;\" data-kid=\"29\">\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"30\">\n    <img src=\"https://images.pexels.com/photos/3862149/pexels-photo-3862149.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Ingenieure bei der FEM-Simulationsarbeit\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"31\">\n  </div>\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"32\">\n    <div style=\"max-width:560px;\" data-kid=\"33\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"34\">BERECHNUNG &amp; SIMULATION</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"35\">FEM-Analyse &amp; Lastfälle</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"36\">Ermüdungs-, statische und dynamische Strukturanalysen mit branchenüblichen Tools. Nachweise gemäß EASA CS-27/29 und LTH.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"37\">Mehr erfahren →</a>\n    </div>\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#ffffff;\" data-kid=\"38\">\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"39\">\n    <div style=\"max-width:560px;\" data-kid=\"40\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"41\">SYSTEMINTEGRATION</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"42\">Avionik &amp; mechanische Systeme</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"43\">Integration von Hydraulik-, Elektro- und Mechanik-Systemen in die Flugzeugstruktur. Schnittstellenmanagement mit Zulieferern.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"44\">Mehr erfahren →</a>\n    </div>\n  </div>\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"45\">\n    <img src=\"https://images.pexels.com/photos/3913017/pexels-photo-3913017.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Ingenieur am CAD-Arbeitsplatz mit Engineering-Software\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"46\">\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#f6f7f9;\" data-kid=\"47\">\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"48\">\n    <img src=\"https://images.pexels.com/photos/30841298/pexels-photo-30841298.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Detailansicht der Helikopter-Montage\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"49\">\n  </div>\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"50\">\n    <div style=\"max-width:560px;\" data-kid=\"51\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"52\">PROZESSENGINEERING</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"53\">Fertigungs- und Montageprozesse</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"54\">Definition und Optimierung von Fertigungsprozessen für Luftfahrtkomponenten inkl. Quality-Gates und Betriebsmittelkonzept.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"55\">Mehr erfahren →</a>\n    </div>\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#ffffff;\" data-kid=\"56\">\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"57\">\n    <div style=\"max-width:560px;\" data-kid=\"58\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"59\">QUALIFIKATION &amp; DOKUMENTATION</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"60\">Musterprüfungsunterstützung</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"61\">Erstellung von Zulassungsdokumentation, Prüfplänen und Qualifikationsberichten nach EASA- und FAA-Anforderungen.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"62\">Mehr erfahren →</a>\n    </div>\n  </div>\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"63\">\n    <img src=\"https://images.pexels.com/photos/3862373/pexels-photo-3862373.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Ingenieure bei der Überprüfung technischer Dokumentation\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"64\">\n  </div>\n</section>\n\n<section style=\"display:flex; min-height:420px; background:#f6f7f9;\" data-kid=\"65\">\n  <div style=\"width:40%; overflow:hidden;\" data-kid=\"66\">\n    <img src=\"https://images.pexels.com/photos/6285157/pexels-photo-6285157.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Ingenieure im Projektbesprechung mit Bauplänen\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"67\">\n  </div>\n  <div style=\"width:60%; display:flex; align-items:center; padding:64px 96px;\" data-kid=\"68\">\n    <div style=\"max-width:560px;\" data-kid=\"69\">\n      <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"70\">PROJEKTMANAGEMENT</p>\n      <h2 style=\"font-size:22px; font-weight:700; color:#0c1e35; line-height:1.3; margin-bottom:16px;\" data-kid=\"71\">Technische Projektleitung</h2>\n      <p style=\"font-size:16px; font-weight:300; color:#2d3a4a; line-height:1.6; margin-bottom:24px;\" data-kid=\"72\">Ganzheitliches Projektmanagement für Engineering-Pakete – Steuerung von Umfang, Terminen und Schnittstellen mit OEM-Projektteams.</p>\n      <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#1a6dd4; text-decoration:none;\" data-kid=\"73\">Mehr erfahren →</a>\n    </div>\n  </div>\n</section>\n\n<section style=\"height:480px; overflow:hidden;\" data-kid=\"74\">\n  <img src=\"https://images.pexels.com/photos/5493554/pexels-photo-5493554.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\" alt=\"Weitwinkelansicht der Triebwerksturbinenschaufeln eines Großflugzeugs\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover; object-position:center 40%;\" data-kid=\"75\">\n</section>\n\n<section style=\"background:#0c1e35; padding:80px 0 0 0;\" data-kid=\"76\">\n  <div style=\"padding:0 96px 64px;\" data-kid=\"77\">\n    <p style=\"font-size:12px; font-weight:700; color:#d4881a; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:16px;\" data-kid=\"78\">UNSERE LEISTUNGEN</p>\n    <h2 style=\"font-size:28px; font-weight:700; color:#ffffff; line-height:1.2;\" data-kid=\"79\">Weitere Kompetenzbereiche</h2>\n  </div>\n  <div style=\"display:flex; height:360px;\" data-kid=\"80\">\n    <div style=\"width:50%; position:relative; overflow:hidden;\" data-kid=\"81\">\n      <img src=\"https://images.pexels.com/photos/19233057/pexels-photo-19233057.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Hochmoderne Roboter-Montagelinie in der Automobilindustrie\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover; transition:transform 0.4s ease;\" data-kid=\"82\">\n      <div style=\"position:absolute; inset:0; background:linear-gradient(to top, rgba(9,22,39,0.88) 0%, rgba(9,22,39,0.2) 50%, transparent 100%);\" data-kid=\"83\"></div>\n      <div style=\"position:absolute; bottom:40px; left:48px;\" data-kid=\"84\">\n        <h3 style=\"font-size:22px; font-weight:700; color:#ffffff; margin-bottom:12px;\" data-kid=\"85\">AUTOMOTIVE</h3>\n        <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#ffffff; text-decoration:none; opacity:0.85;\" data-kid=\"86\">Entdecken →</a>\n      </div>\n    </div>\n    <div style=\"width:50%; position:relative; overflow:hidden;\" data-kid=\"87\">\n      <img src=\"https://images.pexels.com/photos/5506047/pexels-photo-5506047.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Modernes Engineering-Technologielabor\" decoding=\"async\" loading=\"lazy\" style=\"width:100%; height:100%; object-fit:cover;\" data-kid=\"88\">\n      <div style=\"position:absolute; inset:0; background:linear-gradient(to top, rgba(9,22,39,0.88) 0%, rgba(9,22,39,0.2) 50%, transparent 100%);\" data-kid=\"89\"></div>\n      <div style=\"position:absolute; bottom:40px; left:48px;\" data-kid=\"90\">\n        <h3 style=\"font-size:22px; font-weight:700; color:#ffffff; margin-bottom:12px;\" data-kid=\"91\">TECHNOLOGIE</h3>\n        <a href=\"#\" style=\"font-size:14px; font-weight:600; color:#ffffff; text-decoration:none; opacity:0.85;\" data-kid=\"92\">Entdecken →</a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section style=\"background:#0c1e35; padding:80px 96px; text-align:center; border-top:1px solid #132d4f;\" data-kid=\"93\">\n  <h2 style=\"font-size:28px; font-weight:700; color:#ffffff; margin-bottom:24px; line-height:1.2;\" data-kid=\"94\">Lassen Sie uns Ihre Anforderungen besprechen</h2>\n  <a href=\"#\" style=\"display:inline-block; background:#1a6dd4; color:#ffffff; font-size:14px; font-weight:600; padding:14px 28px; border-radius:4px; text-decoration:none; letter-spacing:0.2px;\" data-kid=\"95\">Kontakt aufnehmen</a>\n</section>\n\n<footer style=\"background:#0c1e35; padding:64px 96px 0;\" data-kid=\"96\">\n  <div style=\"display:grid; grid-template-columns:1fr 1fr 1fr; gap:64px; padding-bottom:48px;\" data-kid=\"97\">\n    <div data-kid=\"98\">\n      <div style=\"font-size:18px; font-weight:800; color:#ffffff; letter-spacing:-0.3px; margin-bottom:24px;\" data-kid=\"99\">LION<span style=\"color:#1a6dd4;\" data-kid=\"100\">.</span></div>\n      <p style=\"font-size:14px; font-weight:300; color:#b8c4d4; line-height:1.6;\" data-kid=\"101\">Präzisions-Engineering für Luft- und Raumfahrt sowie Automotive – aus Ottobrunn bei München.</p>\n    </div>\n    <div data-kid=\"102\">\n      <h4 style=\"font-size:18px; font-weight:700; color:#ffffff; margin-bottom:20px;\" data-kid=\"103\">Leistungen</h4>\n      <div style=\"display:flex; flex-direction:column; gap:12px;\" data-kid=\"104\">\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"105\">Luft- und Raumfahrt</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"106\">Automotive</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"107\">Technologie</a>\n        <a href=\"#\" style=\"font-size:14px; font-weight:400; color:#b8c4d4; text-decoration:none;\" data-kid=\"108\">Zertifizierungen</a>\n      </div>\n    </div>\n    <div data-kid=\"109\">\n      <h4 style=\"font-size:18px; font-weight:700; color:#ffffff; margin-bottom:20px;\" data-kid=\"110\">Kontakt</h4>\n      <div style=\"display:flex; flex-direction:column; gap:12px;\" data-kid=\"111\">\n        <span style=\"font-size:14px; font-weight:300; color:#b8c4d4;\" data-kid=\"112\">Einsteinstr. 10, 85521 Ottobrunn</span>\n        <span style=\"font-size:14px; font-weight:300; color:#b8c4d4;\" data-kid=\"113\">+49 89 6146572-0</span>\n        <a href=\"mailto:info@lion-engineering.de\" style=\"font-size:14px; font-weight:300; color:#b8c4d4; text-decoration:none;\" data-kid=\"114\">info@lion-engineering.de</a>\n      </div>\n    </div>\n  </div>\n  <div style=\"border-top:1px solid #132d4f; padding:24px 0; display:flex; justify-content:space-between; align-items:center;\" data-kid=\"115\">\n    <span style=\"font-size:13px; color:#5a6a7e;\" data-kid=\"116\">© 2026 Lion Engineering GmbH</span>\n    <div style=\"display:flex; gap:24px;\" data-kid=\"117\">\n      <a href=\"#\" style=\"font-size:13px; color:#5a6a7e; text-decoration:none;\" data-kid=\"118\">Impressum</a>\n      <a href=\"#\" style=\"font-size:13px; color:#5a6a7e; text-decoration:none;\" data-kid=\"119\">Datenschutz</a>\n    </div>\n  </div>\n</footer>\n",
