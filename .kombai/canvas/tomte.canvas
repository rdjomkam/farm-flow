; padding: 14px 0; border-bottom: 1px solid #F0E8DE; align-items: center;\" data-kid=\"180\">\n            <span style=\"font-weight: 600; color: #36454F; font-size: 15px;\" data-kid=\"181\">Dienstag</span>\n            <span style=\"color: #5A6E7A; font-size: 14px; text-align: right;\" data-kid=\"182\">8:30–12:30 &amp; 14:00–19:00</span>\n          </div>\n          <div style=\"display: flex; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid #F0E8DE; align-items: center;\" data-kid=\"183\">\n            <span style=\"font-weight: 600; color: #36454F; font-size: 15px;\" data-kid=\"184\">Mittwoch</span>\n            <span style=\"color: #5A6E7A; font-size: 14px;\" data-kid=\"185\">8:30–13:00</span>\n          </div>\n          <div style=\"display: flex; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid #F0E8DE; align-items: center;\" data-kid=\"186\">\n            <span style=\"font-weight: 600; color: #36454F; font-size: 15px;\" data-kid=\"187\">Donnerstag</span>\n            <span style=\"color: #5A6E7A; font-size: 14px; text-align: right;\" data-kid=\"188\">8:30–12:30 &amp; 14:00–18:00</span>\n          </div>\n          <div style=\"display: flex; justify-content: space-between; padding: 14px 0; align-items: center;\" data-kid=\"189\">\n            <span style=\"font-weight: 600; color: #36454F; font-size: 15px;\" data-kid=\"190\">Freitag</span>\n            <span style=\"color: #5A6E7A; font-size: 14px;\" data-kid=\"191\">8:30–13:00</span>\n          </div>\n        </div>\n        <div style=\"margin-top: 20px; padding: 14px 18px; background: #F2E8EF; border-radius: 10px; font-size: 13px; color: #5A6E7A; font-style: italic; display: flex; align-items: center; gap: 8px;\" data-kid=\"192\">\n          <i class=\"ti ti-phone\" style=\"color: #6B3558; font-size: 15px;\" data-kid=\"193\"></i>\n          … und nach telefonischer Vereinbarung\n        </div>\n      </div>\n      <div data-kid=\"194\">\n        <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;\" data-kid=\"195\">Was Patienten sagen</div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 26px; font-weight: 700; color: #36454F; margin: 0 0 28px 0;\" data-kid=\"196\">Patientenstimmen</h3>\n        <div style=\"display: flex; flex-direction: column; gap: 20px; margin-bottom: 28px;\" data-kid=\"197\">\n          <div style=\"background: #FFFFFF; border-radius: 16px; padding: 28px; box-shadow: 0 2px 16px rgba(54,69,79,0.06);\" data-kid=\"198\">\n            <div style=\"display: flex; gap: 4px; margin-bottom: 12px;\" data-kid=\"199\">\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"200\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"201\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"202\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"203\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"204\"></i>\n            </div>\n            <p style=\"font-size: 15px; color: #5A6E7A; line-height: 1.7; margin: 0 0 14px 0; font-style: italic;\" data-kid=\"205\">\"Sehr freundliche und einfühlsame Behandlung. Dr. Tomte erklärt alles verständlich und ist sehr geduldig. Ich fühle mich hier bestens aufgehoben.\"</p>\n            <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"206\">\n              <img src=\"https://i.pravatar.cc/36?u=patient1\" alt=\"Patient\" decoding=\"async\" loading=\"lazy\" style=\"width: 36px; height: 36px; border-radius: 50%;\" data-kid=\"207\">\n              <div data-kid=\"208\">\n                <div style=\"font-size: 14px; font-weight: 600; color: #36454F;\" data-kid=\"209\">Maria S.</div>\n                <div style=\"font-size: 12px; color: #6B3558;\" data-kid=\"210\">via Jameda</div>\n              </div>\n            </div>\n          </div>\n          <div style=\"background: #FFFFFF; border-radius: 16px; padding: 28px; box-shadow: 0 2px 16px rgba(54,69,79,0.06);\" data-kid=\"211\">\n            <div style=\"display: flex; gap: 4px; margin-bottom: 12px;\" data-kid=\"212\">\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"213\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"214\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"215\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"216\"></i>\n              <i class=\"ti ti-star-filled\" style=\"color: #F5A623; font-size: 16px;\" data-kid=\"217\"></i>\n            </div>\n            <p style=\"font-size: 15px; color: #5A6E7A; line-height: 1.7; margin: 0 0 14px 0; font-style: italic;\" data-kid=\"218\">\"Die Kinderecke ist toll — meine Kinder gehen sogar gerne zum Zahnarzt! Das ganze Team ist herzlich und professionell.\"</p>\n            <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"219\">\n              <img src=\"https://i.pravatar.cc/36?u=patient2\" alt=\"Patient\" decoding=\"async\" loading=\"lazy\" style=\"width: 36px; height: 36px; border-radius: 50%;\" data-kid=\"220\">\n              <div data-kid=\"221\">\n                <div style=\"font-size: 14px; font-weight: 600; color: #36454F;\" data-kid=\"222\">Thomas K.</div>\n                <div style=\"font-size: 12px; color: #6B3558;\" data-kid=\"223\">via Sanego</div>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div style=\"display: flex; gap: 12px;\" data-kid=\"224\">\n          <a href=\"#\" style=\"display: flex; align-items: center; gap: 8px; background: #6B3558; color: