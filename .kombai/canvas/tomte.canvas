      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Public+Sans:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n<div style=\"font-family: 'Public Sans', sans-serif; color: #36454F; background-color: #FAF0E6; min-width: 375px;\" data-kid=\"1\">\n\n  <header style=\"background: white; border-bottom: 1px solid #F2E8EF; height: 60px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px;\" data-kid=\"2\">\n    <div style=\"display: flex; align-items: center; gap: 8px;\" data-kid=\"3\">\n      <div style=\"width: 32px; height: 32px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"4\">\n        <i class=\"ti ti-tooth\" style=\"color: white; font-size: 15px;\" data-kid=\"5\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; font-weight: 600; font-size: 18px; color: #36454F;\" data-kid=\"6\">Dr. Tomte</span>\n    </div>\n    <button style=\"width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;\" data-kid=\"7\">\n      <i class=\"ti ti-menu-2\" style=\"font-size: 24px; color: #36454F;\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  <section style=\"background: #FAF0E6; padding: 44px 20px 36px; text-align: center;\" data-kid=\"9\">\n    <p style=\"font-size: 11px; font-weight: 600; color: #6B3558; letter-spacing: 0.15em; text-transform: uppercase; margin: 0 0 10px;\" data-kid=\"10\">Home · Über uns</p>\n    <h1 style=\"font-family: 'Lora', serif; font-size: 34px; font-weight: 700; color: #36454F; line-height: 1.2; margin: 0 0 12px;\" data-kid=\"11\">Unser Team</h1>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.65; margin: 0; line-height: 1.6;\" data-kid=\"12\">Persönliche Betreuung von Anfang an</p>\n  </section>\n\n  <section style=\"background: white; padding: 28px 20px;\" data-kid=\"13\">\n    <div style=\"width: 100%; height: 260px; background: #F2E8EF; border-radius: 20px; border: 1px solid rgba(107,53,88,0.3); display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 22px;\" data-kid=\"14\">\n      <i class=\"ti ti-user-circle\" style=\"font-size: 72px; color: #6B3558; margin-bottom: 8px;\" data-kid=\"15\"></i>\n      <span style=\"font-size: 13px; color: #6B3558; font-weight: 500;\" data-kid=\"16\">[Foto: Dr. Tomte Portrait]</span>\n    </div>\n    <div style=\"margin-bottom: 14px;\" data-kid=\"17\">\n      <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 600; color: #36454F; margin: 0 0 10px; line-height: 1.3;\" data-kid=\"18\">Dr. med. dent.<br data-kid=\"19\">Laurice Thierry Tomte</h2>\n      <span style=\"display: inline-block; background: #6B3558; color: white; font-size: 12px; font-weight: 600; padding: 4px 14px; border-radius: 20px;\" data-kid=\"20\">Zahnärztin</span>\n    </div>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.72; line-height: 1.72; margin: 0 0 20px;\" data-kid=\"21\">Dr. Tomte führt ihre Praxis im Herzen Nymphenburg mit Leidenschaft und einem hohen wissenschaftlichen Anspruch. Ihr besonderes Anliegen ist die einfühlsame Behandlung — besonders bei Kindern und ängstlichen Patienten.</p>\n    <p style=\"font-size: 11px; color: #36454F; opacity: 0.45; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 10px;\" data-kid=\"22\">Spricht</p>\n    <div style=\"display: flex; gap: 8px; flex-wrap: wrap;\" data-kid=\"23\">\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 12px; font-weight: 600; padding: 5px 13px; border-radius: 20px; border: 1px solid rgba(107,53,88,0.3);\" data-kid=\"24\">🇩🇪 Deutsch</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 12px; font-weight: 600; padding: 5px 13px; border-radius: 20px; border: 1px solid rgba(107,53,88,0.3);\" data-kid=\"25\">🇫🇷 Français</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 12px; font-weight: 600; padding: 5px 13px; border-radius: 20px; border: 1px solid rgba(107,53,88,0.3);\" data-kid=\"26\">🇬🇧 English</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 12px; font-weight: 600; padding: 5px 13px; border-radius: 20px; border: 1px solid rgba(107,53,88,0.3);\" data-kid=\"27\">🇹🇷 Türkçe</span>\n    </div>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 28px 20px;\" data-kid=\"28\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 18px;\" data-kid=\"29\">Unser Team</h2>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 12px;\" data-kid=\"30\">\n      <div style=\"background: white; border-radius: 16px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"31\">\n        <img src=\"https://i.pravatar.cc/80?u=azime\" decoding=\"async\" loading=\"lazy\" alt=\"Azime Kaya\" style=\"width: 64px; height: 64px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px; display: block; border: 2.5px solid #F2E8EF;\" data-kid=\"32\">\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0 0 4px; line-height: 1.3;\" data-kid=\"33\">Azime Kaya</p>\n        <p style=\"font-size: 11px; color: #6B3558; font-weight: 500; margin: 0;\" data-kid=\"34\">Zahnarzthelferin</p>\n      </div>\n      <div style=\"background: white; border-radius: 16px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"35\">\n        <img src=\"https://i.pravatar.cc/80?u=christina\" decoding=\"async\" loading=\"lazy\" alt=\"Christina Spengler\" style=\"width: 64px; height: 64px; border-radius: 50%; object-fit: cover; margin: 0 auto 12px; display: block; border: 2.5px solid #F2E8EF;\" data-kid=\"36\">\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0 0 4px; line-height: 1.3;\" data-kid=\"37\">Christina Spengler</p>\n        <p style=\"font-size: 11px; color: #6B3558; font-weight: 500; margin: 0;\" data-kid=\"38\">Abrechnung</p>\n      </div>\n      <div style=\"background: white; border-radius: 16px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF; grid-column: span 2; display: flex; align-items: center; gap: 16px; text-align: left;\" data-kid=\"39\">\n        <img src=\"https://i.pravatar.cc/80?u=jehan\" decoding=\"async\" loading=\"lazy\" alt=\"Jehan Smaael Kheder\" style=\"width: 56px; height: 56px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2.5px solid #F2E8EF;\" data-kid=\"40\">\n        <div data-kid=\"41\">\n          <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0 0 3px;\" data-kid=\"42\">Jehan Smaael Kheder</p>\n          <p style=\"font-size: 11px; color: #6B3558; font-weight: 500; margin: 0 0 4px;\" data-kid=\"43\">Auszubildende</p>\n          <span style=\"background: rgba(107,53,88,0.12); color: #6B3558; font-size: 10px; font-weight: 600; padding: 2px 10px; border-radius: 10px;\" data-kid=\"44\">Nachwuchs 🌱</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #F2E8EF; padding: 28px 20px;\" data-kid=\"45\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 18px;\" data-kid=\"46\">Unsere Werte</h2>\n    <div style=\"display: flex; flex-direction: column; gap: 12px;\" data-kid=\"47\">\n      <div style=\"background: white; border-radius: 14px; padding: 18px 16px; display: flex; align-items: flex-start; gap: 13px;\" data-kid=\"48\">\n        <div style=\"width: 44px; height: 44px; background: rgba(107,53,88,0.12); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"49\">\n          <i class=\"ti ti-heart\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"50\"></i>\n        </div>\n        <div data-kid=\"51\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 4px;\" data-kid=\"52\">Warme Atmosphäre</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.65; margin: 0; line-height: 1.55;\" data-kid=\"53\">Wir nehmen uns Zeit für Sie – in einer ruhigen, freundlichen Umgebung.</p>\n        </div>\n      </div>\n      <div style=\"background: white; border-radius: 14px; padding: 18px 16px; display: flex; align-items: flex-start; gap: 13px;\" data-kid=\"54\">\n        <div style=\"width: 44px; height: 44px; background: rgba(107,53,88,0.12); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"55\">\n          <i class=\"ti ti-shield-check\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"56\"></i>\n        </div>\n        <div data-kid=\"57\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 4px;\" data-kid=\"58\">Höchste Standards</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.65; margin: 0; line-height: 1.55;\" data-kid=\"59\">Neueste Medizintechnik und höchstes wissenschaftliches Niveau.</p>\n        </div>\n      </div>\n      <div style=\"background: white; border-radius: 14px; padding: 18px 16px; display: flex; align-items: flex-start; gap: 13px;\" data-kid=\"60\">\n        <div style=\"width: 44px; height: 44px; background: rgba(107,53,88,0.12); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"61\">\n          <i class=\"ti ti-currency-euro\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"62\"></i>\n        </div>\n        <div data-kid=\"63\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 4px;\" data-kid=\"64\">Transparente Kosten</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.65; margin: 0; line-height: 1.55;\" data-kid=\"65\">Behandlungspläne erläutern wir Ihnen fair und verständlich.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: white; padding: 28px 20px;\" data-kid=\"66\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 8px;\" data-kid=\"67\">Wir sprechen Ihre Sprache</h2>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.62; margin: 0 0 18px; line-height: 1.6;\" data-kid=\"68\">Beratung und Behandlung in vier Sprachen — für Ihre Sicherheit.</p>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 12px;\" data-kid=\"69\">\n      <div style=\"background: #FAF0E6; border-radius: 14px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"70\">\n        <div style=\"font-size: 32px; margin-bottom: 8px;\" data-kid=\"71\">🇩🇪</div>\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0;\" data-kid=\"72\">Deutsch</p>\n      </div>\n      <div style=\"background: #FAF0E6; border-radius: 14px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"73\">\n        <div style=\"font-size: 32px; margin-bottom: 8px;\" data-kid=\"74\">🇫🇷</div>\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0;\" data-kid=\"75\">Français</p>\n      </div>\n      <div style=\"background: #FAF0E6; border-radius: 14px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"76\">\n        <div style=\"font-size: 32px; margin-bottom: 8px;\" data-kid=\"77\">🇬🇧</div>\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0;\" data-kid=\"78\">English</p>\n      </div>\n      <div style=\"background: #FAF0E6; border-radius: 14px; padding: 20px 14px; text-align: center; border: 1px solid #F2E8EF;\" data-kid=\"79\">\n        <div style=\"font-size: 32px; margin-bottom: 8px;\" data-kid=\"80\">🇹🇷</div>\n        <p style=\"font-size: 13px; font-weight: 600; color: #36454F; margin: 0;\" data-kid=\"81\">Türkçe</p>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 20px;\" data-kid=\"82\">\n    <div style=\"background: white; border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 14px; border: 1px solid #F2E8EF;\" data-kid=\"83\">\n      <div style=\"width: 48px; height: 48px; background: rgba(107,53,88,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"84\">\n        <i class=\"ti ti-briefcase\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"85\"></i>\n      </div>\n      <div style=\"flex: 1;\" data-kid=\"86\">\n        <p style=\"font-size: 10px; font-weight: 600; color: #6B3558; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 3px;\" data-kid=\"87\">Wir suchen</p>\n        <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 3px;\" data-kid=\"88\">ZMF gesucht!</h3>\n        <p style=\"font-size: 12px; color: #36454F; opacity: 0.6; margin: 0 0 12px;\" data-kid=\"89\">Zahnmedizinische Fachangestellte</p>\n        <button style=\"background: #6B3558; color: white; border: none; padding: 8px 18px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'Public Sans', sans-serif; display: inline-flex; align-items: center; gap: 5px;\" data-kid=\"90\">\n          <i class=\"ti ti-send\" style=\"font-size: 13px;\" data-kid=\"91\"></i>Jetzt bewerben\n        </button>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #36454F; padding: 44px 20px; text-align: center;\" data-kid=\"92\">\n    <p style=\"font-size: 14px; color: rgba(255,255,255,0.5); margin: 0 0 8px; font-style: italic; font-family: 'Lora', serif;\" data-kid=\"93\">„Wir freuen uns auf Ihr Lächeln!\"</p>\n    <h2 style=\"font-family: 'Lora', serif; font-size: 24px; font-weight: 600; color: white; margin: 0 0 12px;\" data-kid=\"94\">Lernen Sie uns kennen</h2>\n    <p style=\"font-size: 14px; color: rgba(255,255,255,0.62); margin: 0 0 28px; line-height: 1.6;\" data-kid=\"95\">Vereinbaren Sie noch heute Ihren ersten Termin.</p>\n    <button style=\"width: 100%; max-width: 295px; background: #6B3558; color: white; border: none; padding: 15px 24px; border-radius: 40px; font-size: 15px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Public Sans', sans-serif;\" data-kid=\"96\">\n      <i class=\"ti ti-calendar\" data-kid=\"97\"></i>Termin vereinbaren\n    </button>\n  </section>\n\n  <footer style=\"background: #2A1E28; padding: 32px 20px 24px;\" data-kid=\"98\">\n    <div style=\"display: flex; align-items: center; gap: 10px; margin-bottom: 18px;\" data-kid=\"99\">\n      <div style=\"width: 30px; height: 30px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"100\">\n        <i class=\"ti ti-tooth\" style=\"color: white; font-size: 14px;\" data-kid=\"101\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; color: white; font-weight: 600; font-size: 14px;\" data-kid=\"102\">Zahnarztpraxis Dr. Tomte</span>\n    </div>\n    <p style=\"font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.8; margin: 0 0 20px;\" data-kid=\"103\">Volpinistraße 19<br data-kid=\"104\">80638 München – Nymphenburg</p>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;\" data-kid=\"105\">\n      <div data-kid=\"106\">\n        <p style=\"font-size: 10px; color: rgba(255,255,255,0.35); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 8px;\" data-kid=\"107\">Kontakt</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 4px;\" data-kid=\"108\">089 / 178 33 50</p>\n        <p style=\"font-size: 11px; color: rgba(255,255,255,0.55); margin: 0;\" data-kid=\"109\">praxis@zahnarztpraxis-tomte.de</p>\n      </div>\n      <div data-kid=\"110\">\n        <p style=\"font-size: 10px; color: rgba(255,255,255,0.35); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 8px;\" data-kid=\"111\">Navigation</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"112\">Home</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"113\">Praxis</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"114\">Über uns</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0;\" data-kid=\"115\">Leistungen</p>\n      </div>\n    </div>\n    <div style=\"border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;\" data-kid=\"116\">\n      <p style=\"font-size: 11px; color: rgba(255,255,255,0.32); margin: 0;\" data-kid=\"117\">© Dr. Tomte 2012–2025</p>\n      <div style=\"display: flex; gap: 14px; font-size: 11px; color: rgba(255,255,255,0.32);\" data-kid=\"118\">\n        <span data-kid=\"119\">Datenschutz</span><span data-kid=\"120\">Impressum</span>\n      </div>\n    </div>\n  </footer>\n\n  <div style=\"background: white; border-top: 1.5px solid #F2E8EF; padding: 12px 16px; display: flex; gap: 12px;\" data-kid=\"121\">\n    <button style=\"flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 13px; border-radius: 12px; border: 1.5px solid #6B3558; background: none; color: #6B3558; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Public Sans', sans-serif;\" data-kid=\"122\">\n      <i class=\"ti ti-phone\" style=\"font-size: 16px;\" data-kid=\"123\"></i><span data-kid=\"124\">Anrufen</span>\n    </button>\n    <button style=\"flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 13px; border-radius: 12px; border: none; background: #6B3558; color: white; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Public Sans', sans-serif;\" data-kid=\"125\">\n      <i class=\"ti ti-calendar\" style=\"font-size: 16px;\" data-kid=\"126\"></i><span data-kid=\"127\">Termin</span>\n    </button>\n  </div>\n</div>",
