g:2px 8px;border-radius:4px;\" data-kid=\"78\">Tram</span>\n              <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"79\">17 – Romanplatz</span>\n            </div>\n            <p style=\"font-size:12px;color:#6f5a68;margin:0;\" data-kid=\"80\">Direkte Verbindung ins Nymphenburg-Viertel</p>\n          </div>\n          <div style=\"background:#F2E8EF;border-radius:12px;padding:14px 16px;\" data-kid=\"81\">\n            <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:5px;\" data-kid=\"82\">\n              <span style=\"background:#3C8A2E;color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px;\" data-kid=\"83\">Bus</span>\n              <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"84\">68 – Haltestelle Nymphenburg</span>\n            </div>\n            <p style=\"font-size:12px;color:#6f5a68;margin:0;\" data-kid=\"85\">Wenige Gehminuten entfernt</p>\n          </div>\n        </div>\n      </div>\n      <div style=\"border:1.5px solid #ead4e4;border-radius:22px;padding:38px;background:#fdfcfa;\" data-kid=\"86\">\n        <div style=\"width:52px;height:52px;background:#F2E8EF;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:22px;\" data-kid=\"87\">\n          <i class=\"ti ti-car\" style=\"font-size:26px;color:#6B3558;\" data-kid=\"88\"></i>\n        </div>\n        <h3 style=\"font-family:'Lora',serif;font-size:20px;font-weight:600;color:#36454F;margin:0 0 18px;\" data-kid=\"89\">Mit dem Auto</h3>\n        <div style=\"display:flex;flex-direction:column;gap:14px;\" data-kid=\"90\">\n          <div data-kid=\"91\">\n            <p style=\"font-size:14px;font-weight:600;color:#36454F;margin:0 0 5px;\" data-kid=\"92\">Aus der Innenstadt (A8 / B2R)</p>\n            <p style=\"font-size:13px;color:#6f5a68;line-height:1.65;margin:0;\" data-kid=\"93\">Richtung Nymphenburg, Ausfahrt Schlossanlage, dann Richtung Neuhausen/Nymphenburg.</p>\n          </div>\n          <div style=\"background:#F2E8EF;border-radius:12px;padding:14px 16px;display:flex;gap:10px;align-items:flex-start;\" data-kid=\"94\">\n            <i class=\"ti ti-parking\" style=\"font-size:20px;color:#6B3558;flex-shrink:0;margin-top:1px;\" data-kid=\"95\"></i>\n            <div data-kid=\"96\">\n              <p style=\"font-size:13px;font-weight:600;color:#36454F;margin:0 0 4px;\" data-kid=\"97\">Parkmöglichkeiten</p>\n              <p style=\"font-size:13px;color:#6f5a68;margin:0;\" data-kid=\"98\">Kostenlose Parkmöglichkeiten in der Volpinistraße und umliegenden Straßen vorhanden.</p>\n            </div>\n          </div>\n          <div style=\"display:flex;gap:10px;align-items:flex-start;\" data-kid=\"99\">\n            <i class=\"ti ti-info-circle\" style=\"font-size:18px;color:#6B3558;flex-shrink:0;margin-top:1px;\" data-kid=\"100\"></i>\n            <p style=\"font-size:13px;color:#6f5a68;line-height:1.6;margin:0;\" data-kid=\"101\">Bitte beachten Sie die Parkzonen in der Umgebung (Bewohnerparkzone). Parken ist meist auf der Straße möglich.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background:#FAF0E6;padding:88px 80px;\" data-kid=\"102\">\n    <div style=\"max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;\" data-kid=\"103\">\n      <div style=\"background:#e5c4d8;border-radius:24px;height:380px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;border:2px dashed #6B3558;\" data-kid=\"104\">\n        <i class=\"ti ti-building\" style=\"font-size:44px;color:#6B3558;opacity:0.5;\" data-kid=\"105\"></i>\n        <p style=\"font-size:13px;color:#7a3a64;text-align:center;padding:0 32px;font-style:italic;line-height:1.5;\" data-kid=\"106\">[Foto: Hauseingang Volpinistraße 19 — seitlicher Eingang]</p>\n      </div>\n      <div data-kid=\"107\">\n        <span style=\"background:#F2E8EF;color:#6B3558;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:5px 16px;border-radius:50px;display:inline-block;margin-bottom:22px;\" data-kid=\"108\">Eingang &amp; Orientierung</span>\n        <h2 style=\"font-family:'Lora',serif;font-size:34px;font-weight:700;color:#36454F;margin:0 0 22px;line-height:1.25;\" data-kid=\"109\">Den Eingang finden</h2>\n        <div style=\"background:#fff;border-radius:18px;padding:28px;display:flex;gap:16px;align-items:flex-start;box-shadow:0 2px 14px rgba(0,0,0,0.06);margin-bottom:22px;\" data-kid=\"110\">\n          <div style=\"width:46px;height:46px;background:#F2E8EF;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;\" data-kid=\"111\">\n            <i class=\"ti ti-door-enter\" style=\"font-size:23px;color:#6B3558;\" data-kid=\"112\"></i>\n          </div>\n          <div data-kid=\"113\">\n            <h3 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0 0 8px;\" data-kid=\"114\">Seitlicher Eingang</h3>\n            <p style=\"font-size:14px;color:#6f5a68;line-height:1.68;margin:0;\" data-kid=\"115\">Der Eingang zur Praxis <strong data-kid=\"116\">befindet sich seitlich des Hauses</strong>. Bitte folgen Sie dem Weg an der linken Gebäudeseite entlang bis zur Eingangstür.</p>\n          </div>\n        </div>\n        <div style=\"background:#fff;border-radius:18px;padding:28px;display:flex;gap:16px;align-items:flex-start;box-shadow:0 2px 14px rgba(0,0,0,0.06);\" data-kid=\"117\">\n          <div style=\"width:46px;height:46px;background:#F2E8EF;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;\" data-kid=\"118\">\n            <i class=\"ti ti-map-pin\" style=\"font-size:23px;color:#6B3558;\" data-kid=\"119\"></i>\n          </div>\n          <div data-kid=\"120\">\n            <h3 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0 0 8px;\" data-kid=\"1