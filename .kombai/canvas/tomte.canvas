      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Public+Sans:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n\n<div style=\"font-family: 'Public Sans', sans-serif; background-color: #FAF0E6; color: #36454F; width: 375px;\" data-kid=\"1\">\n\n  <header style=\"position: sticky; top: 0; z-index: 50; background: #FFFFFF; box-shadow: 0 1px 6px rgba(0,0,0,0.08); height: 60px; display: flex; align-items: center; justify-content: space-between; padding: 0 18px;\" data-kid=\"2\">\n    <div style=\"display: flex; align-items: center; gap: 8px;\" data-kid=\"3\">\n      <div style=\"width: 34px; height: 34px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center;\" data-kid=\"4\">\n        <i class=\"ti ti-tooth\" style=\"font-size: 17px; color: #FFFFFF;\" data-kid=\"5\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; font-weight: 600; font-size: 15px; color: #36454F; letter-spacing: -0.2px;\" data-kid=\"6\">Dr. Tomte</span>\n    </div>\n    <button style=\"background: none; border: none; padding: 6px; cursor: pointer;\" data-kid=\"7\">\n      <i class=\"ti ti-menu-2\" style=\"font-size: 24px; color: #36454F;\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  <section style=\"background: #FAF0E6; padding-bottom: 0;\" data-kid=\"9\">\n    <div style=\"position: relative; width: 375px; height: 340px; overflow: hidden; border-radius: 0 0 24px 24px;\" data-kid=\"10\">\n      <img src=\"https://images.pexels.com/photos/5355860/pexels-photo-5355860.jpeg?auto=compress&cs=tinysrgb&w=750&q=80\" alt=\"Tima Miroshnichenko on Pexels — Smiling patient at dental practice\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; object-position: center top;\" data-kid=\"11\">\n      <div style=\"position: absolute; bottom: 16px; left: 16px;\" data-kid=\"12\">\n        <span style=\"background: #6B3558; color: #FFFFFF; font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 999px; letter-spacing: 0.5px;\" data-kid=\"13\">\n          <i class=\"ti ti-map-pin\" style=\"font-size: 10px;\" data-kid=\"14\"></i> Nymphenburg · München\n        </span>\n      </div>\n    </div>\n    <div style=\"padding: 24px 20px 28px; background: #FAF0E6;\" data-kid=\"15\">\n      <h1 style=\"font-family: 'Lora', serif; font-size: 26px; font-weight: 700; color: #36454F; line-height: 1.35; margin: 0 0 10px;\" data-kid=\"16\">Herzlich Willkommen bei Ihrer Zahnärztin in Nymphenburg</h1>\n      <p style=\"font-family: 'Lora', serif; font-style: italic; font-size: 15px; color: #6B3558; margin: 0 0 22px; font-weight: 400;\" data-kid=\"17\">Wir freuen uns auf Ihr Lächeln!</p>\n      <a href=\"#\" style=\"display: block; text-align: center; background: #6B3558; color: #FFFFFF; font-size: 15px; font-weight: 600; padding: 14px; border-radius: 10px; text-decoration: none; margin-bottom: 10px;\" data-kid=\"18\">\n        <i class=\"ti ti-calendar-event\" style=\"font-size: 15px;\" data-kid=\"19\"></i> Termin vereinbaren\n      </a>\n      <a href=\"#\" style=\"display: block; text-align: center; background: transparent; color: #6B3558; font-size: 14px; font-weight: 600; padding: 13px; border-radius: 10px; text-decoration: none; border: 1.5px solid #6B3558;\" data-kid=\"20\">\n        <i class=\"ti ti-phone-call\" style=\"font-size: 14px;\" data-kid=\"21\"></i> Anrufen: 089 / 178 33 50\n      </a>\n    </div>\n  </section>\n\n  <section style=\"background: #FFFFFF; padding: 20px 16px; display: flex; flex-direction: column; gap: 10px;\" data-kid=\"22\">\n    <div style=\"display: flex; align-items: center; gap: 12px; background: #FAF0E6; border-left: 4px solid #6B3558; border-radius: 0 8px 8px 0; padding: 12px 14px;\" data-kid=\"23\">\n      <i class=\"ti ti-clock\" style=\"font-size: 20px; color: #6B3558; flex-shrink: 0;\" data-kid=\"24\"></i>\n      <div data-kid=\"25\">\n        <div style=\"font-size: 11px; font-weight: 600; color: #6B3558; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;\" data-kid=\"26\">Öffnungszeiten</div>\n        <div style=\"font-size: 13px; color: #36454F;\" data-kid=\"27\">Mo–Do: 8:30–12:30 &amp; 14:00–18/19 Uhr</div>\n        <div style=\"font-size: 13px; color: #36454F;\" data-kid=\"28\">Fr: 8:30–13:00 Uhr</div>\n      </div>\n    </div>\n    <div style=\"display: flex; align-items: center; gap: 12px; background: #FAF0E6; border-left: 4px solid #6B3558; border-radius: 0 8px 8px 0; padding: 12px 14px;\" data-kid=\"29\">\n      <i class=\"ti ti-map-pin\" style=\"font-size: 20px; color: #6B3558; flex-shrink: 0;\" data-kid=\"30\"></i>\n      <div data-kid=\"31\">\n        <div style=\"font-size: 11px; font-weight: 600; color: #6B3558; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;\" data-kid=\"32\">Adresse</div>\n        <div style=\"font-size: 13px; color: #36454F;\" data-kid=\"33\">Volpinistraße 19, 80638 München – Nymphenburg</div>\n      </div>\n    </div>\n    <div style=\"display: flex; align-items: center; gap: 12px; background: #FAF0E6; border-left: 4px solid #6B3558; border-radius: 0 8px 8px 0; padding: 12px 14px;\" data-kid=\"34\">\n      <i class=\"ti ti-phone\" style=\"font-size: 20px; color: #6B3558; flex-shrink: 0;\" data-kid=\"35\"></i>\n      <div data-kid=\"36\">\n        <div style=\"font-size: 11px; font-weight: 600; color: #6B3558; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px;\" data-kid=\"37\">Telefon</div>\n        <div style=\"font-size: 13px; color: #36454F; font-weight: 600;\" data-kid=\"38\">089 / 178 33 50</div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 32px 16px;\" data-kid=\"39\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 700; color: #36454F; margin: 0 0 6px;\" data-kid=\"40\">Unsere Leistungen</h2>\n    <p style=\"font-size: 13px; color: #6B7B74; margin: 0 0 20px;\" data-kid=\"41\">Professionelle Zahnmedizin für die ganze Familie</p>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 10px;\" data-kid=\"42\">\n      <div style=\"background: #F2E8EF; border: 1.5px solid #6B3558; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px; position: relative;\" data-kid=\"43\">\n        <span style=\"position: absolute; top: 8px; right: 8px; background: #6B3558; color: #fff; font-size: 9px; font-weight: 700; padding: 2px 7px; border-radius: 999px; letter-spacing: 0.3px;\" data-kid=\"44\">Schwerpunkt</span>\n        <i class=\"ti ti-mood-kid\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"45\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"46\">Kinderzahn­heilkunde</span>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1.5px solid #E0DDD8; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;\" data-kid=\"47\">\n        <i class=\"ti ti-shield-check\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"48\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"49\">Prophylaxe</span>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1.5px solid #E0DDD8; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;\" data-kid=\"50\">\n        <i class=\"ti ti-tooth\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"51\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"52\">Zahnerhaltung</span>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1.5px solid #E0DDD8; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;\" data-kid=\"53\">\n        <i class=\"ti ti-crown\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"54\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"55\">Prothetik &amp; Implantate</span>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1.5px solid #E0DDD8; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;\" data-kid=\"56\">\n        <i class=\"ti ti-activity\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"57\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"58\">Parodontologie</span>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1.5px solid #E0DDD8; border-radius: 12px; padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;\" data-kid=\"59\">\n        <i class=\"ti ti-sparkles\" style=\"font-size: 24px; color: #6B3558;\" data-kid=\"60\"></i>\n        <span style=\"font-size: 12px; font-weight: 700; color: #36454F; line-height: 1.3;\" data-kid=\"61\">Bleaching</span>\n      </div>\n    </div>\n    <a href=\"#\" style=\"display: block; text-align: center; color: #6B3558; font-size: 13px; font-weight: 600; margin-top: 18px; text-decoration: none;\" data-kid=\"62\">Alle Leistungen ansehen →</a>\n  </section>\n\n  <section style=\"background: #FFFFFF; padding: 32px 20px;\" data-kid=\"63\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 700; color: #36454F; margin: 0 0 12px; line-height: 1.35;\" data-kid=\"64\">Ihre Zahnarztpraxis mit Herz</h2>\n    <p style=\"font-size: 14px; color: #4D5F58; line-height: 1.65; margin: 0 0 14px;\" data-kid=\"65\">Herzlich Willkommen! In unserer familiären Praxis in Nymphenburg steht Ihr Wohlbefinden an erster Stelle. Wir behandeln mit modernster Medizintechnik, erläutern Ihnen fair und verständlich alle Behandlungsschritte — und unsere Kinderecke macht jeden Besuch für die Kleinsten zum Abenteuer.</p>\n    <p style=\"font-size: 13px; font-style: italic; color: #6B3558; margin: 0 0 18px; font-family: 'Lora', serif;\" data-kid=\"66\">„Keine Sorge hinsichtlich Behandlungsplanung und Kosten: Was wir vorhaben erläutern wir Ihnen fair und verständlich.\"</p>\n    <div style=\"display: flex; gap: 6px; flex-wrap: wrap;\" data-kid=\"67\">\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 999px; border: 1px solid #D9B5CE;\" data-kid=\"68\">🇩🇪 DE</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 999px; border: 1px solid #D9B5CE;\" data-kid=\"69\">🇫🇷 FR</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 999px; border: 1px solid #D9B5CE;\" data-kid=\"70\">🇬🇧 EN</span>\n      <span style=\"background: #F2E8EF; color: #6B3A58; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 999px; border: 1px solid #D9B5CE;\" data-kid=\"71\">🇹🇷 TR</span>\n    </div>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 32px 0 32px 0;\" data-kid=\"72\">\n    <div style=\"padding: 0 20px 16px;\" data-kid=\"73\">\n      <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 700; color: #36454F; margin: 0 0 4px;\" data-kid=\"74\">Unser Team</h2>\n      <p style=\"font-size: 13px; color: #6B7B74; margin: 0;\" data-kid=\"75\">Persönliche und kompetente Betreuung</p>\n    </div>\n    <div style=\"display: flex; gap: 12px; overflow-x: auto; padding: 4px 20px 8px; scrollbar-width: none;\" data-kid=\"76\">\n      <div style=\"flex-shrink: 0; width: 130px; background: #FFFFFF; border-radius: 14px; padding: 16px 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);\" data-kid=\"77\">\n        <img src=\"https://i.pravatar.cc/80?u=laurice-tomte\" alt=\"Dr. Laurice Thierry Tomte\" decoding=\"async\" loading=\"lazy\" style=\"width: 56px; height: 56px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px; display: block; border: 3px solid #F2E8EF;\" data-kid=\"78\">\n        <div style=\"font-size: 11px; font-weight: 700; color: #36454F; line-height: 1.3; margin-bottom: 3px;\" data-kid=\"79\">Dr. Laurice Tomte</div>\n        <div style=\"font-size: 10px; color: #6B3558; font-weight: 500;\" data-kid=\"80\">Zahnärztin</div>\n      </div>\n      <div style=\"flex-shrink: 0; width: 130px; background: #FFFFFF; border-radius: 14px; padding: 16px 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);\" data-kid=\"81\">\n        <img src=\"https://i.pravatar.cc/80?u=azime-kaya\" alt=\"Azime Kaya\" decoding=\"async\" loading=\"lazy\" style=\"width: 56px; height: 56px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px; display: block; border: 3px solid #F2E8EF;\" data-kid=\"82\">\n        <div style=\"font-size: 11px; font-weight: 700; color: #36454F; margin-bottom: 3px;\" data-kid=\"83\">Azime Kaya</div>\n        <div style=\"font-size: 10px; color: #6B3558; font-weight: 500;\" data-kid=\"84\">Zahnarzthelferin</div>\n      </div>\n      <div style=\"flex-shrink: 0; width: 130px; background: #FFFFFF; border-radius: 14px; padding: 16px 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);\" data-kid=\"85\">\n        <img src=\"https://i.pravatar.cc/80?u=christina-spengler\" alt=\"Christina Spengler\" decoding=\"async\" loading=\"lazy\" style=\"width: 56px; height: 56px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px; display: block; border: 3px solid #F2E8EF;\" data-kid=\"86\">\n        <div style=\"font-size: 11px; font-weight: 700; color: #36454F; margin-bottom: 3px;\" data-kid=\"87\">Christina Spengler</div>\n        <div style=\"font-size: 10px; color: #6B3558; font-weight: 500;\" data-kid=\"88\">Abrechnung</div>\n      </div>\n      <div style=\"flex-shrink: 0; width: 130px; background: #FFFFFF; border-radius: 14px; padding: 16px 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);\" data-kid=\"89\">\n        <img src=\"https://i.pravatar.cc/80?u=jehan-kheder\" alt=\"Jehan Smaael Kheder\" decoding=\"async\" loading=\"lazy\" style=\"width: 56px; height: 56px; border-radius: 50%; object-fit: cover; margin: 0 auto 10px; display: block; border: 3px solid #F2E8EF;\" data-kid=\"90\">\n        <div style=\"font-size: 11px; font-weight: 700; color: #36454F; margin-bottom: 3px;\" data-kid=\"91\">Jehan S. Kheder</div>\n        <div style=\"font-size: 10px; color: #6B3558; font-weight: 500;\" data-kid=\"92\">Auszubildende</div>\n      </div>\n    </div>\n    <div style=\"padding: 8px 20px 0;\" data-kid=\"93\">\n      <a href=\"#\" style=\"font-size: 13px; font-weight: 600; color: #6B3558; text-decoration: none;\" data-kid=\"94\">Unser Team kennenlernen →</a>\n    </div>\n  </section>\n\n  <section style=\"background: #FFFFFF; padding: 32px 20px;\" data-kid=\"95\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 700; color: #36454F; margin: 0 0 16px;\" data-kid=\"96\">Sprechzeiten</h2>\n    <table style=\"width: 100%; border-collapse: collapse;\" data-kid=\"97\">\n      <tbody data-kid=\"98\">\n        <tr style=\"border-bottom: 1px solid #F0EDE8;\" data-kid=\"99\">\n          <td style=\"padding: 9px 0; font-size: 13px; font-weight: 600; color: #36454F;\" data-kid=\"100\">Montag</td>\n          <td style=\"padding: 9px 0; font-size: 13px; color: #4D5F58; text-align: right;\" data-kid=\"101\">8:30–12:30 &amp; 14:00–18:00</td>\n        </tr>\n        <tr style=\"border-bottom: 1px solid #F0EDE8;\" data-kid=\"102\">\n          <td style=\"padding: 9px 0; font-size: 13px; font-weight: 600; color: #36454F;\" data-kid=\"103\">Dienstag</td>\n          <td style=\"padding: 9px 0; font-size: 13px; color: #4D5F58; text-align: right;\" data-kid=\"104\">8:30–12:30 &amp; 14:00–19:00</td>\n        </tr>\n        <tr style=\"border-bottom: 1px solid #F0EDE8;\" data-kid=\"105\">\n          <td style=\"padding: 9px 0; font-size: 13px; font-weight: 600; color: #36454F;\" data-kid=\"106\">Mittwoch</td>\n          <td style=\"padding: 9px 0; font-size: 13px; color: #4D5F58; text-align: right;\" data-kid=\"107\">8:30–13:00</td>\n        </tr>\n        <tr style=\"border-bottom: 1px solid #F0EDE8;\" data-kid=\"108\">\n          <td style=\"padding: 9px 0; font-size: 13px; font-weight: 600; color: #36454F;\" data-kid=\"109\">Donnerstag</td>\n          <td style=\"padding: 9px 0; font-size: 13px; color: #4D5F58; text-align: right;\" data-kid=\"110\">8:30–12:30 &amp; 14:00–18:00</td>\n        </tr>\n        <tr style=\"border-bottom: 1px solid #F0EDE8;\" data-kid=\"111\">\n          <td style=\"padding: 9px 0; font-size: 13px; font-weight: 600; color: #36454F;\" data-kid=\"112\">Freitag</td>\n          <td style=\"padding: 9px 0; font-size: 13px; color: #4D5F58; text-align: right;\" data-kid=\"113\">8:30–13:00</td>\n        </tr>\n      </tbody>\n    </table>\n    <p style=\"font-size: 12px; color: #6B3558; font-style: italic; margin: 12px 0 0;\" data-kid=\"114\">… und nach telefonischer Vereinbarung</p>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 32px 16px;\" data-kid=\"115\">\n    <div style=\"display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 8px;\" data-kid=\"116\">\n      <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 700; color: #36454F; margin: 0;\" data-kid=\"117\">Patientenstimmen</h2>\n      <div style=\"display: flex; gap: 6px;\" data-kid=\"118\">\n        <span style=\"background: #FFFFFF; border: 1px solid #E0DDD8; border-radius: 6px; padding: 3px 8px; font-size: 10px; font-weight: 700; color: #E84C6B;\" data-kid=\"119\">jameda</span>\n        <span style=\"background: #FFFFFF; border: 1px solid #E0DDD8; border-radius: 6px; padding: 3px 8px; font-size: 10px; font-weight: 700; color: #0075A2;\" data-kid=\"120\">sanego</span>\n      </div>\n    </div>\n    <div style=\"background: #FFFFFF; border-radius: 14px; padding: 18px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);\" data-kid=\"121\">\n      <div style=\"display: flex; gap: 2px; margin-bottom: 8px;\" data-kid=\"122\">\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"123\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"124\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"125\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"126\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"127\"></i>\n      </div>\n      <p style=\"font-size: 13px; color: #4D5F58; line-height: 1.6; margin: 0 0 10px; font-style: italic;\" data-kid=\"128\">„Sehr freundliche und einfühlsame Ärztin. Die Behandlung wurde immer klar erklärt und ich fühlte mich von Anfang an gut aufgehoben.\"</p>\n      <div style=\"font-size: 12px; font-weight: 600; color: #36454F;\" data-kid=\"129\">– Maria K., München</div>\n    </div>\n    <div style=\"background: #FFFFFF; border-radius: 14px; padding: 18px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);\" data-kid=\"130\">\n      <div style=\"display: flex; gap: 2px; margin-bottom: 8px;\" data-kid=\"131\">\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"132\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"133\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"134\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"135\"></i>\n        <i class=\"ti ti-star-filled\" style=\"font-size: 14px; color: #F59E0B;\" data-kid=\"136\"></i>\n      </div>\n      <p style=\"font-size: 13px; color: #4D5F58; line-height: 1.6; margin: 0 0 10px; font-style: italic;\" data-kid=\"137\">„Unsere ganze Familie kommt seit Jahren hierher. Besonders die Kinder werden mit viel Geduld behandelt — die Kinderecke ist toll!\"</p>\n      <div style=\"font-size: 12px; font-weight: 600; color: #36454F;\" data-kid=\"138\">– Thomas B., Nymphenburg</div>\n    </div>\n  </section>\n\n  <section style=\"background: #FFFFFF; padding: 32px 16px;\" data-kid=\"139\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 21px; font-weight: 700; color: #36454F; margin: 0 0 16px;\" data-kid=\"140\">Anfahrt</h2>\n    <div style=\"border-radius: 14px; overflow: hidden; border: 1px solid #E0DDD8; margin-bottom: 14px;\" data-kid=\"141\">\n      <iframe src=\"https://www.openstreetmap.org/export/embed.html?bbox=11.525%2C48.147%2C11.545%2C48.157&amp;layer=mapnik&amp;marker=48.152%2C11.535\" width=\"343\" height=\"220\" style=\"border: none; display: block; width: 100%;\" title=\"Praxis Standort\" loading=\"lazy\" data-kid=\"142\"></iframe>\n    </div>\n    <div style=\"display: flex; gap: 10px; align-items: flex-start;\" data-kid=\"143\">\n      <i class=\"ti ti-map-pin\" style=\"font-size: 18px; color: #6B3558; flex-shrink: 0; margin-top: 2px;\" data-kid=\"144\"></i>\n      <div data-kid=\"145\">\n        <div style=\"font-size: 14px; font-weight: 700; color: #36454F; margin-bottom: 2px;\" data-kid=\"146\">Zahnarztpraxis Dr. Tomte</div>\n        <div style=\"font-size: 13px; color: #4D5F58; line-height: 1.6;\" data-kid=\"147\">Volpinistraße 19<br data-kid=\"148\">80638 München – Nymphenburg<br data-kid=\"149\"><span style=\"font-size: 12px; color: #6B7B74;\" data-kid=\"150\">Der Eingang befindet sich seitlich des Hauses.</span></div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #36454F; padding: 40px 20px; text-align: center;\" data-kid=\"151\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 24px; font-weight: 700; color: #FFFFFF; margin: 0 0 10px; line-height: 1.35;\" data-kid=\"152\">Bereit für Ihr schönstes Lächeln?</h2>\n    <p style=\"font-size: 14px; color: #C9B8C4; margin: 0 0 22px; line-height: 1.6;\" data-kid=\"153\">Vereinbaren Sie noch heute Ihren Termin — wir freuen uns auf Sie!</p>\n    <a href=\"#\" style=\"display: inline-block; background: #6B3558; color: #FFFFFF; font-size: 15px; font-weight: 700; padding: 14px 28px; border-radius: 10px; text-decoration: none;\" data-kid=\"154\">\n      <i class=\"ti ti-calendar-event\" style=\"font-size: 15px;\" data-kid=\"155\"></i> Termin vereinbaren\n    </a>\n  </section>\n\n  <footer style=\"background: #2A1E28; padding: 32px 20px 20px; color: #D8C2D5;\" data-kid=\"156\">\n    <div style=\"display: flex; align-items: center; gap: 8px; margin-bottom: 18px;\" data-kid=\"157\">\n      <div style=\"width: 30px; height: 30px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center;\" data-kid=\"158\">\n        <i class=\"ti ti-tooth\" style=\"font-size: 15px; color: #FFFFFF;\" data-kid=\"159\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; font-size: 14px; font-weight: 600; color: #FFFFFF;\" data-kid=\"160\">Zahnarztpraxis Dr. Tomte</span>\n    </div>\n    <div style=\"font-size: 12px; line-height: 1.8; margin-bottom: 16px; color: #C2A8BB;\" data-kid=\"161\">\n      Volpinistraße 19 · 80638 München<br data-kid=\"162\">\n      Tel: <span style=\"color: #D8C2D5;\" data-kid=\"163\">089 / 178 33 50</span><br data-kid=\"164\">\n      Fax: 089 / 178 37 62<br data-kid=\"165\">\n      E-Mail: praxis@zahnarztpraxis-tomte.de\n    </div>\n    <div style=\"display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 16px;\" data-kid=\"166\">\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"167\">Startseite</a>\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"168\">Praxis</a>\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"169\">Über uns</a>\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"170\">Leistungen</a>\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"171\">Anfahrt</a>\n      <a href=\"#\" style=\"font-size: 11px; color: #C2A8BB; text-decoration: none;\" data-kid=\"172\">Kontakt</a>\n    </div>\n    <div style=\"border-top: 1px solid #45303D; padding-top: 14px; display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between; align-items: center;\" data-kid=\"173\">\n      <div style=\"display: flex; gap: 10px;\" data-kid=\"174\">\n        <a href=\"#\" style=\"font-size: 10px; color: #9B758D; text-decoration: none;\" data-kid=\"175\">Datenschutz</a>\n        <a href=\"#\" style=\"font-size: 10px; color: #9B758D; text-decoration: none;\" data-kid=\"176\">Impressum</a>\n      </div>\n      <div style=\"font-size: 10px; color: #7B6B7A;\" data-kid=\"177\">© Dr. Tomte 2012–2025</div>\n    </div>\n  </footer>\n\n  <div style=\"background: #FFFFFF; border-top: 1.5px solid #E8E5E0; display: flex; height: 64px;\" data-kid=\"178\">\n    <a href=\"#\" style=\"flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; text-decoration: none; border-right: 1px solid #E8E5E0;\" data-kid=\"179\">\n      <i class=\"ti ti-phone-call\" style=\"font-size: 20px; color: #6B3558;\" data-kid=\"180\"></i>\n      <span style=\"font-size: 11px; font-weight: 600; color: #6B3558;\" data-kid=\"181\">Anrufen</span>\n    </a>\n    <a href=\"#\" style=\"flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; text-decoration: none; background: #6B3558;\" data-kid=\"182\">\n      <i class=\"ti ti-calendar-event\" style=\"font-size: 20px; color: #FFFFFF;\" data-kid=\"183\"></i>\n      <span style=\"font-size: 11px; font-weight: 600; color: #FFFFFF;\" data-kid=\"184\">Termin</span>\n    </a>\n  </div>\n\n</div>",
