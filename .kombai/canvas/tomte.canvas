      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Public+Sans:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n\n<div style=\"font-family: 'Public Sans', sans-serif; width: 375px; height: 812px; position: relative; overflow: hidden;\" data-kid=\"1\">\n\n  <div style=\"position: absolute; inset: 0; background: #FAF0E6;\" data-kid=\"2\">\n    <div style=\"padding: 0 20px; padding-top: 60px; opacity: 0.3;\" data-kid=\"3\">\n      <div style=\"height: 32px; background: #D0B8CC; border-radius: 6px; margin-bottom: 10px; width: 80%;\" data-kid=\"4\"></div>\n      <div style=\"height: 20px; background: #D0B8CC; border-radius: 4px; margin-bottom: 8px; width: 60%;\" data-kid=\"5\"></div>\n      <div style=\"height: 20px; background: #D0B8CC; border-radius: 4px; margin-bottom: 8px; width: 70%;\" data-kid=\"6\"></div>\n      <div style=\"height: 180px; background: #C8A8C0; border-radius: 12px; margin-bottom: 16px;\" data-kid=\"7\"></div>\n      <div style=\"height: 16px; background: #D0B8CC; border-radius: 4px; margin-bottom: 6px; width: 90%;\" data-kid=\"8\"></div>\n      <div style=\"height: 16px; background: #D0B8CC; border-radius: 4px; width: 75%;\" data-kid=\"9\"></div>\n    </div>\n  </div>\n\n  <div style=\"position: absolute; inset: 0; background: rgba(54, 28, 48, 0.72);\" data-kid=\"10\"></div>\n\n  <div style=\"position: absolute; top: 0; right: 0; width: 308px; height: 812px; background: #FFFFFF; box-shadow: -8px 0 40px rgba(0,0,0,0.25); display: flex; flex-direction: column; overflow-y: auto;\" data-kid=\"11\">\n\n    <div style=\"display: flex; align-items: center; justify-content: space-between; padding: 20px 20px 18px; border-bottom: 1px solid #F0EDE8;\" data-kid=\"12\">\n      <div style=\"display: flex; align-items: center; gap: 9px;\" data-kid=\"13\">\n        <div style=\"width: 32px; height: 32px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center;\" data-kid=\"14\">\n          <i class=\"ti ti-tooth\" style=\"font-size: 16px; color: #FFFFFF;\" data-kid=\"15\"></i>\n        </div>\n        <span style=\"font-family: 'Lora', serif; font-weight: 600; font-size: 14px; color: #36454F; line-height: 1.2;\" data-kid=\"16\">Zahnarztpraxis<br data-kid=\"17\">Dr. Tomte</span>\n      </div>\n      <button style=\"background: #FAF0E6; border: none; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer;\" data-kid=\"18\">\n        <i class=\"ti ti-x\" style=\"font-size: 18px; color: #36454F;\" data-kid=\"19\"></i>\n      </button>\n    </div>\n\n    <nav style=\"padding: 10px 0; flex: 1;\" data-kid=\"20\">\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; background: #F2E8EF; border-left: 4px solid #6B3558; margin-bottom: 2px;\" data-kid=\"21\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"22\">\n          <i class=\"ti ti-home\" style=\"font-size: 18px; color: #6B3558;\" data-kid=\"23\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 600; color: #6B3558;\" data-kid=\"24\">Home</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #6B3558;\" data-kid=\"25\"></i>\n      </a>\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; border-left: 4px solid transparent; margin-bottom: 2px;\" data-kid=\"26\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"27\">\n          <i class=\"ti ti-building\" style=\"font-size: 18px; color: #6B7B74;\" data-kid=\"28\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 500; color: #36454F;\" data-kid=\"29\">Praxis</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #B0BDB8;\" data-kid=\"30\"></i>\n      </a>\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; border-left: 4px solid transparent; margin-bottom: 2px;\" data-kid=\"31\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"32\">\n          <i class=\"ti ti-users\" style=\"font-size: 18px; color: #6B7B74;\" data-kid=\"33\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 500; color: #36454F;\" data-kid=\"34\">Über uns</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #B0BDB8;\" data-kid=\"35\"></i>\n      </a>\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; border-left: 4px solid transparent; margin-bottom: 2px;\" data-kid=\"36\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"37\">\n          <i class=\"ti ti-stethoscope\" style=\"font-size: 18px; color: #6B7B74;\" data-kid=\"38\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 500; color: #36454F;\" data-kid=\"39\">Leistungen</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #B0BDB8;\" data-kid=\"40\"></i>\n      </a>\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; border-left: 4px solid transparent; margin-bottom: 2px;\" data-kid=\"41\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"42\">\n          <i class=\"ti ti-map-pin\" style=\"font-size: 18px; color: #6B7B74;\" data-kid=\"43\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 500; color: #36454F;\" data-kid=\"44\">Anfahrt</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #B0BDB8;\" data-kid=\"45\"></i>\n      </a>\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: space-between; padding: 15px 22px; text-decoration: none; border-left: 4px solid transparent;\" data-kid=\"46\">\n        <div style=\"display: flex; align-items: center; gap: 12px;\" data-kid=\"47\">\n          <i class=\"ti ti-mail\" style=\"font-size: 18px; color: #6B7B74;\" data-kid=\"48\"></i>\n          <span style=\"font-family: 'Lora', serif; font-size: 18px; font-weight: 500; color: #36454F;\" data-kid=\"49\">Kontakt</span>\n        </div>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 14px; color: #B0BDB8;\" data-kid=\"50\"></i>\n      </a>\n    </nav>\n\n    <div style=\"height: 1px; background: #F0EDE8; margin: 0 20px;\" data-kid=\"51\"></div>\n\n    <div style=\"padding: 16px 22px;\" data-kid=\"52\">\n      <div style=\"font-size: 11px; font-weight: 600; color: #6B7B74; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px;\" data-kid=\"53\">Sprache / Language</div>\n      <div style=\"display: flex; gap: 8px;\" data-kid=\"54\">\n        <button style=\"background: #6B3558; color: #FFFFFF; font-size: 11px; font-weight: 700; padding: 6px 12px; border-radius: 6px; border: none; cursor: pointer;\" data-kid=\"55\">🇩🇪 DE</button>\n        <button style=\"background: #FAF0E6; color: #36454F; font-size: 11px; font-weight: 600; padding: 6px 12px; border-radius: 6px; border: 1px solid #E0DDD8; cursor: pointer;\" data-kid=\"56\">🇫🇷 FR</button>\n        <button style=\"background: #FAF0E6; color: #36454F; font-size: 11px; font-weight: 600; padding: 6px 12px; border-radius: 6px; border: 1px solid #E0DDD8; cursor: pointer;\" data-kid=\"57\">🇬🇧 EN</button>\n        <button style=\"background: #FAF0E6; color: #36454F; font-size: 11px; font-weight: 600; padding: 6px 12px; border-radius: 6px; border: 1px solid #E0DDD8; cursor: pointer;\" data-kid=\"58\">🇹🇷 TR</button>\n      </div>\n    </div>\n\n    <div style=\"height: 1px; background: #F0EDE8; margin: 0 20px;\" data-kid=\"59\"></div>\n\n    <div style=\"padding: 18px 22px 22px;\" data-kid=\"60\">\n      <a href=\"#\" style=\"display: flex; align-items: center; justify-content: center; gap: 8px; background: #6B3558; color: #FFFFFF; font-size: 14px; font-weight: 700; padding: 14px; border-radius: 10px; text-decoration: none; margin-bottom: 12px;\" data-kid=\"61\">\n        <i class=\"ti ti-calendar-event\" style=\"font-size: 16px;\" data-kid=\"62\"></i>\n        Termin vereinbaren\n      </a>\n      <a href=\"tel:+4989178333350\" style=\"display: flex; align-items: center; gap: 10px; text-decoration: none; padding: 10px 0; border-bottom: 1px solid #F0EDE8;\" data-kid=\"63\">\n        <i class=\"ti ti-phone-call\" style=\"font-size: 18px; color: #6B3558;\" data-kid=\"64\"></i>\n        <div data-kid=\"65\">\n          <div style=\"font-size: 11px; color: #6B7B74; font-weight: 500;\" data-kid=\"66\">Telefon</div>\n          <div style=\"font-size: 14px; font-weight: 700; color: #36454F;\" data-kid=\"67\">089 / 178 33 50</div>\n        </div>\n      </a>\n      <div style=\"display: flex; align-items: flex-start; gap: 10px; padding: 10px 0;\" data-kid=\"68\">\n        <i class=\"ti ti-clock\" style=\"font-size: 18px; color: #6B3558; margin-top: 2px;\" data-kid=\"69\"></i>\n        <div data-kid=\"70\">\n          <div style=\"font-size: 11px; color: #6B7B74; font-weight: 500; margin-bottom: 3px;\" data-kid=\"71\">Sprechzeiten</div>\n          <div style=\"font-size: 12px; color: #36454F; line-height: 1.6;\" data-kid=\"72\">Mo–Do: 8:30–12:30 &amp; 14:00–18/19 Uhr<br data-kid=\"73\">Fr: 8:30–13:00 Uhr</div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n</div>",
