      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Public+Sans:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n\n<div style=\"font-family:'Public Sans',sans-serif;color:#36454F;background:#FAF0E6;min-width:375px;max-width:375px;margin:0 auto;\" data-kid=\"1\">\n\n  <header style=\"background:#fff;box-shadow:0 2px 8px rgba(0,0,0,0.08);height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;position:relative;z-index:10;\" data-kid=\"2\">\n    <div style=\"display:flex;align-items:center;gap:8px;\" data-kid=\"3\">\n      <div style=\"width:34px;height:34px;background:#6B3558;border-radius:50%;display:flex;align-items:center;justify-content:center;\" data-kid=\"4\">\n        <i class=\"ti ti-tooth\" style=\"color:#fff;font-size:17px;\" data-kid=\"5\"></i>\n      </div>\n      <span style=\"font-family:'Lora',serif;font-size:15px;font-weight:600;color:#36454F;letter-spacing:-0.2px;\" data-kid=\"6\">Dr. Tomte</span>\n    </div>\n    <button style=\"background:none;border:none;cursor:pointer;padding:6px;border-radius:8px;\" data-kid=\"7\">\n      <i class=\"ti ti-menu-2\" style=\"font-size:24px;color:#36454F;\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  <div style=\"background:#FAF0E6;padding:40px 20px 32px;text-align:center;\" data-kid=\"9\">\n    <p style=\"font-size:12px;font-weight:600;letter-spacing:1.5px;color:#6B3558;text-transform:uppercase;margin:0 0 10px;\" data-kid=\"10\">Anfahrt</p>\n    <h1 style=\"font-family:'Lora',serif;font-size:26px;font-weight:700;color:#36454F;line-height:1.25;margin:0 0 12px;\" data-kid=\"11\">So finden Sie uns</h1>\n    <p style=\"font-size:14px;color:#5a6a72;margin:0;line-height:1.5;\" data-kid=\"12\">\n      <i class=\"ti ti-map-pin\" style=\"font-size:14px;color:#6B3558;vertical-align:middle;margin-right:4px;\" data-kid=\"13\"></i>\n      Volpinistraße 19, 80638 München – Nymphenburg\n    </p>\n  </div>\n\n  <div style=\"background:#fff;padding:0 0 4px;\" data-kid=\"14\">\n    <iframe src=\"https://maps.google.com/maps?q=Volpinistra%C3%9Fe+19,+80638+M%C3%BCnchen&output=embed\" width=\"375\" height=\"280\" style=\"border:none;display:block;width:100%;\" loading=\"lazy\" title=\"Praxisstandort Karte\" data-kid=\"15\"></iframe>\n  </div>\n\n  <div style=\"padding:16px;\" data-kid=\"16\">\n    <div style=\"background:#fff;border-radius:14px;border-left:4px solid #6B3558;padding:20px 16px;box-shadow:0 2px 12px rgba(0,0,0,0.06);\" data-kid=\"17\">\n      <h2 style=\"font-family:'Lora',serif;font-size:16px;font-weight:600;margin:0 0 16px;color:#36454F;\" data-kid=\"18\">Kontaktdaten</h2>\n\n      <div style=\"display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;\" data-kid=\"19\">\n        <div style=\"width:36px;height:36px;background:#F2E8EF;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"20\">\n          <i class=\"ti ti-map-pin\" style=\"font-size:17px;color:#6B3558;\" data-kid=\"21\"></i>\n        </div>\n        <div data-kid=\"22\">\n          <p style=\"margin:0;font-size:14px;font-weight:600;color:#36454F;\" data-kid=\"23\">Adresse</p>\n          <p style=\"margin:3px 0 0;font-size:13px;color:#5a6a72;line-height:1.5;\" data-kid=\"24\">Volpinistraße 19<br data-kid=\"25\">80638 München – Nymphenburg</p>\n        </div>\n      </div>\n\n      <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:14px;\" data-kid=\"26\">\n        <div style=\"width:36px;height:36px;background:#F2E8EF;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"27\">\n          <i class=\"ti ti-phone\" style=\"font-size:17px;color:#6B3558;\" data-kid=\"28\"></i>\n        </div>\n        <div data-kid=\"29\">\n          <p style=\"margin:0;font-size:14px;font-weight:600;color:#36454F;\" data-kid=\"30\">Telefon</p>\n          <p style=\"margin:3px 0 0;font-size:13px;color:#6B3558;font-weight:600;\" data-kid=\"31\">089 / 178 33 50</p>\n        </div>\n      </div>\n\n      <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:20px;\" data-kid=\"32\">\n        <div style=\"width:36px;height:36px;background:#F2E8EF;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"33\">\n          <i class=\"ti ti-mail\" style=\"font-size:17px;color:#6B3558;\" data-kid=\"34\"></i>\n        </div>\n        <div data-kid=\"35\">\n          <p style=\"margin:0;font-size:14px;font-weight:600;color:#36454F;\" data-kid=\"36\">E-Mail</p>\n          <p style=\"margin:3px 0 0;font-size:12px;color:#5a6a72;\" data-kid=\"37\">praxis@zahnarztpraxis-tomte.de</p>\n        </div>\n      </div>\n\n      <button style=\"background:#6B3558;color:#fff;border:none;border-radius:100px;width:100%;padding:14px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Public Sans',sans-serif;letter-spacing:0.2px;\" data-kid=\"38\">\n        <i class=\"ti ti-calendar\" style=\"margin-right:6px;\" data-kid=\"39\"></i> Termin vereinbaren\n      </button>\n    </div>\n  </div>\n\n  <div style=\"background:#FAF0E6;padding:24px 20px;\" data-kid=\"40\">\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:12px;\" data-kid=\"41\">\n      <div style=\"width:38px;height:38px;background:#F2E8EF;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"42\">\n        <i class=\"ti ti-train\" style=\"font-size:20px;color:#6B3558;\" data-kid=\"43\"></i>\n      </div>\n      <h2 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0;\" data-kid=\"44\">Öffentliche Verkehrsmittel</h2>\n    </div>\n    <p style=\"font-size:13px;color:#5a6a72;line-height:1.7;margin:0 0 10px;\" data-kid=\"45\">\n      Das Viertel Nymphenburg ist gut mit dem ÖPNV erreichbar. Nutzen Sie die Tram oder den Bus in Richtung Nymphenburg / Schlosspark.\n    </p>\n    <div style=\"display:flex;flex-direction:column;gap:8px;\" data-kid=\"46\">\n      <div style=\"display:flex;align-items:center;gap:8px;background:#fff;border-radius:10px;padding:10px 12px;\" data-kid=\"47\">\n        <span style=\"background:#0070C0;color:#fff;font-size:11px;font-weight:700;padding:2px 7px;border-radius:6px;\" data-kid=\"48\">Tram 17</span>\n        <span style=\"font-size:13px;color:#36454F;\" data-kid=\"49\">Haltestelle Nymphenburg</span>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:8px;background:#fff;border-radius:10px;padding:10px 12px;\" data-kid=\"50\">\n        <span style=\"background:#E8000B;color:#fff;font-size:11px;font-weight:700;padding:2px 7px;border-radius:6px;\" data-kid=\"51\">Bus 51</span>\n        <span style=\"font-size:13px;color:#36454F;\" data-kid=\"52\">Haltestelle Amalienburgstr.</span>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"background:#fff;padding:24px 20px;\" data-kid=\"53\">\n    <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:12px;\" data-kid=\"54\">\n      <div style=\"width:38px;height:38px;background:#F2E8EF;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"55\">\n        <i class=\"ti ti-car\" style=\"font-size:20px;color:#6B3558;\" data-kid=\"56\"></i>\n      </div>\n      <h2 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0;\" data-kid=\"57\">Mit dem Auto</h2>\n    </div>\n    <p style=\"font-size:13px;color:#5a6a72;line-height:1.7;margin:0 0 12px;\" data-kid=\"58\">\n      Die Praxis liegt im ruhigen Nymphenburg, gut erreichbar über die Nymphenburger Straße.\n    </p>\n    <div style=\"background:#F2E8EF;border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;\" data-kid=\"59\">\n      <i class=\"ti ti-parking\" style=\"font-size:22px;color:#6B3558;flex-shrink:0;\" data-kid=\"60\"></i>\n      <p style=\"margin:0;font-size:13px;color:#36454F;font-weight:500;\" data-kid=\"61\">Kostenlose Parkmöglichkeiten in der unmittelbaren Umgebung</p>\n    </div>\n  </div>\n\n  <div style=\"background:#FAF0E6;padding:24px 20px;\" data-kid=\"62\">\n    <h2 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0 0 12px;\" data-kid=\"63\">\n      <i class=\"ti ti-door-enter\" style=\"color:#6B3558;margin-right:6px;\" data-kid=\"64\"></i>Eingang\n    </h2>\n    <div style=\"background:#F2E8EF;border-radius:14px;height:200px;display:flex;flex-direction:column;align-items:center;justify-content:center;border:2px dashed #6B3558;\" data-kid=\"65\">\n      <i class=\"ti ti-building\" style=\"font-size:36px;color:#6B3558;margin-bottom:10px;\" data-kid=\"66\"></i>\n      <p style=\"font-size:12px;color:#6B3558;font-weight:600;margin:0;text-align:center;padding:0 20px;\" data-kid=\"67\">[Foto: Seitlicher Eingang Volpinistraße 19]</p>\n    </div>\n    <div style=\"margin-top:12px;background:#fff;border-radius:10px;padding:12px 14px;display:flex;align-items:flex-start;gap:8px;\" data-kid=\"68\">\n      <i class=\"ti ti-info-circle\" style=\"font-size:18px;color:#6B3558;margin-top:1px;flex-shrink:0;\" data-kid=\"69\"></i>\n      <p style=\"margin:0;font-size:13px;color:#5a6a72;line-height:1.6;\" data-kid=\"70\"><strong style=\"color:#36454F;\" data-kid=\"71\">Hinweis:</strong> Der Eingang befindet sich seitlich des Hauses.</p>\n    </div>\n  </div>\n\n  <div style=\"background:#fff;padding:24px 20px;\" data-kid=\"72\">\n    <h2 style=\"font-family:'Lora',serif;font-size:17px;font-weight:600;color:#36454F;margin:0 0 16px;\" data-kid=\"73\">\n      <i class=\"ti ti-clock\" style=\"color:#6B3558;margin-right:6px;\" data-kid=\"74\"></i>Sprechzeiten\n    </h2>\n    <div style=\"display:flex;flex-direction:column;gap:0;\" data-kid=\"75\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#F2E8EF;border-radius:10px 10px 0 0;border-bottom:1px solid rgba(107,53,88,0.2);\" data-kid=\"76\">\n        <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"77\">Montag</span>\n        <span style=\"font-size:13px;color:#5a6a72;\" data-kid=\"78\">8:30–12:30 &amp; 14:00–18:00</span>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#fff;border-bottom:1px solid #f0ebe3;\" data-kid=\"79\">\n        <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"80\">Dienstag</span>\n        <span style=\"font-size:13px;color:#5a6a72;\" data-kid=\"81\">8:30–12:30 &amp; 14:00–19:00</span>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#F2E8EF;border-bottom:1px solid rgba(107,53,88,0.2);\" data-kid=\"82\">\n        <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"83\">Mittwoch</span>\n        <span style=\"font-size:13px;color:#5a6a72;\" data-kid=\"84\">8:30–13:00</span>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#fff;border-bottom:1px solid #f0ebe3;\" data-kid=\"85\">\n        <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"86\">Donnerstag</span>\n        <span style=\"font-size:13px;color:#5a6a72;\" data-kid=\"87\">8:30–12:30 &amp; 14:00–18:00</span>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:#F2E8EF;border-radius:0 0 10px 10px;\" data-kid=\"88\">\n        <span style=\"font-size:13px;font-weight:600;color:#36454F;\" data-kid=\"89\">Freitag</span>\n        <span style=\"font-size:13px;color:#5a6a72;\" data-kid=\"90\">8:30–13:00</span>\n      </div>\n    </div>\n    <p style=\"font-size:12px;color:#6B3558;margin:12px 0 0;text-align:center;font-style:italic;\" data-kid=\"91\">... und nach telefonischer Vereinbarung</p>\n  </div>\n\n  <footer style=\"background:#2A1E28;padding:32px 20px 24px;color:#fff;\" data-kid=\"92\">\n    <div style=\"margin-bottom:20px;\" data-kid=\"93\">\n      <p style=\"font-family:'Lora',serif;font-size:15px;font-weight:600;margin:0 0 4px;color:#fff;\" data-kid=\"94\">Zahnarztpraxis Dr. Tomte</p>\n      <p style=\"font-size:12px;color:rgba(255,255,255,0.65);margin:0;line-height:1.6;\" data-kid=\"95\">Volpinistraße 19 · 80638 München</p>\n      <p style=\"font-size:12px;color:rgba(255,255,255,0.65);margin:4px 0 0;\" data-kid=\"96\">Tel: 089 / 178 33 50</p>\n    </div>\n    <div style=\"display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px;\" data-kid=\"97\">\n      <a href=\"#\" style=\"font-size:12px;color:rgba(255,255,255,0.55);text-decoration:none;\" data-kid=\"98\">Impressum</a>\n      <a href=\"#\" style=\"font-size:12px;color:rgba(255,255,255,0.55);text-decoration:none;\" data-kid=\"99\">Datenschutz</a>\n      <a href=\"#\" style=\"font-size:12px;color:rgba(255,255,255,0.55);text-decoration:none;\" data-kid=\"100\">Anfahrt</a>\n      <a href=\"#\" style=\"font-size:12px;color:rgba(255,255,255,0.55);text-decoration:none;\" data-kid=\"101\">Kontakt</a>\n    </div>\n    <p style=\"font-size:11px;color:rgba(255,255,255,0.35);margin:0;\" data-kid=\"102\">© Dr. Tomte 2012–2025</p>\n  </footer>\n\n  <div style=\"background:#fff;border-top:1px solid #e8e0d6;height:64px;display:flex;align-items:center;\" data-kid=\"103\">\n    <button style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;cursor:pointer;height:100%;border-right:1px solid #f0ebe3;\" data-kid=\"104\">\n      <i class=\"ti ti-phone\" style=\"font-size:20px;color:#6B3558;\" data-kid=\"105\"></i>\n      <span style=\"font-size:11px;font-weight:600;color:#6B3558;\" data-kid=\"106\">Anrufen</span>\n    </button>\n    <button style=\"flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;background:none;border:none;cursor:pointer;height:100%;\" data-kid=\"107\">\n      <div style=\"background:#6B3558;border-radius:100px;padding:6px 18px;display:flex;flex-direction:column;align-items:center;gap:2px;\" data-kid=\"108\">\n        <i class=\"ti ti-calendar\" style=\"font-size:17px;color:#fff;\" data-kid=\"109\"></i>\n        <span style=\"font-size:10px;font-weight:600;color:#fff;\" data-kid=\"110\">Termin</span>\n      </div>\n    </button>\n  </div>\n\n</div>",
