      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Public+Sans:wght@300;400;500;600;700&display=swap');\n</style>\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<div style=\"font-family: 'Public Sans', sans-serif; background-color: #FAF0E6; color: #36454F; position: relative;\" data-kid=\"2\">\n\n  \n  <div style=\"background-color: #F2E8EF; padding: 8px 64px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; font-weight: 500;\" data-kid=\"3\">\n    <div style=\"display: flex; align-items: center; gap: 8px; color: #36454F;\" data-kid=\"4\">\n      <i class=\"ti ti-phone\" style=\"color: #6B3558; font-size: 14px;\" data-kid=\"5\"></i>\n      <span data-kid=\"6\">089 / 178 33 50</span>\n    </div>\n    <div style=\"display: flex; align-items: center; gap: 12px; color: #36454F; font-weight: 600; letter-spacing: 0.05em;\" data-kid=\"7\">\n      <span style=\"padding: 2px 8px; border-radius: 4px; background: #6B3558; color: white; font-size: 11px;\" data-kid=\"8\">DE</span>\n      <span style=\"color: #6B3558; font-size: 11px; font-weight: 600;\" data-kid=\"9\">EN</span>\n      <span style=\"color: #6B3558; font-size: 11px; font-weight: 600;\" data-kid=\"10\">FR</span>\n      <span style=\"color: #6B3558; font-size: 11px; font-weight: 600;\" data-kid=\"11\">TR</span>\n    </div>\n  </div>\n\n  \n  <nav style=\"background: #FFFFFF; box-shadow: 0 2px 16px rgba(54,69,79,0.08); padding: 18px 64px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100;\" data-kid=\"12\">\n    <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"13\">\n      <div style=\"width: 38px; height: 38px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center;\" data-kid=\"14\">\n        <i class=\"ti ti-tooth\" style=\"color: white; font-size: 20px;\" data-kid=\"15\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; font-size: 17px; font-weight: 600; color: #36454F; letter-spacing: -0.01em;\" data-kid=\"16\">Zahnarztpraxis Dr. Tomte</span>\n    </div>\n    <div style=\"display: flex; gap: 32px; font-size: 15px; font-weight: 500;\" data-kid=\"17\">\n      <a href=\"#\" style=\"color: #6B3558; text-decoration: none; border-bottom: 2px solid #6B3558; padding-bottom: 2px;\" data-kid=\"18\">Home</a>\n      <a href=\"#\" style=\"color: #36454F; text-decoration: none;\" data-kid=\"19\">Praxis</a>\n      <a href=\"#\" style=\"color: #36454F; text-decoration: none;\" data-kid=\"20\">Über uns</a>\n      <a href=\"#\" style=\"color: #36454F; text-decoration: none;\" data-kid=\"21\">Leistungen</a>\n      <a href=\"#\" style=\"color: #36454F; text-decoration: none;\" data-kid=\"22\">Anfahrt</a>\n      <a href=\"#\" style=\"color: #36454F; text-decoration: none;\" data-kid=\"23\">Kontakt</a>\n    </div>\n    <a href=\"#\" style=\"background: #6B3558; color: white; padding: 12px 24px; border-radius: 50px; text-decoration: none; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 8px;\" data-kid=\"24\">\n      <i class=\"ti ti-calendar-event\" style=\"font-size: 16px;\" data-kid=\"25\"></i>\n      Termin vereinbaren\n    </a>\n  </nav>\n\n  \n  <div style=\"display: flex; min-height: 700px; background: #FAF0E6;\" data-kid=\"26\">\n    <div style=\"flex: 1; padding: 80px 64px; display: flex; flex-direction: column; justify-content: center; max-width: 680px;\" data-kid=\"27\">\n      <div style=\"display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap;\" data-kid=\"28\">\n        <span style=\"background: #F2E8EF; color: #6B3558; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;\" data-kid=\"29\">DE</span>\n        <span style=\"background: #F2E8EF; color: #6B3558; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;\" data-kid=\"30\">EN</span>\n        <span style=\"background: #F2E8EF; color: #6B3558; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;\" data-kid=\"31\">FR</span>\n        <span style=\"background: #F2E8EF; color: #6B3558; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600;\" data-kid=\"32\">TR</span>\n      </div>\n      <h1 style=\"font-family: 'Lora', serif; font-size: 50px; font-weight: 700; line-height: 1.15; color: #36454F; margin: 0 0 18px 0;\" data-kid=\"33\">Herzlich Willkommen bei Ihrer Zahnärztin in Nymphenburg</h1>\n      <p style=\"font-family: 'Lora', serif; font-size: 22px; font-style: italic; color: #6B3558; font-weight: 500; margin: 0 0 18px 0;\" data-kid=\"34\">Wir freuen uns auf Ihr Lächeln!</p>\n      <p style=\"font-size: 16px; line-height: 1.7; color: #5A6E7A; margin: 0 0 36px 0;\" data-kid=\"35\">Ihre freundliche Zahnarztpraxis im Herzen von Nymphenburg — familiär, mehrsprachig, transparent. Wir nehmen uns Zeit für Sie und Ihre Familie.</p>\n      <div style=\"display: flex; gap: 16px; align-items: center; flex-wrap: wrap;\" data-kid=\"36\">\n        <a href=\"#\" style=\"background: #6B3558; color: white; padding: 16px 32px; border-radius: 50px; text-decoration: none; font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 16px rgba(107,53,88,0.3);\" data-kid=\"37\">\n          <i class=\"ti ti-calendar-event\" style=\"font-size: 18px;\" data-kid=\"38\"></i>\n          Termin vereinbaren\n        </a>\n        <a href=\"#\" style=\"color: #36454F; text-decoration: none; font-size: 15px; font-weight: 500; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid #36454F; padding-bottom: 2px;\" data-kid=\"39\">\n          <i class=\"ti ti-phone\" style=\"font-size: 16px; color: #6B3558;\" data-kid=\"40\"></i>\n          Jetzt anrufen\n        </a>\n      </div>\n    </div>\n    <div style=\"flex: 1; position: relative; overflow: hidden; min-height: 700px;\" data-kid=\"41\">\n      <img src=\"https://images.pexels.com/photos/5355860/pexels-photo-5355860.jpeg?auto=compress&cs=tinysrgb&w=900&q=80\" alt=\"Lächelnde Patientin in der Zahnarztpraxis — Tima Miroshnichenko on Pexels\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover; border-radius: 24px 0 0 24px;\" data-kid=\"42\">\n      <div style=\"position: absolute; inset: 0; background: linear-gradient(135deg, rgba(250,240,230,0.15) 0%, transparent 60%); border-radius: 24px 0 0 24px;\" data-kid=\"43\"></div>\n    </div>\n  </div>\n\n  \n  <div style=\"background: #FAF0E6; padding: 0 64px;\" data-kid=\"44\">\n    <div style=\"display: flex; gap: 24px; transform: translateY(-40px);\" data-kid=\"45\">\n      <div style=\"flex: 1; background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(107,53,88,0.25); border-radius: 16px; padding: 24px 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); display: flex; align-items: flex-start; gap: 16px;\" data-kid=\"46\">\n        <div style=\"width: 44px; height: 44px; background: #F2E8EF; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"47\">\n          <i class=\"ti ti-clock\" style=\"color: #6B3558; font-size: 22px;\" data-kid=\"48\"></i>\n        </div>\n        <div data-kid=\"49\">\n          <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;\" data-kid=\"50\">Öffnungszeiten</div>\n          <div style=\"font-size: 15px; font-weight: 600; color: #36454F;\" data-kid=\"51\">Mo–Fr 8:30–13:00</div>\n          <div style=\"font-size: 13px; color: #5A6E7A; margin-top: 2px;\" data-kid=\"52\">Mo, Di, Do auch 14:00–18/19 Uhr</div>\n        </div>\n      </div>\n      <div style=\"flex: 1; background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(107,53,88,0.25); border-radius: 16px; padding: 24px 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); display: flex; align-items: flex-start; gap: 16px;\" data-kid=\"53\">\n        <div style=\"width: 44px; height: 44px; background: #F2E8EF; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"54\">\n          <i class=\"ti ti-map-pin\" style=\"color: #6B3558; font-size: 22px;\" data-kid=\"55\"></i>\n        </div>\n        <div data-kid=\"56\">\n          <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;\" data-kid=\"57\">Adresse</div>\n          <div style=\"font-size: 15px; font-weight: 600; color: #36454F;\" data-kid=\"58\">Volpinistraße 19</div>\n          <div style=\"font-size: 13px; color: #5A6E7A; margin-top: 2px;\" data-kid=\"59\">80638 München – Nymphenburg</div>\n        </div>\n      </div>\n      <div style=\"flex: 1; background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(107,53,88,0.25); border-radius: 16px; padding: 24px 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); display: flex; align-items: flex-start; gap: 16px;\" data-kid=\"60\">\n        <div style=\"width: 44px; height: 44px; background: #F2E8EF; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"61\">\n          <i class=\"ti ti-phone-call\" style=\"color: #6B3558; font-size: 22px;\" data-kid=\"62\"></i>\n        </div>\n        <div data-kid=\"63\">\n          <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px;\" data-kid=\"64\">Telefon</div>\n          <div style=\"font-size: 15px; font-weight: 600; color: #36454F;\" data-kid=\"65\">089 / 178 33 50</div>\n          <div style=\"font-size: 13px; color: #6B3558; margin-top: 2px; font-weight: 500; cursor: pointer;\" data-kid=\"66\">Jetzt anrufen →</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div style=\"background: #FAF0E6; padding: 24px 64px 80px;\" data-kid=\"67\">\n    <div style=\"text-align: center; margin-bottom: 52px;\" data-kid=\"68\">\n      <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;\" data-kid=\"69\">Was wir für Sie tun</div>\n      <h2 style=\"font-family: 'Lora', serif; font-size: 40px; font-weight: 700; color: #36454F; margin: 0 0 16px 0;\" data-kid=\"70\">Unsere Leistungen</h2>\n      <p style=\"font-size: 16px; color: #5A6E7A; max-width: 560px; margin: 0 auto; line-height: 1.7;\" data-kid=\"71\">Von der Vorsorge bis zur ästhetischen Behandlung — wir begleiten Sie und Ihre Familie mit modernster Medizintechnik und herzlicher Fürsorge.</p>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;\" data-kid=\"72\">\n      <div style=\"background: #F2E8EF; border: 2px solid #6B3558; border-radius: 20px; padding: 32px; position: relative; overflow: hidden;\" data-kid=\"73\">\n        <div style=\"position: absolute; top: 16px; right: 16px; background: #6B3558; color: white; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.06em;\" data-kid=\"74\">Schwerpunkt</div>\n        <div style=\"width: 52px; height: 52px; background: #6B3558; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"75\">\n          <i class=\"ti ti-mood-kid\" style=\"color: white; font-size: 26px;\" data-kid=\"76\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"77\">Kinderzahnheilkunde</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"78\">Sanfte Zahnmedizin für Ihre Kleinen — mit Kinderecke und viel Geduld für ein angstfreies Erlebnis.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"79\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"80\"></i></a>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1px solid #D4C0CF; border-radius: 20px; padding: 32px;\" data-kid=\"81\">\n        <div style=\"width: 52px; height: 52px; background: #F2E8EF; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"82\">\n          <i class=\"ti ti-shield-check\" style=\"color: #6B3558; font-size: 26px;\" data-kid=\"83\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"84\">Individualprophylaxe</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"85\">Professionelle Zahnreinigung und individuelle Vorsorge für nachhaltig gesunde Zähne.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"86\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"87\"></i></a>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1px solid #D4C0CF; border-radius: 20px; padding: 32px;\" data-kid=\"88\">\n        <div style=\"width: 52px; height: 52px; background: #F2E8EF; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"89\">\n          <i class=\"ti ti-sparkles\" style=\"color: #6B3558; font-size: 26px;\" data-kid=\"90\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"91\">Hochwertige Zahnerhaltung</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"92\">Kunststofffüllungen und Keramikinlays in höchster Qualität — ästhetisch und langlebig.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"93\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"94\"></i></a>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1px solid #D4C0CF; border-radius: 20px; padding: 32px;\" data-kid=\"95\">\n        <div style=\"width: 52px; height: 52px; background: #F2E8EF; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"96\">\n          <i class=\"ti ti-tooth\" style=\"color: #6B3558; font-size: 26px;\" data-kid=\"97\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"98\">Prothetik &amp; Implantate</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"99\">Kronen, Brücken, vollkeramische Restaurationen &amp; Zirkonoxid für ein schönes, natürliches Lächeln.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"100\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"101\"></i></a>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1px solid #D4C0CF; border-radius: 20px; padding: 32px;\" data-kid=\"102\">\n        <div style=\"width: 52px; height: 52px; background: #F2E8EF; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"103\">\n          <i class=\"ti ti-activity\" style=\"color: #6B3558; font-size: 26px;\" data-kid=\"104\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"105\">Parodontologie</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"106\">Behandlung von Zahnfleischerkrankungen für nachhaltige Mundgesundheit und den Erhalt Ihrer Zähne.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"107\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"108\"></i></a>\n      </div>\n      <div style=\"background: #FFFFFF; border: 1px solid #D4C0CF; border-radius: 20px; padding: 32px;\" data-kid=\"109\">\n        <div style=\"width: 52px; height: 52px; background: #F2E8EF; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;\" data-kid=\"110\">\n          <i class=\"ti ti-mood-smile\" style=\"color: #6B3558; font-size: 26px;\" data-kid=\"111\"></i>\n        </div>\n        <h3 style=\"font-family: 'Lora', serif; font-size: 20px; font-weight: 700; color: #36454F; margin: 0 0 10px 0;\" data-kid=\"112\">Ästhetik &amp; Bleaching</h3>\n        <p style=\"font-size: 14px; color: #5A6E7A; line-height: 1.6; margin: 0 0 20px 0;\" data-kid=\"113\">Professionelles Bleaching und ästhetische Behandlungen für Ihr strahlendes Lächeln.</p>\n        <a href=\"#\" style=\"color: #6B3558; font-size: 14px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;\" data-kid=\"114\">Mehr erfahren <i class=\"ti ti-arrow-right\" style=\"font-size: 14px;\" data-kid=\"115\"></i></a>\n      </div>\n    </div>\n    <div style=\"text-align: center; margin-top: 36px;\" data-kid=\"116\">\n      <a href=\"#\" style=\"display: inline-flex; align-items: center; gap: 8px; color: #6B3558; font-weight: 600; font-size: 15px; text-decoration: none; border: 2px solid #6B3558; padding: 12px 28px; border-radius: 50px;\" data-kid=\"117\">\n        Alle Leistungen ansehen <i class=\"ti ti-arrow-right\" style=\"font-size: 16px;\" data-kid=\"118\"></i>\n      </a>\n    </div>\n  </div>\n\n  \n  <div style=\"background: #FFFFFF; padding: 96px 64px;\" data-kid=\"119\">\n    <div style=\"display: flex; gap: 72px; align-items: center; max-width: 1240px; margin: 0 auto;\" data-kid=\"120\">\n      <div style=\"flex: 1; position: relative; min-height: 520px;\" data-kid=\"121\">\n        <div style=\"clip-path: polygon(0 0, calc(100% - 32px) 0, 100% 32px, 100% 100%, 0 100%); border-radius: 8px; overflow: hidden; height: 520px;\" data-kid=\"122\">\n          <img src=\"https://images.pexels.com/photos/8313187/pexels-photo-8313187.jpeg?auto=compress&cs=tinysrgb&w=700&q=80\" alt=\"Zahnarztberatung — RDNE Stock project on Pexels\" decoding=\"async\" loading=\"lazy\" style=\"width: 100%; height: 100%; object-fit: cover;\" data-kid=\"123\">\n        </div>\n        <div style=\"position: absolute; bottom: 32px; left: -24px; background: #6B3558; color: white; padding: 20px 24px; border-radius: 16px; box-shadow: 0 8px 24px rgba(107,53,88,0.35);\" data-kid=\"124\">\n          <div style=\"font-family: 'Lora', serif; font-size: 28px; font-weight: 700;\" data-kid=\"125\">12+</div>\n          <div style=\"font-size: 12px; font-weight: 500; margin-top: 2px; opacity: 0.9;\" data-kid=\"126\">Jahre Erfahrung</div>\n        </div>\n      </div>\n      <div style=\"flex: 1;\" data-kid=\"127\">\n        <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;\" data-kid=\"128\">Über uns</div>\n        <h2 style=\"font-family: 'Lora', serif; font-size: 38px; font-weight: 700; color: #36454F; margin: 0 0 24px 0; line-height: 1.2;\" data-kid=\"129\">Ihre Zahnarztpraxis mit Herz in Nymphenburg</h2>\n        <p style=\"font-size: 16px; color: #5A6E7A; line-height: 1.8; margin: 0 0 20px 0; padding: 20px 24px; background: #FAF0E6; border-left: 4px solid #6B3558; border-radius: 0 12px 12px 0; font-style: italic;\" data-kid=\"130\">\"Keine Sorge hinsichtlich Behandlungsplanung und Kosten: Was wir vorhaben erläutern wir Ihnen fair und verständlich.\"</p>\n        <p style=\"font-size: 16px; color: #5A6E7A; line-height: 1.7; margin: 0 0 28px 0;\" data-kid=\"131\">Wir bieten eine Kinderecke für die kleinen Patienten und sprechen Deutsch, Französisch, Englisch und Türkisch. Unser gesamtes Team steht Ihnen mit Einfühlungsvermögen und modernster Technik zur Seite.</p>\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 36px;\" data-kid=\"132\">\n          <div style=\"display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; color: #36454F;\" data-kid=\"133\">\n            <i class=\"ti ti-check\" style=\"color: #6B3558; font-size: 18px; font-weight: 700;\" data-kid=\"134\"></i>\n            Neueste Medizintechnik\n          </div>\n          <div style=\"display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; color: #36454F;\" data-kid=\"135\">\n            <i class=\"ti ti-check\" style=\"color: #6B3558; font-size: 18px;\" data-kid=\"136\"></i>\n            Familiäre Atmosphäre\n          </div>\n          <div style=\"display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; color: #36454F;\" data-kid=\"137\">\n            <i class=\"ti ti-check\" style=\"color: #6B3558; font-size: 18px;\" data-kid=\"138\"></i>\n            Mehrsprachiges Team\n          </div>\n          <div style=\"display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; color: #36454F;\" data-kid=\"139\">\n            <i class=\"ti ti-check\" style=\"color: #6B3558; font-size: 18px;\" data-kid=\"140\"></i>\n            Transparente Kosten\n          </div>\n        </div>\n        <a href=\"#\" style=\"color: #6B3558; font-weight: 600; font-size: 15px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border-bottom: 2px solid #6B3558; padding-bottom: 4px;\" data-kid=\"141\">\n          Unser Team kennenlernen <i class=\"ti ti-arrow-right\" style=\"font-size: 16px;\" data-kid=\"142\"></i>\n        </a>\n      </div>\n    </div>\n  </div>\n\n  \n  <div style=\"background: #F2E8EF; padding: 80px 64px;\" data-kid=\"143\">\n    <div style=\"text-align: center; margin-bottom: 52px;\" data-kid=\"144\">\n      <div style=\"font-size: 13px; color: #6B3558; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;\" data-kid=\"145\">Das Team</div>\n      <h2 style=\"font-family: 'Lora', serif; font-size: 38px; font-weight: 700; color: #36454F; margin: 0 0 12px 0;\" data-kid=\"146\">Unser Team</h2>\n      <p style=\"font-size: 16px; color: #5A6E7A;\" data-kid=\"147\">Persönlich. Kompetent. Herzlich.</p>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; max-width: 1000px; margin: 0 auto;\" data-kid=\"148\">\n      <div style=\"background: #FFFFFF; border-radius: 20px; padding: 32px 24px; text-align: center; box-shadow: 0 2px 16px rgba(54,69,79,0.06);\" data-kid=\"149\">\n        <img src=\"https://i.pravatar.cc/120?u=laurice\" alt=\"Dr. Laurice Thierry Tomte\" decoding=\"async\" loading=\"lazy\" style=\"width: 88px; height: 88px; border-radius: 50%; object-fit: cover; margin-bottom: 16px; border: 3px solid #F2E8EF;\" data-kid=\"150\">\n        <div style=\"font-family: 'Lora', serif; font-size: 16px; font-weight: 700; color: #36454F; margin-bottom: 6px;\" data-kid=\"151\">Dr. Laurice Thierry Tomte</div>\n        <div style=\"font-size: 13px; color: #6B3558; font-weight: 600;\" data-kid=\"152\">Zahnärztin</div>\n        <div style=\"font-size: 12px; color: #5A6E7A; margin-top: 4px;\" data-kid=\"153\">Praxisinhaberin</div>\n      </div>\n      <div