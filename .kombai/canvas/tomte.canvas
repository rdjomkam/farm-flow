      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Public+Sans:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n<div style=\"font-family: 'Public Sans', sans-serif; color: #36454F; background-color: #FAF0E6; min-width: 375px;\" data-kid=\"1\">\n\n  <header style=\"background: white; border-bottom: 1px solid #F2E8EF; height: 60px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px;\" data-kid=\"2\">\n    <div style=\"display: flex; align-items: center; gap: 8px;\" data-kid=\"3\">\n      <div style=\"width: 32px; height: 32px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"4\">\n        <i class=\"ti ti-tooth\" style=\"color: white; font-size: 15px;\" data-kid=\"5\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; font-weight: 600; font-size: 18px; color: #36454F;\" data-kid=\"6\">Dr. Tomte</span>\n    </div>\n    <button style=\"width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;\" data-kid=\"7\">\n      <i class=\"ti ti-menu-2\" style=\"font-size: 24px; color: #36454F;\" data-kid=\"8\"></i>\n    </button>\n  </header>\n\n  <section style=\"background: #FAF0E6; padding: 44px 20px 36px; text-align: center;\" data-kid=\"9\">\n    <p style=\"font-size: 11px; font-weight: 600; color: #6B3558; letter-spacing: 0.15em; text-transform: uppercase; margin: 0 0 10px;\" data-kid=\"10\">Home · Praxis</p>\n    <h1 style=\"font-family: 'Lora', serif; font-size: 34px; font-weight: 700; color: #36454F; line-height: 1.2; margin: 0 0 12px;\" data-kid=\"11\">Unsere Praxis</h1>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.65; margin: 0; line-height: 1.6;\" data-kid=\"12\">Ein Ort, an dem Sie sich wohlfühlen</p>\n  </section>\n\n  <section style=\"background: white; padding: 28px 20px;\" data-kid=\"13\">\n    <div style=\"width: 100%; height: 220px; background: #F2E8EF; border-radius: 16px; border: 1px solid rgba(107,53,88,0.25); display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 24px;\" data-kid=\"14\">\n      <i class=\"ti ti-building-hospital\" style=\"font-size: 48px; color: #6B3558; margin-bottom: 8px;\" data-kid=\"15\"></i>\n      <span style=\"font-size: 13px; color: #6B3558; font-weight: 500;\" data-kid=\"16\">[Foto: Empfangsbereich mit warmem Licht]</span>\n    </div>\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 12px;\" data-kid=\"17\">Eine Praxis zum Wohlfühlen</h2>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.72; line-height: 1.7; margin: 0 0 20px;\" data-kid=\"18\">Unsere Praxis in Nymphenburg verbindet modernste Medizintechnik mit einer herzlichen, persönlichen Atmosphäre. Bei uns stehen Sie als Mensch im Mittelpunkt.</p>\n    <div style=\"display: flex; flex-direction: column; gap: 10px;\" data-kid=\"19\">\n      <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"20\">\n        <span style=\"width: 22px; height: 22px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"21\">\n          <i class=\"ti ti-check\" style=\"color: white; font-size: 12px;\" data-kid=\"22\"></i>\n        </span>\n        <span style=\"font-size: 14px; color: #36454F; opacity: 0.82;\" data-kid=\"23\">Modernste Medizintechnik</span>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"24\">\n        <span style=\"width: 22px; height: 22px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"25\">\n          <i class=\"ti ti-check\" style=\"color: white; font-size: 12px;\" data-kid=\"26\"></i>\n        </span>\n        <span style=\"font-size: 14px; color: #36454F; opacity: 0.82;\" data-kid=\"27\">Angenehme Atmosphäre</span>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 10px;\" data-kid=\"28\">\n        <span style=\"width: 22px; height: 22px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"29\">\n          <i class=\"ti ti-check\" style=\"color: white; font-size: 12px;\" data-kid=\"30\"></i>\n        </span>\n        <span style=\"font-size: 14px; color: #36454F; opacity: 0.82;\" data-kid=\"31\">Liebevolle Kinderecke</span>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #FAF0E6; padding: 28px 20px;\" data-kid=\"32\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 18px;\" data-kid=\"33\">Einblicke</h2>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 12px;\" data-kid=\"34\">\n      <div style=\"height: 148px; background: #F2E8EF; border-radius: 14px; border: 1px solid rgba(107,53,88,0.2); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;\" data-kid=\"35\">\n        <i class=\"ti ti-door\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"36\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 500; text-align: center; padding: 0 8px;\" data-kid=\"37\">Empfang</span>\n      </div>\n      <div style=\"height: 148px; background: #F2E8EF; border-radius: 14px; border: 1px solid rgba(107,53,88,0.2); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;\" data-kid=\"38\">\n        <i class=\"ti ti-tooth\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"39\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 500; text-align: center; padding: 0 8px;\" data-kid=\"40\">Behandlungszimmer 1</span>\n      </div>\n      <div style=\"height: 148px; background: #F2E8EF; border-radius: 14px; border: 1px solid rgba(107,53,88,0.2); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;\" data-kid=\"41\">\n        <i class=\"ti ti-tooth\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"42\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 500; text-align: center; padding: 0 8px;\" data-kid=\"43\">Behandlungszimmer 2</span>\n      </div>\n      <div style=\"height: 148px; background: #F2E8EF; border-radius: 14px; border: 1px solid rgba(107,53,88,0.2); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;\" data-kid=\"44\">\n        <i class=\"ti ti-clock\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"45\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 500; text-align: center; padding: 0 8px;\" data-kid=\"46\">Wartebereich</span>\n      </div>\n      <div style=\"height: 148px; background: rgba(107,53,88,0.12); border-radius: 14px; border: 2px solid #6B3558; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; position: relative;\" data-kid=\"47\">\n        <span style=\"position: absolute; top: 7px; right: 7px; background: #6B3558; color: white; font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 20px;\" data-kid=\"48\">Nr. 1</span>\n        <i class=\"ti ti-mood-kid\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"49\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 600; text-align: center; padding: 0 8px;\" data-kid=\"50\">Kinderecke</span>\n      </div>\n      <div style=\"height: 148px; background: #F2E8EF; border-radius: 14px; border: 1px solid rgba(107,53,88,0.2); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;\" data-kid=\"51\">\n        <i class=\"ti ti-droplet\" style=\"font-size: 30px; color: #6B3558;\" data-kid=\"52\"></i>\n        <span style=\"font-size: 11px; color: #6B3558; font-weight: 500; text-align: center; padding: 0 8px;\" data-kid=\"53\">Sterilisation</span>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #F2E8EF; padding: 28px 20px;\" data-kid=\"54\">\n    <div style=\"width: 100%; height: 200px; background: rgba(107,53,88,0.18); border-radius: 16px; border: 1px solid rgba(107,53,88,0.3); display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 18px;\" data-kid=\"55\">\n      <i class=\"ti ti-mood-kid\" style=\"font-size: 52px; color: #6B3558; margin-bottom: 8px;\" data-kid=\"56\"></i>\n      <span style=\"font-size: 13px; color: #6B3558; font-weight: 500;\" data-kid=\"57\">[Foto: Kinderecke mit Spielzeug]</span>\n    </div>\n    <div style=\"display: inline-flex; align-items: center; background: #6B3558; color: white; font-size: 11px; font-weight: 700; padding: 5px 14px; border-radius: 20px; margin-bottom: 14px;\" data-kid=\"58\">\n      Kinderzahnheilkunde — Nr. 1 Schwerpunkt\n    </div>\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 12px;\" data-kid=\"59\">Unsere Kinderecke</h2>\n    <p style=\"font-size: 14px; color: #36454F; opacity: 0.72; line-height: 1.7; margin: 0;\" data-kid=\"60\">Für unsere kleinen Patienten haben wir eine liebevoll gestaltete Kinderecke eingerichtet. Eine vertraute, spielerische Atmosphäre hilft Kindern, sich beim Zahnarzt wohlzufühlen.</p>\n  </section>\n\n  <section style=\"background: white; padding: 28px 20px;\" data-kid=\"61\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 22px; font-weight: 600; color: #36454F; margin: 0 0 18px;\" data-kid=\"62\">Unsere Technologie</h2>\n    <div style=\"display: flex; flex-direction: column; gap: 12px;\" data-kid=\"63\">\n      <div style=\"display: flex; align-items: center; gap: 14px; padding: 16px; border-radius: 14px; border: 1px solid #F2E8EF; background: #FAF0E6;\" data-kid=\"64\">\n        <div style=\"width: 48px; height: 48px; background: rgba(107,53,88,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"65\">\n          <i class=\"ti ti-scan\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"66\"></i>\n        </div>\n        <div data-kid=\"67\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 3px;\" data-kid=\"68\">Digital-Röntgen</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.6; margin: 0;\" data-kid=\"69\">Minimale Strahlung, maximale Präzision</p>\n        </div>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 14px; padding: 16px; border-radius: 14px; border: 1px solid #F2E8EF; background: #FAF0E6;\" data-kid=\"70\">\n        <div style=\"width: 48px; height: 48px; background: rgba(107,53,88,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"71\">\n          <i class=\"ti ti-cube\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"72\"></i>\n        </div>\n        <div data-kid=\"73\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 3px;\" data-kid=\"74\">CAD/CAM Cerec</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.6; margin: 0;\" data-kid=\"75\">Keramikinlays in einer einzigen Sitzung</p>\n        </div>\n      </div>\n      <div style=\"display: flex; align-items: center; gap: 14px; padding: 16px; border-radius: 14px; border: 1px solid #F2E8EF; background: #FAF0E6;\" data-kid=\"76\">\n        <div style=\"width: 48px; height: 48px; background: rgba(107,53,88,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"77\">\n          <i class=\"ti ti-device-laptop\" style=\"font-size: 22px; color: #6B3558;\" data-kid=\"78\"></i>\n        </div>\n        <div data-kid=\"79\">\n          <h3 style=\"font-size: 14px; font-weight: 600; color: #36454F; margin: 0 0 3px;\" data-kid=\"80\">Digitale Abformung</h3>\n          <p style=\"font-size: 12px; color: #36454F; opacity: 0.6; margin: 0;\" data-kid=\"81\">Komfortabel &amp; vollständig abdruckfrei</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section style=\"background: #36454F; padding: 44px 20px; text-align: center;\" data-kid=\"82\">\n    <h2 style=\"font-family: 'Lora', serif; font-size: 24px; font-weight: 600; color: white; margin: 0 0 12px;\" data-kid=\"83\">Kommen Sie uns besuchen</h2>\n    <p style=\"font-size: 14px; color: rgba(255,255,255,0.62); margin: 0 0 28px; line-height: 1.6;\" data-kid=\"84\">Überzeugen Sie sich selbst von unserer Praxis in Nymphenburg.</p>\n    <button style=\"width: 100%; max-width: 295px; background: #6B3558; color: white; border: none; padding: 15px 24px; border-radius: 40px; font-size: 15px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: 'Public Sans', sans-serif;\" data-kid=\"85\">\n      <i class=\"ti ti-calendar\" data-kid=\"86\"></i>Ersten Termin vereinbaren\n    </button>\n  </section>\n\n  <footer style=\"background: #2A1E28; padding: 32px 20px 24px;\" data-kid=\"87\">\n    <div style=\"display: flex; align-items: center; gap: 10px; margin-bottom: 18px;\" data-kid=\"88\">\n      <div style=\"width: 30px; height: 30px; border-radius: 50%; background: #6B3558; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\" data-kid=\"89\">\n        <i class=\"ti ti-tooth\" style=\"color: white; font-size: 14px;\" data-kid=\"90\"></i>\n      </div>\n      <span style=\"font-family: 'Lora', serif; color: white; font-weight: 600; font-size: 14px;\" data-kid=\"91\">Zahnarztpraxis Dr. Tomte</span>\n    </div>\n    <p style=\"font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.8; margin: 0 0 20px;\" data-kid=\"92\">Volpinistraße 19<br data-kid=\"93\">80638 München – Nymphenburg</p>\n    <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;\" data-kid=\"94\">\n      <div data-kid=\"95\">\n        <p style=\"font-size: 10px; color: rgba(255,255,255,0.35); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 8px;\" data-kid=\"96\">Kontakt</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 4px;\" data-kid=\"97\">089 / 178 33 50</p>\n        <p style=\"font-size: 11px; color: rgba(255,255,255,0.55); margin: 0;\" data-kid=\"98\">praxis@zahnarztpraxis-tomte.de</p>\n      </div>\n      <div data-kid=\"99\">\n        <p style=\"font-size: 10px; color: rgba(255,255,255,0.35); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 8px;\" data-kid=\"100\">Navigation</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"101\">Home</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"102\">Praxis</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 3px;\" data-kid=\"103\">Über uns</p>\n        <p style=\"font-size: 12px; color: rgba(255,255,255,0.65); margin: 0;\" data-kid=\"104\">Leistungen</p>\n      </div>\n    </div>\n    <div style=\"border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;\" data-kid=\"105\">\n      <p style=\"font-size: 11px; color: rgba(255,255,255,0.32); margin: 0;\" data-kid=\"106\">© Dr. Tomte 2012–2025</p>\n      <div style=\"display: flex; gap: 14px; font-size: 11px; color: rgba(255,255,255,0.32);\" data-kid=\"107\">\n        <span data-kid=\"108\">Datenschutz</span><span data-kid=\"109\">Impressum</span>\n      </div>\n    </div>\n  </footer>\n\n  <div style=\"background: white; border-top: 1.5px solid #F2E8EF; padding: 12px 16px; display: flex; gap: 12px;\" data-kid=\"110\">\n    <button style=\"flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 13px; border-radius: 12px; border: 1.5px solid #6B3558; background: none; color: #6B3558; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Public Sans', sans-serif;\" data-kid=\"111\">\n      <i class=\"ti ti-phone\" style=\"font-size: 16px;\" data-kid=\"112\"></i><span data-kid=\"113\">Anrufen</span>\n    </button>\n    <button style=\"flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px; padding: 13px; border-radius: 12px; border: none; background: #6B3558; color: white; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'Public Sans', sans-serif;\" data-kid=\"114\">\n      <i class=\"ti ti-calendar\" style=\"font-size: 16px;\" data-kid=\"115\"></i><span data-kid=\"116\">Termin</span>\n    </button>\n  </div>\n</div>",
