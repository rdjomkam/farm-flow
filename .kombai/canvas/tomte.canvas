      "html": "<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Public+Sans:wght@300;400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n</style>\n\n<div style=\"font-family: 'Public Sans', sans-serif; color: #36454F; background-color: #FAF0E6; position: relative;\" data-kid=\"1\">\n\n  \n  <div style=\"background-color: #F2E8EF;\" class=\"py-2 px-8\" data-kid=\"2\">\n    <div class=\"max-w-[1320px] mx-auto flex items-center justify-between\" data-kid=\"3\">\n      <a href=\"tel:0891783350\" class=\"flex items-center gap-2 text-sm no-underline\" style=\"color: #36454F;\" data-kid=\"4\">\n        <i class=\"ti ti-phone\" style=\"color: #6B3558;\" data-kid=\"5\"></i>\n        <span data-kid=\"6\">089 / 178 33 50</span>\n      </a>\n      <div class=\"flex items-center gap-3 text-sm font-medium\" style=\"color: #36454F;\" data-kid=\"7\">\n        <span data-kid=\"8\">DE</span><span style=\"color: rgba(107,53,88,0.4);\" data-kid=\"9\">|</span>\n        <span data-kid=\"10\">EN</span><span style=\"color: rgba(107,53,88,0.4);\" data-kid=\"11\">|</span>\n        <span data-kid=\"12\">FR</span><span style=\"color: rgba(107,53,88,0.4);\" data-kid=\"13\">|</span>\n        <span data-kid=\"14\">TR</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <nav class=\"bg-white py-4 px-8\" style=\"box-shadow: 0 1px 4px rgba(0,0,0,0.08);\" data-kid=\"15\">\n    <div class=\"max-w-[1320px] mx-auto flex items-center justify-between\" data-kid=\"16\">\n      <div class=\"flex items-center gap-2.5\" data-kid=\"17\">\n        <div class=\"w-9 h-9 rounded-full flex items-center justify-center\" style=\"background-color: #6B3558;\" data-kid=\"18\">\n          <i class=\"ti ti-tooth text-white\" style=\"font-size: 1.05rem;\" data-kid=\"19\"></i>\n        </div>\n        <span class=\"font-semibold\" style=\"font-family: 'Lora', serif; font-size: 1rem; color: #36454F;\" data-kid=\"20\">Zahnarztpraxis Dr. Tomte</span>\n      </div>\n      <div class=\"flex items-center gap-8\" data-kid=\"21\">\n        <a href=\"#\" class=\"text-sm font-medium no-underline\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"22\">Home</a>\n        <a href=\"#\" class=\"text-sm font-medium no-underline pb-0.5 border-b-2\" style=\"color: #6B3558; border-color: #6B3558;\" data-kid=\"23\">Praxis</a>\n        <a href=\"#\" class=\"text-sm font-medium no-underline\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"24\">Über uns</a>\n        <a href=\"#\" class=\"text-sm font-medium no-underline\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"25\">Leistungen</a>\n        <a href=\"#\" class=\"text-sm font-medium no-underline\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"26\">Anfahrt</a>\n        <a href=\"#\" class=\"text-sm font-medium no-underline\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"27\">Kontakt</a>\n      </div>\n      <a href=\"#\" class=\"inline-flex items-center gap-2 text-white text-sm font-semibold px-5 py-2.5 rounded-full no-underline\" style=\"background-color: #6B3558;\" data-kid=\"28\">\n        <i class=\"ti ti-calendar-event\" data-kid=\"29\"></i>\n        Termin vereinbaren\n      </a>\n    </div>\n  </nav>\n\n  \n  <div class=\"px-8 relative overflow-hidden\" style=\"background-color: #FAF0E6; height: 380px;\" data-kid=\"30\">\n    <div class=\"absolute rounded-full\" style=\"width: 520px; height: 520px; background-color: rgba(107,53,88,0.07); right: -90px; top: -110px;\" data-kid=\"31\"></div>\n    <div class=\"absolute rounded-full\" style=\"width: 280px; height: 280px; background-color: rgba(107,53,88,0.05); right: 220px; bottom: -80px;\" data-kid=\"32\"></div>\n    <div class=\"absolute rounded-full\" style=\"width: 150px; height: 150px; background-color: rgba(107,53,88,0.06); left: 38%; top: 30px;\" data-kid=\"33\"></div>\n    <div class=\"max-w-[1320px] mx-auto h-full flex flex-col justify-center\" data-kid=\"34\">\n      <div class=\"flex items-center gap-2 text-sm mb-4\" style=\"color: rgba(54,69,79,0.45);\" data-kid=\"35\">\n        <span data-kid=\"36\">Home</span>\n        <i class=\"ti ti-chevron-right\" style=\"font-size: 0.7rem;\" data-kid=\"37\"></i>\n        <span style=\"color: #6B3558;\" data-kid=\"38\">Praxis</span>\n      </div>\n      <h1 class=\"mb-4\" style=\"font-family: 'Lora', serif; font-size: 3rem; font-weight: 700; line-height: 1.2; color: #36454F;\" data-kid=\"39\">Unsere Praxis</h1>\n      <p class=\"text-lg max-w-xl\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"40\">Ein Ort der Ruhe, modernster Medizin und persönlicher Betreuung — mitten in Nymphenburg.</p>\n    </div>\n  </div>\n\n  \n  <div class=\"bg-white py-20 px-8\" data-kid=\"41\">\n    <div class=\"max-w-[1320px] mx-auto grid gap-16 items-center\" style=\"grid-template-columns: 1fr 1fr;\" data-kid=\"42\">\n      <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-6\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.3); height: 480px;\" data-kid=\"43\">\n        <div class=\"w-16 h-16 rounded-full flex items-center justify-center mb-4\" style=\"background-color: rgba(107,53,88,0.18);\" data-kid=\"44\">\n          <i class=\"ti ti-camera\" style=\"color: #6B3558; font-size: 1.6rem;\" data-kid=\"45\"></i>\n        </div>\n        <p class=\"text-sm font-medium leading-relaxed\" style=\"color: rgba(54,69,79,0.55);\" data-kid=\"46\">Foto: Moderne Empfangstheke<br data-kid=\"47\">mit warmer Beleuchtung</p>\n      </div>\n      <div data-kid=\"48\">\n        <div class=\"inline-block text-xs font-semibold px-3 py-1.5 rounded-full mb-5 uppercase tracking-wider\" style=\"background-color: #F2E8EF; color: #6B3558;\" data-kid=\"49\">Unsere Praxis</div>\n        <h2 class=\"mb-5\" style=\"font-family: 'Lora', serif; font-size: 2.1rem; font-weight: 600; line-height: 1.3; color: #36454F;\" data-kid=\"50\">Eine Praxis zum Wohlfühlen</h2>\n        <p class=\"text-base leading-relaxed mb-8\" style=\"color: rgba(54,69,79,0.7);\" data-kid=\"51\">Willkommen in unserer Zahnarztpraxis in München-Nymphenburg. Wir haben uns eine ruhige und entspannte Atmosphäre geschaffen, in der Sie sich von Anfang an wohl und aufgehoben fühlen. Modernste Ausstattung und ein herzliches Team sorgen für eine angenehme Behandlung auf höchstem Niveau.</p>\n        <ul class=\"space-y-3.5\" data-kid=\"52\">\n          <li class=\"flex items-center gap-3\" style=\"color: rgba(54,69,79,0.8);\" data-kid=\"53\">\n            <div class=\"w-6 h-6 rounded-full flex items-center justify-center shrink-0\" style=\"background-color: #6B3558;\" data-kid=\"54\">\n              <i class=\"ti ti-check text-white\" style=\"font-size: 0.7rem;\" data-kid=\"55\"></i>\n            </div>\n            <span class=\"text-sm\" data-kid=\"56\">Modernste Behandlungstechnologie</span>\n          </li>\n          <li class=\"flex items-center gap-3\" style=\"color: rgba(54,69,79,0.8);\" data-kid=\"57\">\n            <div class=\"w-6 h-6 rounded-full flex items-center justify-center shrink-0\" style=\"background-color: #6B3558;\" data-kid=\"58\">\n              <i class=\"ti ti-check text-white\" style=\"font-size: 0.7rem;\" data-kid=\"59\"></i>\n            </div>\n            <span class=\"text-sm\" data-kid=\"60\">Angenehme, ruhige Atmosphäre</span>\n          </li>\n          <li class=\"flex items-center gap-3\" style=\"color: rgba(54,69,79,0.8);\" data-kid=\"61\">\n            <div class=\"w-6 h-6 rounded-full flex items-center justify-center shrink-0\" style=\"background-color: #6B3558;\" data-kid=\"62\">\n              <i class=\"ti ti-check text-white\" style=\"font-size: 0.7rem;\" data-kid=\"63\"></i>\n            </div>\n            <span class=\"text-sm\" data-kid=\"64\">Barrierefreier Zugang</span>\n          </li>\n          <li class=\"flex items-center gap-3\" style=\"color: rgba(54,69,79,0.8);\" data-kid=\"65\">\n            <div class=\"w-6 h-6 rounded-full flex items-center justify-center shrink-0\" style=\"background-color: #6B3558;\" data-kid=\"66\">\n              <i class=\"ti ti-check text-white\" style=\"font-size: 0.7rem;\" data-kid=\"67\"></i>\n            </div>\n            <span class=\"text-sm\" data-kid=\"68\">Kostenlose Parkplätze vor dem Haus</span>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"py-20 px-8\" style=\"background-color: #FAF0E6;\" data-kid=\"69\">\n    <div class=\"max-w-[1320px] mx-auto\" data-kid=\"70\">\n      <div class=\"text-center mb-14\" data-kid=\"71\">\n        <div class=\"inline-block text-xs font-semibold px-3 py-1.5 rounded-full mb-4 uppercase tracking-wider\" style=\"background-color: #F2E8EF; color: #6B3558;\" data-kid=\"72\">Galerie</div>\n        <h2 style=\"font-family: 'Lora', serif; font-size: 2.1rem; font-weight: 600; color: #36454F;\" data-kid=\"73\">Einblicke in unsere Praxis</h2>\n      </div>\n      <div class=\"grid gap-4\" style=\"grid-template-columns: repeat(3, 1fr);\" data-kid=\"74\">\n        <div class=\"col-span-2 rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.25); height: 280px;\" data-kid=\"75\">\n          <i class=\"ti ti-users mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"76\"></i>\n          <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"77\">Foto: Empfang – freundliches Team begrüßt Patienten</p>\n        </div>\n        <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.25); height: 280px;\" data-kid=\"78\">\n          <i class=\"ti ti-stethoscope mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"79\"></i>\n          <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"80\">Foto: Behandlungszimmer 1 – modern und hell</p>\n        </div>\n        <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.25); height: 240px;\" data-kid=\"81\">\n          <i class=\"ti ti-radioactive mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"82\"></i>\n          <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"83\">Foto: Behandlungszimmer 2 – digitale Röntgentechnik</p>\n        </div>\n        <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.25); height: 240px;\" data-kid=\"84\">\n          <i class=\"ti ti-armchair mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"85\"></i>\n          <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"86\">Foto: Wartebereich – bequeme Sitzgelegenheiten</p>\n        </div>\n        <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.18); border: 2px solid rgba(107,53,88,0.4); height: 240px;\" data-kid=\"87\">\n          <i class=\"ti ti-mood-kid mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"88\"></i>\n          <p class=\"text-sm font-semibold mb-2\" style=\"color: rgba(54,69,79,0.7);\" data-kid=\"89\">Foto: Kinderecke – bunt und einladend für kleine Patienten</p>\n          <span class=\"inline-block text-white text-xs px-3 py-1 rounded-full\" style=\"background-color: #6B3558;\" data-kid=\"90\">Kinderschwerpunkt</span>\n        </div>\n        <div class=\"col-span-3 rounded-2xl flex flex-col items-center justify-center text-center p-4\" style=\"background-color: rgba(107,53,88,0.09); border: 1px dashed rgba(107,53,88,0.25); height: 200px;\" data-kid=\"91\">\n          <i class=\"ti ti-shield-check mb-3\" style=\"color: #6B3558; font-size: 2.2rem;\" data-kid=\"92\"></i>\n          <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"93\">Foto: Sterilisation – höchste Hygienestandards</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"py-20 px-8\" style=\"background-color: #F2E8EF;\" data-kid=\"94\">\n    <div class=\"max-w-[1320px] mx-auto grid gap-16 items-center\" style=\"grid-template-columns: 1fr 1fr;\" data-kid=\"95\">\n      <div class=\"rounded-2xl flex flex-col items-center justify-center text-center p-6\" style=\"background-color: rgba(107,53,88,0.15); border: 2px dashed rgba(107,53,88,0.35); height: 460px;\" data-kid=\"96\">\n        <div class=\"w-20 h-20 rounded-full flex items-center justify-center mb-5\" style=\"background-color: rgba(107,53,88,0.25);\" data-kid=\"97\">\n          <i class=\"ti ti-mood-kid\" style=\"color: #6B3558; font-size: 2.6rem;\" data-kid=\"98\"></i>\n        </div>\n        <p class=\"text-sm font-medium\" style=\"color: rgba(54,69,79,0.65);\" data-kid=\"99\">Foto: Kinderecke mit Spielzeug<br data-kid=\"100\">und bunten Möbeln</p>\n      </div>\n      <div data-kid=\"101\">\n        <div class=\"inline-flex items-center gap-2 text-white text-xs font-semibold px-4 py-2 rounded-full mb-6\" style=\"background-color: #6B3558;\" data-kid=\"102\">\n          <i class=\"ti ti-star-filled\" style=\"font-size: 0.7rem;\" data-kid=\"103\"></i>\n          Kinderzahnheilkunde — Unser Schwerpunkt\n        </div>\n        <h2 class=\"mb-5\" style=\"font-family: 'Lora', serif; font-size: 2.1rem; font-weight: 600; line-height: 1.3; color: #36454F;\" data-kid=\"104\">Unsere Kinderecke —<br data-kid=\"105\">Zahnarzt ohne Angst</h2>\n        <p class=\"text-base leading-relaxed mb-5\" style=\"color: rgba(54,69,79,0.7);\" data-kid=\"106\">Für unsere kleinen Patienten haben wir eine besondere Wohlfühloase geschaffen. Die liebevoll gestaltete Kinderecke mit bunten Spielsachen und kindgerechten Möbeln macht den Besuch beim Zahnarzt zu einem positiven Erlebnis.</p>\n        <p class=\"text-base leading-relaxed mb-8\" style=\"color: rgba(54,69,79,0.7);\" data-kid=\"107\">Dr. Tomte und das gesamte Team begegnen Kindern mit besonderer Geduld und Einfühlungsvermögen. Unser Ziel: Kinder von Anfang an mit positiven Erfahrungen an die Zahngesundheit heranzuführen — ganz ohne Angst.</p>\n        <a href=\"#\" class=\"inline-flex items-center gap-2 text-white text-sm font-semibold px-6 py-3 rounded-full no-underline\" style=\"background-color: #6B3558;\" data-kid=\"108\">\n          <i class=\"ti ti-calendar-event\" data-kid=\"109\"></i>\n          Termin für Ihr Kind vereinbaren\n        </a>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"bg-white py-20 px-8\" data-kid=\"110\">\n    <div class=\"max-w-[1320px] mx-auto\" data-kid=\"111\">\n      <div class=\"text-center mb-14\" data-kid=\"112\">\n        <div class=\"inline-block text-xs font-semibold px-3 py-1.5 rounded-full mb-4 uppercase tracking-wider\" style=\"background-color: #F2E8EF; color: #6B3558;\" data-kid=\"113\">Ausstattung</div>\n        <h2 class=\"mb-3\" style=\"font-family: 'Lora', serif; font-size: 2.1rem; font-weight: 600; color: #36454F;\" data-kid=\"114\">Neueste Medizintechnik</h2>\n        <p class=\"text-base max-w-lg mx-auto\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"115\">Wir setzen auf modernste Technologie — für präzisere Diagnosen, schonendere Behandlungen und höchsten Komfort.</p>\n      </div>\n      <div class=\"grid gap-8\" style=\"grid-template-columns: repeat(3, 1fr);\" data-kid=\"116\">\n        <div class=\"p-8 rounded-2xl\" style=\"border: 1px solid #F2E8EF;\" data-kid=\"117\">\n          <div class=\"w-14 h-14 rounded-xl flex items-center justify-center mb-6\" style=\"background-color: #F2E8EF;\" data-kid=\"118\">\n            <i class=\"ti ti-scan-eye\" style=\"color: #6B3558; font-size: 1.5rem;\" data-kid=\"119\"></i>\n          </div>\n          <h3 class=\"font-semibold text-lg mb-3\" style=\"font-family: 'Lora', serif; color: #36454F;\" data-kid=\"120\">Digital-Röntgen</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"121\">Modernste digitale Röntgentechnik mit bis zu 90% reduzierter Strahlenbelastung. Sofortige Bildauswertung für schnelle, präzise Diagnosen.</p>\n        </div>\n        <div class=\"p-8 rounded-2xl\" style=\"border: 1px solid #F2E8EF;\" data-kid=\"122\">\n          <div class=\"w-14 h-14 rounded-xl flex items-center justify-center mb-6\" style=\"background-color: #F2E8EF;\" data-kid=\"123\">\n            <i class=\"ti ti-cpu\" style=\"color: #6B3558; font-size: 1.5rem;\" data-kid=\"124\"></i>\n          </div>\n          <h3 class=\"font-semibold text-lg mb-3\" style=\"font-family: 'Lora', serif; color: #36454F;\" data-kid=\"125\">CAD/CAM Cerec</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"126\">Vollkeramische Restaurationen an einem einzigen Termin — CEREC ermöglicht Keramikinlays und -kronen in einer Sitzung ohne Provisorium.</p>\n        </div>\n        <div class=\"p-8 rounded-2xl\" style=\"border: 1px solid #F2E8EF;\" data-kid=\"127\">\n          <div class=\"w-14 h-14 rounded-xl flex items-center justify-center mb-6\" style=\"background-color: #F2E8EF;\" data-kid=\"128\">\n            <i class=\"ti ti-device-ipad-horizontal\" style=\"color: #6B3558; font-size: 1.5rem;\" data-kid=\"129\"></i>\n          </div>\n          <h3 class=\"font-semibold text-lg mb-3\" style=\"font-family: 'Lora', serif; color: #36454F;\" data-kid=\"130\">Digitale Abformung</h3>\n          <p class=\"text-sm leading-relaxed\" style=\"color: rgba(54,69,79,0.6);\" data-kid=\"131\">Keine unangenehmen Abdruckmassen mehr — präzise 3D-Scans Ihrer Zähne für optimale Passgenauigkeit und höchsten Komfort.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"py-20 px-8\" style=\"background-color: #2A1E28;\" data-kid=\"132\">\n    <div class=\"max-w-[1320px] mx-auto text-center\" data-kid=\"133\">\n      <h2 class=\"text-white mb-4\" style=\"font-family: 'Lora', serif; font-size: 2.3rem; font-weight: 600;\" data-kid=\"134\">Überzeugen Sie sich selbst</h2>\n      <p class=\"text-lg mb-8 max-w-lg mx-auto\" style=\"color: rgba(255,255,255,0.6);\" data-kid=\"135\">Vereinbaren Sie Ihren ersten Termin und erleben Sie unsere Praxis persönlich. Wir freuen uns auf Ihr Lächeln!</p>\n      <a href=\"#\" class=\"inline-flex items-center gap-2 text-white text-base font-semibold px-8 py-4 rounded-full no-underline\" style=\"background-color: #6B3558;\" data-kid=\"136\">\n        <i class=\"ti ti-calendar-event\" data-kid=\"137\"></i>\n        Ersten Termin vereinbaren\n      </a>\n    </div>\n  </div>\n\n  \n  <footer class=\"py-16 px-8\" style=\"background-color: #2A1E28; border-top: 1px solid rgba(255,255,255,0.08);\" data-kid=\"138\">\n    <div class=\"max-w-[1320px] mx-auto grid gap-12\" style=\"grid-template-columns: repeat(4, 1fr);\" data-kid=\"139\">\n      <div data-kid=\"140\">\n        <div class=\"flex items-center gap-2 mb-5\" data-kid=\"141\">\n          <div class=\"w-8 h-8 rounded-full flex items-center justify-center\" style=\"background-color: #6B3558;\" data-kid=\"142\">\n            <i class=\"ti ti-tooth text-white\" style=\"font-size: 0.85rem;\" data-kid=\"143\"></i>\n          </div>\n          <span class=\"font-semibold text-white\" style=\"font-family: 'Lora', serif; font-size: 0.9rem;\" data-kid=\"144\">Dr. Tomte</span>\n        </div>\n        <p class=\"text-sm leading-relaxed mb-5\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"145\">Zahnarztpraxis Dr. med. dent.<br data-kid=\"146\">Laurice Thierry Tomte<br data-kid=\"147\">Volpinistraße 19<br data-kid=\"148\">80638 München – Nymphenburg</p>\n        <div class=\"space-y-2\" data-kid=\"149\">\n          <div class=\"flex items-center gap-2 text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"150\"><i class=\"ti ti-phone\" style=\"color: #6B3558;\" data-kid=\"151\"></i><span data-kid=\"152\">089 / 178 33 50</span></div>\n          <div class=\"flex items-center gap-2 text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"153\"><i class=\"ti ti-printer\" style=\"color: #6B3558;\" data-kid=\"154\"></i><span data-kid=\"155\">089 / 178 37 62</span></div>\n          <div class=\"flex items-center gap-2 text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"156\"><i class=\"ti ti-mail\" style=\"color: #6B3558;\" data-kid=\"157\"></i><span data-kid=\"158\">praxis@zahnarztpraxis-tomte.de</span></div>\n        </div>\n      </div>\n      <div data-kid=\"159\">\n        <h4 class=\"text-sm font-semibold mb-4 uppercase tracking-wider\" style=\"color: rgba(255,255,255,0.85);\" data-kid=\"160\">Navigation</h4>\n        <ul class=\"space-y-2.5\" data-kid=\"161\">\n          <li data-kid=\"162\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"163\">Home</a></li>\n          <li data-kid=\"164\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"165\">Unsere Praxis</a></li>\n          <li data-kid=\"166\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"167\">Über uns</a></li>\n          <li data-kid=\"168\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"169\">Leistungen</a></li>\n          <li data-kid=\"170\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"171\">Anfahrt</a></li>\n          <li data-kid=\"172\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"173\">Kontakt</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"174\">\n        <h4 class=\"text-sm font-semibold mb-4 uppercase tracking-wider\" style=\"color: rgba(255,255,255,0.85);\" data-kid=\"175\">Sprechzeiten</h4>\n        <div class=\"space-y-2\" data-kid=\"176\">\n          <div class=\"flex justify-between text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"177\"><span data-kid=\"178\">Montag</span><span data-kid=\"179\">8:30–12:30 &amp; 14–18</span></div>\n          <div class=\"flex justify-between text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"180\"><span data-kid=\"181\">Dienstag</span><span data-kid=\"182\">8:30–12:30 &amp; 14–19</span></div>\n          <div class=\"flex justify-between text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"183\"><span data-kid=\"184\">Mittwoch</span><span data-kid=\"185\">8:30–13 Uhr</span></div>\n          <div class=\"flex justify-between text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"186\"><span data-kid=\"187\">Donnerstag</span><span data-kid=\"188\">8:30–12:30 &amp; 14–18</span></div>\n          <div class=\"flex justify-between text-sm\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"189\"><span data-kid=\"190\">Freitag</span><span data-kid=\"191\">8:30–13 Uhr</span></div>\n        </div>\n        <p class=\"text-xs mt-3\" style=\"color: rgba(255,255,255,0.3);\" data-kid=\"192\">...und nach telefonischer Vereinbarung</p>\n      </div>\n      <div data-kid=\"193\">\n        <h4 class=\"text-sm font-semibold mb-4 uppercase tracking-wider\" style=\"color: rgba(255,255,255,0.85);\" data-kid=\"194\">Rechtliches</h4>\n        <ul class=\"space-y-2.5 mb-6\" data-kid=\"195\">\n          <li data-kid=\"196\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"197\">Datenschutz</a></li>\n          <li data-kid=\"198\"><a href=\"#\" class=\"text-sm no-underline\" style=\"color: rgba(255,255,255,0.45);\" data-kid=\"199\">Impressum</a></li>\n        </ul>\n        <div class=\"pt-4\" style=\"border-top: 1px solid rgba(255,255,255,0.1);\" data-kid=\"200\">\n          <p class=\"text-xs mb-2\" style=\"color: rgba(255,255,255,0.35);\" data-kid=\"201\">Bewertungen auf:</p>\n          <div class=\"flex gap-2\" data-kid=\"202\">\n            <span class=\"text-xs px-2.5 py-1 rounded\" style=\"color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15);\" data-kid=\"203\">Jameda</span>\n            <span class=\"text-xs px-2.5 py-1 rounded\" style=\"color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.15);\" data-kid=\"204\">Sanego</span>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"max-w-[1320px] mx-auto mt-12 pt-6 text-center\" style=\"border-top: 1px solid rgba(255,255,255,0.08);\" data-kid=\"205\">\n      <p class=\"text-sm\" style=\"color: rgba(255,255,255,0.25);\" data-kid=\"206\">© Zahnarztpraxis Dr. Tomte 2012–2025 · Volpinistraße 19, 80638 München · Alle Rechte vorbehalten</p>\n    </div>\n  </footer>\n\n  \n  <div class=\"flex flex-col gap-2\" style=\"position: absolute; right: 24px; top: 820px; z-index: 50;\" data-kid=\"207\">\n    <a href=\"#\" class=\"w-11 h-11 rounded-full flex items-center justify-center no-underline\" style=\"background-color: #6B3558; box-shadow: 0 4px 14px rgba(107,53,88,0.45);\" data-kid=\"208\">\n      <i class=\"ti ti-phone text-white\" style=\"font-size: 1.1rem;\" data-kid=\"209\"></i>\n    </a>\n    <a href=\"#\" class=\"w-11 h-11 rounded-full flex items-center justify-center no-underline\" style=\"background-color: #6B3558; box-shadow: 0 4px 14px rgba(107,53,88,0.45);\" data-kid=\"210\">\n      <i class=\"ti ti-mail text-white\" style=\"font-size: 1.1rem;\" data-kid=\"211\"></i>\n    </a>\n  </div>\n\n</div>",
