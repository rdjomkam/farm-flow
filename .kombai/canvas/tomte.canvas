);gap:28px;\" data-kid=\"43\">\n      <div style=\"border:2px solid #6B3558;border-radius:22px;padding:38px;background:#fdfcfa;\" data-kid=\"44\">\n        <div style=\"width:52px;height:52px;background:#F2E8EF;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:22px;\" data-kid=\"45\">\n          <i class=\"ti ti-map-pin\" style=\"font-size:26px;color:#6B3558;\" data-kid=\"46\"></i>\n        </div>\n        <h3 style=\"font-family:'Lora',serif;font-size:20px;font-weight:600;color:#36454F;margin:0 0 18px;\" data-kid=\"47\">Adresse &amp; Kontakt</h3>\n        <div style=\"font-size:14px;color:#604a58;line-height:2;display:flex;flex-direction:column;gap:4px;\" data-kid=\"48\">\n          <div style=\"display:flex;align-items:flex-start;gap:8px;\" data-kid=\"49\"><i class=\"ti ti-building\" style=\"font-size:15px;color:#6B3558;margin-top:2px;\" data-kid=\"50\"></i><span data-kid=\"51\">Volpinistraße 19<br data-kid=\"52\">80638 München – Nymphenburg</span></div>\n          <div style=\"display:flex;align-items:center;gap:8px;margin-top:6px;\" data-kid=\"53\"><i class=\"ti ti-phone\" style=\"font-size:15px;color:#6B3558;\" data-kid=\"54\"></i><a href=\"tel:+4989178330\" style=\"color:#36454F;text-decoration:none;\" data-kid=\"55\">089 / 178 33 50</a></div>\n          <div style=\"display:flex;align-items:center;gap:8px;\" data-kid=\"56\"><i class=\"ti ti-device-floppy\" style=\"font-size:15px;color:#6B3558;\" data-kid=\"57\"></i><span data-kid=\"58\">Fax: 089 / 178 37 62</span></div>\n          <div style=\"display:flex;align-items:center;gap:8px;\" data-kid=\"59\"><i class=\"ti ti-mail\" style=\"font-size:15px;color:#6B3558;\" data-kid=\"60\"></i><a href=\"mailto:praxis@zahnarztpraxis-tomte.de\" style=\"color:#36454F;text-decoration:none;font-size:13px;\" data-kid=\"61\">praxis@zahnarztpraxis-tomte.de</a></div>\n        </div>\n        <div style=\"border-top:1px solid #ead4e4;margin-top:20px;padding-top:18px;\" data-kid=\"62\">\n    