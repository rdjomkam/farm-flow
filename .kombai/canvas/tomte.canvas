data-kid=\"281\">\n          <a href=\"tel:08917833350\" style=\"font-size: 14px; color: rgba(255,255,255,0.65); text-decoration: none; display: flex; align-items: center; gap: 8px;\" data-kid=\"282\">\n            <i class=\"ti ti-phone\" style=\"color: #6B3558; font-size: 15px;\" data-kid=\"283\"></i> 089 / 178 33 50\n          </a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.65); text-decoration: none; display: flex; align-items: center; gap: 8px;\" data-kid=\"284\">\n            <i class=\"ti ti-device-fax\" style=\"color: #6B3558; font-size: 15px;\" data-kid=\"285\"></i> 089 / 178 37 62\n          </a>\n          <a href=\"mailto:praxis@zahnarztpraxis-tomte.de\" style=\"font-size: 14px; color: rgba(255,255,255,0.65); text-decoration: none; display: flex; align-items: center; gap: 8px;\" data-kid=\"286\">\n            <i class=\"ti ti-mail\" style=\"color: #6B3558; font-size: 15px;\" data-kid=\"287\"></i> praxis@zahnarztpraxis-tomte.de\n          </a>\n        </div>\n      </div>\n      <div data-kid=\"288\">\n        <h4 style=\"font-family: 'Lora', serif; font-size: 16px; font-weight: 600; color: #FFFFFF; margin: 0 0 20px 0;\" data-kid=\"289\">Leistungen</h4>\n        <div style=\"display: flex; flex-direction: column; gap: 10px;\" data-kid=\"290\">\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"291\">Kinderzahnheilkunde</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"292\">Individualprophylaxe</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"293\">Zahnerhaltung</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"294\">Prothetik &amp; Implantate</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"295\">Parodontologie</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"296\">Bleaching &amp; Ästhetik</a>\n        </div>\n      </div>\n      <div data-kid=\"297\">\n        <h4 style=\"font-family: 'Lora', serif; font-size: 16px; font-weight: 600; color: #FFFFFF; margin: 0 0 20px 0;\" data-kid=\"298\">Sprechzeiten</h4>\n        <div style=\"display: flex; flex-direction: column; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.7;\" data-kid=\"299\">\n          <div data-kid=\"300\">Mo 8:30–12:30 &amp; 14–18 Uhr</div>\n          <div data-kid=\"301\">Di 8:30–12:30 &amp; 14–19 Uhr</div>\n          <div data-kid=\"302\">Mi 8:30–13:00 Uhr</div>\n          <div data-kid=\"303\">Do 8:30–12:30 &amp; 14–18 Uhr</div>\n          <div data-kid=\"304\">Fr 8:30–13:00 Uhr</div>\n          <div style=\"color: rgba(255,255,255,0.45); font-style: italic; margin-top: 4px;\" data-kid=\"305\">... und nach telefonischer Vereinbarung</div>\n        </div>\n      </div>\n      <div data-kid=\"306\">\n        <h4 style=\"font-family: 'Lora', serif; font-size: 16px; font-weight: 600; color: #FFFFFF; margin: 0 0 20px 0;\" data-kid=\"307\">Navigation</h4>\n        <div style=\"display: flex; flex-direction: column; gap: 10px;\" data-kid=\"308\">\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"309\">Startseite</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"310\">Praxis</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"311\">Über uns</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"312\">Leistungen</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"313\">Anfahrt</a>\n          <a href=\"#\" style=\"font-size: 14px; color: rgba(255,255,255,0.6); text-decoration: none;\" data-kid=\"314\">Kontakt</a>\n          <div style=\"height: 1px; background: rgba(255,255,255,0.1); margin: 4px 0;\" data-kid=\"315\"></div>\n          <a href=\"#\" style=\"font-size: 13px; color: rgba(255,255,255,0.45); text-decoration: none;\" data-kid=\"316\">Datenschutz</a>\n          <a href=\"#\" style=\"font-size: 13px; color: rgba(255,255,255,0.45); text-decoration: none;\" data-kid=\"317\">Impressum</a>\n        </div>\n      </div>\n    </div>\n    <div style=\"border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: rgba(255,255,255,0.4);\" data-kid=\"318\">\n      <span data-kid=\"319\">© Dr. Tomte 2012–2025 · Zahnarztpraxis Dr. Tomte, München</span>\n      <span data-kid=\"320\">www.zahnarztpraxis-tomte.de</span>\n    </div>\n  </footer>\n\n  \n  <div style=\"position: absolute; right: 24px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 10px; z-index: 200;\" data-kid=\"321\">\n    <a href=\"tel:08917833350\" style=\"width: 48px; height: 48px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(107,53,88,0.4); text-decoration: none;\" data-kid=\"322\">\n      <i class=\"ti ti-phone\" style=\"color: white; font-size: 20px;\" data-kid=\"323\"></i>\n    </a>\n    <a href=\"mailto:praxis@zahnarztpraxis-tomte.de\" style=\"width: 48px; height: 48px; background: #6B3558; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(107,53,88,0.4); text-decoration: none;\" data-kid=\"324\">\n      <i class=\"ti ti-mail\" style=\"color: white; font-size: 20px;\" data-kid=\"325\"></i>\n    </a>\n  </div>\n\n</div>",
