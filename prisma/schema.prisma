// ──────────────────────────────────────────
// Modèles — Multi-tenancy
// ──────────────────────────────────────────

model Site {
  id             String           @id @default(cuid())
  name           String
  address        String?
  isActive       Boolean          @default(true)
  supervised     Boolean          @default(false)
  enabledModules SiteModule[]     @default([])
  members      SiteMember[]
  roles        SiteRole[]
  bacs         Bac[]
  vagues       Vague[]
  releves      Releve[]
  sessions     Session[]
  fournisseurs Fournisseur[]
  produits     Produit[]
  mouvements           MouvementStock[]
  commandes            Commande[]
  releveConsommations  ReleveConsommation[]
  clients              Client[]
  ventes               Vente[]
  factures             Facture[]
  paiements            Paiement[]
  reproducteurs        Reproducteur[]
  pontes               Ponte[]
  lotsAlevins          LotAlevins[]
  configAlertes        ConfigAlerte[]
  notifications        Notification[]
  activites            Activite[]
  depenses             Depense[]
  paiementsDepense     PaiementDepense[]
  depensesRecurrentes  DepenseRecurrente[]
  listesBesoins        ListeBesoins[]
  configsElevage       ConfigElevage[]
  // Sprint 20 — Packs & Provisioning
  packs                Pack[]
  packActivationsVendeur   PackActivation[]  @relation("PackActivationsVendeur")
  packActivationsClient    PackActivation[]  @relation("PackActivationsClient")
  // Sprint 21 — Moteur d'activités
  reglesActivite       RegleActivite[]
  // Sprint 23 — Monitoring Ingénieur
  notesRecues          NoteIngenieur[]  @relation("NotesRecues")
  notes                NoteIngenieur[]  @relation("NotesDKFarm")
  // Sprint 24 — Calibrage
  calibrages           Calibrage[]
  // Sprint 26 — Modification tracking (ADR-014/ADR-015)
  releveModifications  ReleveModification[]
  calibrageModifications CalibrageModification[]
  // Sprint FD — Feed Analytics
  historiqueNutritionnel HistoriqueNutritionnel[]
  // Sprint Gompertz
  gompertzVagues         GompertzVague[]
  // Sprint 30 — Abonnements
  abonnements          Abonnement[]              @relation("AbonnementsSite")
  paiementsAbo         PaiementAbonnement[]      @relation("PaiementsAboSite")
  remises              Remise[]                  @relation("RemisesSite")
  commissions          CommissionIngenieur[]     @relation("CommissionsDKFarm")
  commissionsClient    CommissionIngenieur[]     @relation("CommissionsSiteClient")
  portefeuilles        PortefeuilleIngenieur[]   @relation("PortefeuillesSite")
  retraits             RetraitPortefeuille[]     @relation("RetraitsSite")
  // Sprint 30.4 — Idempotency
  idempotencyRecords   IdempotencyRecord[]
  // ADR-021 — Cycle de vie & audit
  /** Null si non suspendu. Non-null = site suspendu (accès restreint). */
  suspendedAt          DateTime?
  /** Raison de la suspension — obligatoire lors de la suspension. */
  suspendedReason      String?
  /** Soft delete — null = actif, non-null = archivé (lecture seule). */
  deletedAt            DateTime?
  auditLogs            SiteAuditLog[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([deletedAt])
  @@index([suspendedAt])
}

// ──────────────────────────────────────────
// Modèles — ConfigElevage (Sprint 19)
// ──────────────────────────────────────────

/**
 * ConfigElevage — Parametres configurables par site pour piloter le moteur d'elevage.
 *
 * Chaque site peut avoir plusieurs profils. Un seul peut etre isDefault=true par site.
 * Les valeurs par defaut correspondent aux benchmarks FAO pour Clarias gariepinus.
 */
model ConfigElevage {
  id          String  @id @default(cuid())
  /** Nom du profil — ex: "Clarias Standard Cameroun" */
  nom         String
  description String?

  // ── Objectif de production ──────────────────────
  /** Poids cible par poisson a la recolte (g) — ex: 800 */
  poidsObjectif        Float
  /** Duree estimee du cycle en jours — ex: 180 */
  dureeEstimeeCycle    Int
  /** Taux de survie cible en % — ex: 85 */
  tauxSurvieObjectif   Float

  // ── Phases de croissance (seuils de poids en g) ─
  /** 0 → seuilAcclimatation g */
  seuilAcclimatation   Float @default(15)
  /** seuilAcclimatation → seuilCroissanceDebut g */
  seuilCroissanceDebut Float @default(50)
  /** seuilCroissanceDebut → seuilJuvenile g */
  seuilJuvenile        Float @default(150)
  /** seuilJuvenile → seuilGrossissement g */
  seuilGrossissement   Float @default(350)
  /** seuilGrossissement → seuilFinition g */
  seuilFinition        Float @default(700)
  // Au-dela de seuilFinition → PRE_RECOLTE

  // ── Alimentation : taille de granule par poids ──
  /** JSON: [{poidsMin, poidsMax, tailleGranule, description, proteines}] */
  alimentTailleConfig Json
  /** JSON: [{phase, tauxMin, tauxMax, frequence, notes}] */
  alimentTauxConfig   Json
  /** JSON: [{phase, scoreMin, scoreMax, label, couleur}] — Feed Analytics (Sprint FA) */
  scoreAlimentConfig  Json?

  // ── Benchmarks : FCR (lower is better) ──────────
  fcrExcellentMax    Float @default(1.5)
  fcrBonMax          Float @default(1.8)
  fcrAcceptableMax   Float @default(2.2)

  // ── Benchmarks : SGR (%/jour, higher is better) ─
  sgrExcellentMin    Float @default(2.0)
  sgrBonMin          Float @default(1.5)
  sgrAcceptableMin   Float @default(1.0)

  // ── Benchmarks : Taux de survie (%) ─────────────
  survieExcellentMin    Float @default(90)
  survieBonMin          Float @default(85)
  survieAcceptableMin   Float @default(80)

  // ── Benchmarks : Densite (kg/m3, lower is better)
  densiteExcellentMax   Float @default(7)
  densiteBonMax         Float @default(10)
  densiteAcceptableMax  Float @default(15)

  // ── Benchmarks : Mortalite cumulative (%) ───────
  mortaliteExcellentMax   Float @default(3)
  mortaliteBonMax         Float @default(5)
  mortaliteAcceptableMax  Float @default(10)

  // ── Qualite eau : seuils d'alerte ───────────────
  phMin                Float @default(6.5)
  phMax                Float @default(8.5)
  phOptimalMin         Float @default(6.5)
  phOptimalMax         Float @default(7.5)

  temperatureMin       Float @default(22)
  temperatureMax       Float @default(36)
  temperatureOptimalMin Float @default(26)
  temperatureOptimalMax Float @default(32)

  oxygeneMin     Float @default(1.5)
  oxygeneAlerte  Float @default(4.0)
  oxygeneOptimal Float @default(5.0)

  ammoniacMax     Float @default(0.5)
  ammoniacAlerte  Float @default(0.05)
  ammoniacOptimal Float @default(0.02)

  nitriteMax    Float @default(1.0)
  nitriteAlerte Float @default(0.5)

  // ── Mortalite : seuils d'alerte quotidiens ──────
  /** % morts/jour → investigation */
  mortaliteQuotidienneAlerte   Float @default(1.0)
  /** % morts/jour → urgence */
  mortaliteQuotidienneCritique Float @default(3.0)

  // ── Alimentation : seuils d'alerte ──────────────
  /** FCR au-dela de ce seuil → reduire dose */
  fcrAlerteMax       Float @default(2.0)
  /** Jours restants de stock → alerte */
  stockJoursAlerte   Int   @default(5)

  // ── Tri / Grading ───────────────────────────────
  triPoidsMin          Float @default(5)
  triPoidsMax          Float @default(150)
  triIntervalleJours   Int   @default(14)

  // ── Biometrie ───────────────────────────────────
  biometrieIntervalleDebut  Int   @default(7)
  biometrieIntervalleFin    Int   @default(14)
  biometrieEchantillonPct   Float @default(10)

  // ── Changement d'eau ────────────────────────────
  eauChangementPct               Float @default(30)
  eauChangementIntervalleJours   Int   @default(3)

  // ── Densite d'elevage ───────────────────────────
  densiteMaxPoissonsM3       Float @default(100)
  densiteOptimalePoissonsM3  Float @default(50)

  // ── Seuils de densité par type de système (kg/m3) — utilisés par le UI badge ─
  /** Bac béton / plastique — seuil alerte orange */
  densiteBacBetonAlerte      Float @default(150)
  /** Bac béton / plastique — seuil alerte rouge */
  densiteBacBetonCritique    Float @default(200)
  /** Étang en terre — seuil alerte orange */
  densiteEtangAlerte         Float @default(30)
  /** Étang en terre — seuil alerte rouge */
  densiteEtangCritique       Float @default(40)
  /** RAS — seuil alerte orange */
  densiteRasAlerte           Float @default(350)
  /** RAS — seuil alerte rouge */
  densiteRasCritique         Float @default(500)

  // ── Renouvellement ───────────────────────────────
  /** Fenêtre temporelle pour le calcul du taux de renouvellement effectif (jours) */
  fenetreRenouvellementJours Int @default(7)

  // ── Recolte ─────────────────────────────────────
  recoltePartiellePoidsSeuil Float @default(400)
  recolteJeuneAvantJours     Int   @default(2)

  // ── Calibrage Gompertz : parametres initiaux par defaut ─────────────────
  /** Valeur initiale de W∞ (poids asymptotique en g) pour le calibrage Gompertz — ex: 1200 */
  gompertzWInfDefault Float?
  /** Valeur initiale de K (constante de croissance) pour le calibrage Gompertz — ex: 0.018 */
  gompertzKDefault    Float?
  /** Valeur initiale de tᵢ (point d'inflexion en jours) pour le calibrage Gompertz — ex: 95 */
  gompertzTiDefault   Float?
  /** Nombre minimum de biometries (dates uniques) pour declencher le calcul Gompertz */
  gompertzMinPoints   Int     @default(5)

  // ── Metadonnees ─────────────────────────────────
  /** Profil par defaut du site (un seul isDefault=true par site) */
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  /** ID du site (ferme) — R8 */
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  /** Vagues utilisant ce profil */
  vagues Vague[]
  /** Packs utilisant ce profil */
  packs  Pack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, isDefault])
  @@index([siteId, isActive])
}

model SiteRole {
  id          String       @id @default(cuid())
  name        String
  description String?
  permissions Permission[]
  isSystem    Boolean      @default(false)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  members     SiteMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([siteId, name])
  @@index([siteId])
}

model SiteMember {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteRoleId  String
  siteRole    SiteRole     @relation(fields: [siteRoleId], references: [id], onDelete: Restrict)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
  @@index([siteRoleId])
}

// ──────────────────────────────────────────
// Modèles — Authentification
// ──────────────────────────────────────────

model User {
  id                  String           @id @default(cuid())
  email               String?          @unique
  phone               String?          @unique
  name                String
  passwordHash        String
  role                Role             @default(PISCICULTEUR)
  isActive            Boolean          @default(true)
  sessions            Session[]
  memberships         SiteMember[]
  mouvements          MouvementStock[]
  commandes           Commande[]
  ventes              Vente[]          @relation("VenteUser")
  factures            Facture[]        @relation("FactureUser")
  paiements           Paiement[]       @relation("PaiementUser")
  configAlertes       ConfigAlerte[]
  notifications       Notification[]
  activitesCreees     Activite[]       @relation("ActivitesCreees")
  activitesAssignees  Activite[]       @relation("ActivitesAssignees")
  depenses              Depense[]
  paiementsDepense      PaiementDepense[]
  depensesRecurrentes   DepenseRecurrente[]
  listesBesoinsCreees   ListeBesoins[]     @relation("ListeBesoinsCreees")
  listesBesoinsValidees ListeBesoins[]     @relation("ListeBesoinsValidees")
  // Sprint 20 — Packs & Provisioning
  packsCreated          Pack[]
  packActivationsCreees PackActivation[]
  // Sprint 21 — Moteur d'activités
  reglesActivite        RegleActivite[]
  // Sprint 23 — Monitoring Ingénieur
  notesEnvoyees         NoteIngenieur[]    @relation("NotesEnvoyees")
  // Sprint 24 — Calibrage
  calibrages            Calibrage[]        @relation("CalibrageUser")
  // Sprint 26 — Modification tracking (ADR-014/ADR-015)
  releveModifications   ReleveModification[]
  calibrageModifications CalibrageModification[]
  isSystem              Boolean            @default(false)
  // ADR-022 — Backoffice separation
  isSuperAdmin          Boolean            @default(false)
  // Sprint — Impersonation
  originalSessions      Session[]          @relation("OriginalUser")
  // Sprint 30 — Abonnements
  abonnementsUser         Abonnement[]              @relation("AbonnementsUser")
  paiementsAboInities     PaiementAbonnement[]      @relation("PaiementsAboUser")
  commissionsIngenieur    CommissionIngenieur[]     @relation("CommissionsIngenieur")
  remisesCreees           Remise[]                  @relation("RemisesUser")
  remisesApplications     RemiseApplication[]       @relation("RemisesApplicationsUser")
  portefeuille            PortefeuilleIngenieur?    @relation("PortefeuilleIngenieur")
  retraitsDemandes        RetraitPortefeuille[]     @relation("RetraitDemandeur")
  retraitsTraites         RetraitPortefeuille[]     @relation("RetraitTraiteur")
  // ADR-021 — Audit log des actions admin
  auditLogsActed          SiteAuditLog[]            @relation("AuditLogActor")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Session {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeSiteId   String?
  activeSite     Site?    @relation(fields: [activeSiteId], references: [id])
  expires        DateTime
  createdAt      DateTime @default(now())
  locale         String   @default("fr")
  // Impersonation — non null uniquement lors d'une session d'impersonation
  originalUserId String?
  originalUser   User?    @relation("OriginalUser", fields: [originalUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([activeSiteId])
  @@index([originalUserId])
}

// ──────────────────────────────────────────
// Modèles — Élevage
// ──────────────────────────────────────────

model Bac {
  id                  String          @id @default(cuid())
  nom                 String
  volume              Float?
  nombrePoissons      Int?
  nombreInitial       Int?
  poidsMoyenInitial   Float?
  vagueId             String?
  vague               Vague?          @relation(fields: [vagueId], references: [id])
  /** Type de système d'élevage — détermine les seuils de densité applicables.
   *  Null = BAC_BETON par défaut dans le moteur d'alertes. */
  typeSysteme         TypeSystemeBac?
  siteId              String
  site                Site            @relation(fields: [siteId], references: [id])
  releves             Releve[]
  lotsAlevins         LotAlevins[]
  activites           Activite[]
  calibrageGroupesDst CalibrageGroupe[] @relation("GroupeDestBac")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([vagueId])
  @@index([siteId])
}

model Vague {
  id                  String           @id @default(cuid())
  code                String           @unique
  dateDebut           DateTime
  dateFin             DateTime?
  nombreInitial       Int
  poidsMoyenInitial   Float
  origineAlevins      String?
  statut              StatutVague      @default(EN_COURS)
  siteId              String
  site                Site             @relation(fields: [siteId], references: [id])
  /** Config d'elevage associee (nullable — liee lors du provisioning Pack ou manuellement) */
  configElevageId     String?
  configElevage       ConfigElevage?   @relation(fields: [configElevageId], references: [id], onDelete: SetNull)
  /** PackActivation source (nullable — renseigné si vague créée via provisioning) */
  packActivationId    String?
  packActivation      PackActivation?  @relation(fields: [packActivationId], references: [id], onDelete: SetNull)
  bacs                    Bac[]
  releves                 Releve[]
  mouvements              MouvementStock[]
  ventes                  Vente[]
  lotsAlevinsTransferes   LotAlevins[]
  activites               Activite[]
  depenses                Depense[]
  listesBesoinVagues      ListeBesoinsVague[]
  // Sprint 23 — Monitoring Ingénieur
  notes                   NoteIngenieur[]
  // Sprint 24 — Calibrage
  calibrages              Calibrage[]
  // Sprint FD — Feed Analytics
  historiqueNutritionnel  HistoriqueNutritionnel[]
  // Sprint Gompertz
  gompertz                GompertzVague?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([siteId])
  @@index([configElevageId])
  @@index([packActivationId])
}

model Releve {
  id          String     @id @default(cuid())
  date        DateTime
  typeReleve  TypeReleve
  vagueId     String
  vague       Vague      @relation(fields: [vagueId], references: [id])
  bacId       String
  bac         Bac        @relation(fields: [bacId], references: [id])
  siteId      String
  site        Site       @relation(fields: [siteId], references: [id])
  notes       String?

  // Champs biométrie
  poidsMoyen        Float?
  tailleMoyenne     Float?
  echantillonCount  Int?

  // Champs mortalité
  nombreMorts       Int?
  causeMortalite    CauseMortalite?

  // Champs alimentation
  typeAliment       TypeAliment?
  quantiteAliment   Float?
  frequenceAliment  Int?
  // Feed Analytics (Sprint FA)
  tauxRefus         Float?                   // valeurs : 0, 10, 25, 50
  comportementAlim  ComportementAlimentaire?

  // Champs qualité eau
  temperature       Float?
  ph                Float?
  oxygene           Float?
  ammoniac          Float?

  // Champs comptage
  nombreCompte      Int?
  methodeComptage   MethodeComptage?

  // Champs observation
  description       String?

  // Champs renouvellement eau — remplis uniquement quand typeReleve = RENOUVELLEMENT
  // L'un ou l'autre est renseigné (ou les deux si le formulaire calcule automatiquement)
  pourcentageRenouvellement Float?  // % du volume du bac renouvelée (ex: 50 = 50%)
  volumeRenouvele           Float?  // Volume réel en litres (alternative à pourcentageRenouvellement)
  nombreRenouvellements     Int?    @default(1)  // Nombre de passages de renouvellement (ex: 25% × 4 = 100%)

  consommations   ReleveConsommation[]
  mouvements      MouvementStock[]

  // Relation inverse : un releve peut etre lie a au plus une activite (1:1 optionnelle)
  activite        Activite?

  // Lien vers le calibrage source (nullable — rempli si auto-cree lors d'un calibrage)
  calibrageId     String?
  calibrage       Calibrage? @relation("CalibrageReleves", fields: [calibrageId], references: [id], onDelete: SetNull)

  // Traçabilité modification (Sprint 26, ADR-014)
  modifie         Boolean              @default(false)
  modifications   ReleveModification[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vagueId, typeReleve])
  @@index([bacId])
  @@index([date])
  @@index([calibrageId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Stock & Approvisionnement
// ──────────────────────────────────────────

model Fournisseur {
  id        String     @id @default(cuid())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  isActive  Boolean    @default(true)
  siteId    String
  site      Site       @relation(fields: [siteId], references: [id])
  produits  Produit[]
  commandes Commande[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([siteId])
}

model Produit {
  id             String           @id @default(cuid())
  nom            String
  categorie      CategorieProduit
  unite          UniteStock
  uniteAchat     UniteStock?
  contenance     Float?
  prixUnitaire   Float
  stockActuel    Float            @default(0)
  seuilAlerte    Float            @default(0)
  fournisseurId  String?
  fournisseur    Fournisseur?     @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  isActive       Boolean          @default(true)
  // Feed Analytics (Sprint FA) — caractéristiques nutritionnelles aliment
  tailleGranule  TailleGranule?
  formeAliment   FormeAliment?
  tauxProteines  Float?
  tauxLipides    Float?
  tauxFibres     Float?
