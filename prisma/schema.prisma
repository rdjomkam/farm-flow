  @@index([siteId])
  @@index([fournisseurId])
  @@index([categorie])
}

model MouvementStock {
  id         String        @id @default(cuid())
  produitId  String
  produit    Produit       @relation(fields: [produitId], references: [id])
  type       TypeMouvement
