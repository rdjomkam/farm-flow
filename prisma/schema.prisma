  MORTALITE_ELEVEE
  QUALITE_EAU
  STOCK_BAS
  RAPPEL_ALIMENTATION
  RAPPEL_BIOMETRIE
  PERSONNALISEE
}

enum StatutAlerte {
  ACTIVE
  LUE
  TRAITEE
}

enum TypeActivite {
  ALIMENTATION
  BIOMETRIE
  QUALITE_EAU
  COMPTAGE
  NETTOYAGE
  TRAITEMENT
  RECOLTE
  TRI
  MEDICATION
  AUTRE
}

enum StatutActivite {
  PLANIFIEE
  TERMINEE
  ANNULEE
  EN_RETARD
}

enum Recurrence {
  QUOTIDIEN
  HEBDOMADAIRE
  BIMENSUEL
  MENSUEL
  PERSONNALISE
}

enum CategorieDepense {
  ALIMENT
  INTRANT
  EQUIPEMENT
  ELECTRICITE
  EAU
  LOYER
  SALAIRE
  TRANSPORT
  VETERINAIRE
  REPARATION
  INVESTISSEMENT
  AUTRE
}

enum StatutDepense {
  NON_PAYEE
  PAYEE_PARTIELLEMENT
  PAYEE
}

enum FrequenceRecurrence {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum StatutBesoins {
  SOUMISE
  APPROUVEE
  TRAITEE
  CLOTUREE
  REJETEE
}

// ──────────────────────────────────────────
// Enums — Phase 3 : Packs & Provisioning (Sprint 20)
// ──────────────────────────────────────────

enum StatutActivation {
  ACTIVE
  EXPIREE
  SUSPENDUE
}

// ──────────────────────────────────────────
// Enums — Phase 3 : ConfigElevage (Sprint 19)
// ──────────────────────────────────────────

enum PhaseElevage {
  ACCLIMATATION
  CROISSANCE_DEBUT
  JUVENILE
  GROSSISSEMENT
  FINITION
  PRE_RECOLTE
}

// ──────────────────────────────────────────
// Enums — Production Alevins
// ──────────────────────────────────────────

enum SexeReproducteur {
  MALE
  FEMELLE
}

enum StatutReproducteur {
  ACTIF
  REFORME
  MORT
}

enum StatutPonte {
  EN_COURS
  TERMINEE
  ECHOUEE
}

enum StatutLotAlevins {
  EN_INCUBATION
  EN_ELEVAGE
  TRANSFERE
  PERDU
}

// ──────────────────────────────────────────
// Modèles — Multi-tenancy
// ──────────────────────────────────────────

model Site {
  id           String           @id @default(cuid())
  name         String
  address      String?
  isActive     Boolean          @default(true)
  members      SiteMember[]
  roles        SiteRole[]
  bacs         Bac[]
  vagues       Vague[]
  releves      Releve[]
  sessions     Session[]
  fournisseurs Fournisseur[]
  produits     Produit[]
  mouvements           MouvementStock[]
  commandes            Commande[]
  releveConsommations  ReleveConsommation[]
  clients              Client[]
  ventes               Vente[]
  factures             Facture[]
  paiements            Paiement[]
  reproducteurs        Reproducteur[]
  pontes               Ponte[]
  lotsAlevins          LotAlevins[]
  configAlertes        ConfigAlerte[]
  notifications        Notification[]
  activites            Activite[]
  depenses             Depense[]
  paiementsDepense     PaiementDepense[]
  depensesRecurrentes  DepenseRecurrente[]
  listesBesoins        ListeBesoins[]
  configsElevage       ConfigElevage[]
  // Sprint 20 — Packs & Provisioning
  packs                Pack[]
  packActivationsVendeur   PackActivation[]  @relation("PackActivationsVendeur")
  packActivationsClient    PackActivation[]  @relation("PackActivationsClient")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

// ──────────────────────────────────────────
// Modèles — ConfigElevage (Sprint 19)
// ──────────────────────────────────────────

/**
 * ConfigElevage — Parametres configurables par site pour piloter le moteur d'elevage.
 *
 * Chaque site peut avoir plusieurs profils. Un seul peut etre isDefault=true par site.
 * Les valeurs par defaut correspondent aux benchmarks FAO pour Clarias gariepinus.
 */
model ConfigElevage {
  id          String  @id @default(cuid())
  /** Nom du profil — ex: "Clarias Standard Cameroun" */
  nom         String
  description String?

  // ── Objectif de production ──────────────────────
  /** Poids cible par poisson a la recolte (g) — ex: 800 */
  poidsObjectif        Float
  /** Duree estimee du cycle en jours — ex: 180 */
  dureeEstimeeCycle    Int
  /** Taux de survie cible en % — ex: 85 */
  tauxSurvieObjectif   Float

  // ── Phases de croissance (seuils de poids en g) ─
  /** 0 → seuilAcclimatation g */
  seuilAcclimatation   Float @default(15)
  /** seuilAcclimatation → seuilCroissanceDebut g */
  seuilCroissanceDebut Float @default(50)
  /** seuilCroissanceDebut → seuilJuvenile g */
  seuilJuvenile        Float @default(150)
  /** seuilJuvenile → seuilGrossissement g */
  seuilGrossissement   Float @default(350)
  /** seuilGrossissement → seuilFinition g */
  seuilFinition        Float @default(700)
  // Au-dela de seuilFinition → PRE_RECOLTE

  // ── Alimentation : taille de granule par poids ──
  /** JSON: [{poidsMin, poidsMax, tailleGranule, description, proteines}] */
  alimentTailleConfig Json
  /** JSON: [{phase, tauxMin, tauxMax, frequence, notes}] */
  alimentTauxConfig   Json

  // ── Benchmarks : FCR (lower is better) ──────────
  fcrExcellentMax    Float @default(1.5)
  fcrBonMax          Float @default(1.8)
  fcrAcceptableMax   Float @default(2.2)

  // ── Benchmarks : SGR (%/jour, higher is better) ─
  sgrExcellentMin    Float @default(2.0)
  sgrBonMin          Float @default(1.5)
  sgrAcceptableMin   Float @default(1.0)

  // ── Benchmarks : Taux de survie (%) ─────────────
  survieExcellentMin    Float @default(90)
  survieBonMin          Float @default(85)
  survieAcceptableMin   Float @default(80)

  // ── Benchmarks : Densite (kg/m3, lower is better)
  densiteExcellentMax   Float @default(7)
  densiteBonMax         Float @default(10)
  densiteAcceptableMax  Float @default(15)

  // ── Benchmarks : Mortalite cumulative (%) ───────
  mortaliteExcellentMax   Float @default(3)
  mortaliteBonMax         Float @default(5)
  mortaliteAcceptableMax  Float @default(10)

  // ── Qualite eau : seuils d'alerte ───────────────
  phMin                Float @default(6.5)
  phMax                Float @default(8.5)
  phOptimalMin         Float @default(6.5)
  phOptimalMax         Float @default(7.5)

  temperatureMin       Float @default(22)
  temperatureMax       Float @default(36)
  temperatureOptimalMin Float @default(26)
  temperatureOptimalMax Float @default(32)

  oxygeneMin     Float @default(1.5)
  oxygeneAlerte  Float @default(4.0)
  oxygeneOptimal Float @default(5.0)

  ammoniacMax     Float @default(0.5)
  ammoniacAlerte  Float @default(0.05)
  ammoniacOptimal Float @default(0.02)

  nitriteMax    Float @default(1.0)
  nitriteAlerte Float @default(0.5)

  // ── Mortalite : seuils d'alerte quotidiens ──────
  /** % morts/jour → investigation */
  mortaliteQuotidienneAlerte   Float @default(1.0)
  /** % morts/jour → urgence */
  mortaliteQuotidienneCritique Float @default(3.0)

  // ── Alimentation : seuils d'alerte ──────────────
  /** FCR au-dela de ce seuil → reduire dose */
  fcrAlerteMax       Float @default(2.0)
  /** Jours restants de stock → alerte */
  stockJoursAlerte   Int   @default(5)

  // ── Tri / Grading ───────────────────────────────
  triPoidsMin          Float @default(5)
  triPoidsMax          Float @default(150)
  triIntervalleJours   Int   @default(14)

  // ── Biometrie ───────────────────────────────────
  biometrieIntervalleDebut  Int   @default(7)
  biometrieIntervalleFin    Int   @default(14)
  biometrieEchantillonPct   Float @default(10)

  // ── Changement d'eau ────────────────────────────
  eauChangementPct               Float @default(30)
  eauChangementIntervalleJours   Int   @default(3)

  // ── Densite d'elevage ───────────────────────────
  densiteMaxPoissonsM3       Float @default(100)
  densiteOptimalePoissonsM3  Float @default(50)

  // ── Recolte ─────────────────────────────────────
  recoltePartiellePoidsSeuil Float @default(400)
  recolteJeuneAvantJours     Int   @default(2)

  // ── Metadonnees ─────────────────────────────────
  /** Profil par defaut du site (un seul isDefault=true par site) */
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  /** ID du site (ferme) — R8 */
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  /** Vagues utilisant ce profil */
  vagues Vague[]
  /** Packs utilisant ce profil */
  packs  Pack[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, isDefault])
  @@index([siteId, isActive])
}

model SiteRole {
  id          String       @id @default(cuid())
  name        String
  description String?
  permissions Permission[]
  isSystem    Boolean      @default(false)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  members     SiteMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([siteId, name])
  @@index([siteId])
}

model SiteMember {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId      String
  site        Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteRoleId  String
  siteRole    SiteRole     @relation(fields: [siteRoleId], references: [id], onDelete: Restrict)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
  @@index([siteRoleId])
}

// ──────────────────────────────────────────
// Modèles — Authentification
// ──────────────────────────────────────────

model User {
  id                  String           @id @default(cuid())
  email               String?          @unique
  phone               String?          @unique
  name                String
  passwordHash        String
  role                Role             @default(PISCICULTEUR)
  isActive            Boolean          @default(true)
  sessions            Session[]
  memberships         SiteMember[]
  mouvements          MouvementStock[]
  commandes           Commande[]
  ventes              Vente[]          @relation("VenteUser")
  factures            Facture[]        @relation("FactureUser")
  paiements           Paiement[]       @relation("PaiementUser")
  configAlertes       ConfigAlerte[]
  notifications       Notification[]
  activitesCreees     Activite[]       @relation("ActivitesCreees")
  activitesAssignees  Activite[]       @relation("ActivitesAssignees")
  depenses              Depense[]
  paiementsDepense      PaiementDepense[]
  depensesRecurrentes   DepenseRecurrente[]
  listesBesoinsCreees   ListeBesoins[]     @relation("ListeBesoinsCreees")
  listesBesoinsValidees ListeBesoins[]     @relation("ListeBesoinsValidees")
  // Sprint 20 — Packs & Provisioning
  packsCreated          Pack[]
  packActivationsCreees PackActivation[]
  isSystem              Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeSiteId String?
  activeSite   Site?    @relation(fields: [activeSiteId], references: [id])
  expires      DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([activeSiteId])
}

// ──────────────────────────────────────────
// Modèles — Élevage
// ──────────────────────────────────────────

model Bac {
  id              String   @id @default(cuid())
  nom             String
  volume          Float?
  nombrePoissons  Int?
  vagueId         String?
  vague           Vague?   @relation(fields: [vagueId], references: [id])
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id])
  releves         Releve[]
  lotsAlevins     LotAlevins[]
  activites       Activite[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vagueId])
  @@index([siteId])
}

model Vague {
  id                  String           @id @default(cuid())
  code                String           @unique
  dateDebut           DateTime
  dateFin             DateTime?
  nombreInitial       Int
  poidsMoyenInitial   Float
  origineAlevins      String?
  statut              StatutVague      @default(EN_COURS)
  siteId              String
  site                Site             @relation(fields: [siteId], references: [id])
  /** Config d'elevage associee (nullable — liee lors du provisioning Pack ou manuellement) */
  configElevageId     String?
  configElevage       ConfigElevage?   @relation(fields: [configElevageId], references: [id], onDelete: SetNull)
  /** PackActivation source (nullable — renseigné si vague créée via provisioning) */
  packActivationId    String?
  packActivation      PackActivation?  @relation(fields: [packActivationId], references: [id], onDelete: SetNull)
  bacs                    Bac[]
  releves                 Releve[]
  mouvements              MouvementStock[]
  ventes                  Vente[]
  lotsAlevinsTransferes   LotAlevins[]
  activites               Activite[]
  depenses                Depense[]
  listesBesoins           ListeBesoins[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([siteId])
  @@index([configElevageId])
  @@index([packActivationId])
}

model Releve {
  id          String     @id @default(cuid())
  date        DateTime
  typeReleve  TypeReleve
  vagueId     String
  vague       Vague      @relation(fields: [vagueId], references: [id])
  bacId       String
  bac         Bac        @relation(fields: [bacId], references: [id])
  siteId      String
  site        Site       @relation(fields: [siteId], references: [id])
  notes       String?

  // Champs biométrie
  poidsMoyen        Float?
  tailleMoyenne     Float?
  echantillonCount  Int?

  // Champs mortalité
  nombreMorts       Int?
  causeMortalite    CauseMortalite?

  // Champs alimentation
  typeAliment       TypeAliment?
  quantiteAliment   Float?
  frequenceAliment  Int?

  // Champs qualité eau
  temperature       Float?
  ph                Float?
  oxygene           Float?
  ammoniac          Float?

  // Champs comptage
  nombreCompte      Int?
  methodeComptage   MethodeComptage?

  // Champs observation
  description       String?

  consommations   ReleveConsommation[]
  mouvements      MouvementStock[]

  // Relation inverse : un releve peut etre lie a au plus une activite (1:1 optionnelle)
  activite        Activite?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vagueId, typeReleve])
  @@index([bacId])
  @@index([date])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Stock & Approvisionnement
// ──────────────────────────────────────────

model Fournisseur {
  id        String     @id @default(cuid())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  isActive  Boolean    @default(true)
  siteId    String
  site      Site       @relation(fields: [siteId], references: [id])
  produits  Produit[]
  commandes Commande[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([siteId])
}

model Produit {
  id             String           @id @default(cuid())
  nom            String
  categorie      CategorieProduit
  unite          UniteStock
  uniteAchat     UniteStock?
  contenance     Float?
  prixUnitaire   Float
  stockActuel    Float            @default(0)
  seuilAlerte    Float            @default(0)
  fournisseurId  String?
  fournisseur    Fournisseur?     @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)
  isActive       Boolean          @default(true)
  siteId         String
  site           Site             @relation(fields: [siteId], references: [id])
  mouvements     MouvementStock[]
  lignesCommande LigneCommande[]
  consommations  ReleveConsommation[]
  lignesBesoins  LigneBesoin[]
  // Sprint 20 — Packs & Provisioning
  packProduits   PackProduit[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([siteId])
  @@index([fournisseurId])
  @@index([categorie])
}

model MouvementStock {
  id         String        @id @default(cuid())
  produitId  String
  produit    Produit       @relation(fields: [produitId], references: [id])
  type       TypeMouvement
  quantite   Float
  prixTotal  Float?
  vagueId    String?
  vague      Vague?        @relation(fields: [vagueId], references: [id])
  commandeId String?
  commande   Commande?     @relation(fields: [commandeId], references: [id])
  releveId   String?
  releve     Releve?       @relation(fields: [releveId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  date       DateTime
  notes      String?
  siteId     String
  site       Site          @relation(fields: [siteId], references: [id])
  createdAt  DateTime      @default(now())

  @@index([siteId])
  @@index([produitId])
  @@index([date])
  @@index([vagueId])
  @@index([commandeId])
  @@index([releveId])
}

model Commande {
  id             String          @id @default(cuid())
  numero         String          @unique
  fournisseurId  String
  fournisseur    Fournisseur     @relation(fields: [fournisseurId], references: [id])
  statut         StatutCommande  @default(BROUILLON)
  dateCommande   DateTime
  dateLivraison  DateTime?
  montantTotal   Float           @default(0)
  /** URL de la facture fournisseur stockee sur Hetzner Object Storage (nullable) */
  factureUrl     String?
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  siteId         String
  site           Site            @relation(fields: [siteId], references: [id])
  lignes         LigneCommande[]
  mouvements     MouvementStock[]
  depenses       Depense[]
  lignesBesoins  LigneBesoin[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([siteId])
  @@index([fournisseurId])
  @@index([statut])
  @@index([dateCommande])
}

model LigneCommande {
  id           String   @id @default(cuid())
  commandeId   String
  commande     Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produitId    String
  produit      Produit  @relation(fields: [produitId], references: [id])
  quantite     Float
  prixUnitaire Float
  createdAt    DateTime @default(now())

  @@index([commandeId])
  @@index([produitId])
}

// ──────────────────────────────────────────
// Modèle — Consommation produits via relevés
// ──────────────────────────────────────────

model ReleveConsommation {
  id        String   @id @default(cuid())
  releveId  String
  releve    Releve   @relation(fields: [releveId], references: [id], onDelete: Cascade)
  produitId String
  produit   Produit  @relation(fields: [produitId], references: [id])
  quantite  Float
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  createdAt DateTime @default(now())

  @@index([releveId])
  @@index([produitId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Ventes & Facturation
// ──────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  isActive  Boolean  @default(true)
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  ventes    Vente[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
}

model Vente {
  id               String   @id @default(cuid())
  numero           String   @unique
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  vagueId          String
  vague            Vague    @relation(fields: [vagueId], references: [id])
  quantitePoissons Int
  poidsTotalKg     Float
  prixUnitaireKg   Float
  montantTotal     Float
  notes            String?
  siteId           String
  site             Site     @relation(fields: [siteId], references: [id])
  userId           String
  user             User     @relation("VenteUser", fields: [userId], references: [id])
  facture          Facture?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([siteId])
  @@index([clientId])
  @@index([vagueId])
}

model Facture {
  id           String        @id @default(cuid())
  numero       String        @unique
  venteId      String        @unique
  vente        Vente         @relation(fields: [venteId], references: [id])
  statut       StatutFacture @default(BROUILLON)
  dateEmission DateTime      @default(now())
  dateEcheance DateTime?
  montantTotal Float
  montantPaye  Float         @default(0)
  notes        String?
  siteId       String
  site         Site          @relation(fields: [siteId], references: [id])
  userId       String
  user         User          @relation("FactureUser", fields: [userId], references: [id])
  paiements    Paiement[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([siteId])
  @@index([statut])
}

model Paiement {
  id        String       @id @default(cuid())
  factureId String
  facture   Facture      @relation(fields: [factureId], references: [id], onDelete: Cascade)
  montant   Float
  mode      ModePaiement
  reference String?
  date      DateTime     @default(now())
  siteId    String
  site      Site         @relation(fields: [siteId], references: [id])
  userId    String
  user      User         @relation("PaiementUser", fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@index([factureId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Production Alevins
// ──────────────────────────────────────────

model Reproducteur {
  id              String             @id @default(cuid())
  code            String             @unique
  sexe            SexeReproducteur
  poids           Float
  age             Int?
  origine         String?
  statut          StatutReproducteur @default(ACTIF)
  dateAcquisition DateTime           @default(now())
  notes           String?
  siteId          String
  site            Site               @relation(fields: [siteId], references: [id])
  pontesAsFemelle Ponte[]            @relation("PonteFemelle")
  pontesAsMale    Ponte[]            @relation("PonteMale")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([siteId])
  @@index([siteId, statut])
}

model Ponte {
  id              String      @id @default(cuid())
  code            String      @unique
  femelleId       String
  femelle         Reproducteur @relation("PonteFemelle", fields: [femelleId], references: [id])
  maleId          String?
  male            Reproducteur? @relation("PonteMale", fields: [maleId], references: [id])
  datePonte       DateTime
  nombreOeufs     Int?
  tauxFecondation Float?
  statut          StatutPonte @default(EN_COURS)
  notes           String?
  siteId          String
  site            Site        @relation(fields: [siteId], references: [id])
  lots            LotAlevins[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([siteId])
  @@index([femelleId])
  @@index([siteId, statut])
}

model LotAlevins {
  id                  String           @id @default(cuid())
  code                String           @unique
  ponteId             String
  ponte               Ponte            @relation(fields: [ponteId], references: [id])
  nombreInitial       Int
  nombreActuel        Int
  ageJours            Int              @default(0)
  poidsMoyen          Float?
  statut              StatutLotAlevins @default(EN_INCUBATION)
  bacId               String?
  bac                 Bac?             @relation(fields: [bacId], references: [id])
  vagueDestinationId  String?
  vagueDestination    Vague?           @relation(fields: [vagueDestinationId], references: [id])
  dateTransfert       DateTime?
  notes               String?
  siteId              String
  site                Site             @relation(fields: [siteId], references: [id])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([siteId])
  @@index([ponteId])
  @@index([siteId, statut])
}

// ──────────────────────────────────────────
// Modèles — Alertes & Planning
// ──────────────────────────────────────────

model ConfigAlerte {
  id                String     @id @default(cuid())
  typeAlerte        TypeAlerte
  seuilValeur       Float?
  seuilPourcentage  Float?
  enabled           Boolean    @default(true)
  userId            String
  user              User       @relation(fields: [userId], references: [id])
  siteId            String
  site              Site       @relation(fields: [siteId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([userId, siteId, typeAlerte])
  @@index([siteId])
}

model Notification {
  id         String       @id @default(cuid())
  typeAlerte TypeAlerte
  titre      String
  message    String
  statut     StatutAlerte @default(ACTIVE)
  lien       String?
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  siteId     String
  site       Site         @relation(fields: [siteId], references: [id])
  createdAt  DateTime     @default(now())

  @@index([userId, siteId, statut])
  @@index([siteId])
}

model Activite {
  id           String         @id @default(cuid())
  titre        String
  description  String?
  typeActivite TypeActivite
  statut       StatutActivite @default(PLANIFIEE)
  dateDebut    DateTime
  dateFin      DateTime?
  recurrence   Recurrence?
  vagueId      String?
  vague        Vague?         @relation(fields: [vagueId], references: [id])
  bacId        String?
  bac          Bac?           @relation(fields: [bacId], references: [id])
  assigneAId   String?
  assigneA     User?          @relation("ActivitesAssignees", fields: [assigneAId], references: [id])
  userId       String
  user         User           @relation("ActivitesCreees", fields: [userId], references: [id])
  siteId       String
  site         Site           @relation(fields: [siteId], references: [id])
  releveId       String?        @unique
  releve         Releve?        @relation(fields: [releveId], references: [id])
  dateTerminee   DateTime?
  noteCompletion String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([siteId, dateDebut])
  @@index([siteId, statut])
  @@index([assigneAId])
  @@index([releveId])
}

// ──────────────────────────────────────────
// Modèles — Dépenses
// ──────────────────────────────────────────

model Depense {
  id               String           @id @default(cuid())
  /** Numéro auto-généré format DEP-YYYY-NNN */
  numero           String           @unique
  description      String
  categorieDepense CategorieDepense
  montantTotal     Float
  montantPaye      Float            @default(0)
  statut           StatutDepense    @default(NON_PAYEE)
  date             DateTime
  dateEcheance     DateTime?
  /** URL facture fournisseur sur Hetzner Object Storage */
  factureUrl       String?
  notes            String?
  /** Lien optionnel vers la commande d'origine */
  commandeId       String?
  commande         Commande?        @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  /** Lien optionnel vers la vague concernée */
  vagueId          String?
  vague            Vague?           @relation(fields: [vagueId], references: [id], onDelete: SetNull)
  /** Lien optionnel vers la liste de besoins d'origine */
  listeBesoinsId   String?
  listeBesoins     ListeBesoins?    @relation(fields: [listeBesoinsId], references: [id], onDelete: SetNull)
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  siteId           String
  site             Site             @relation(fields: [siteId], references: [id])
  paiements        PaiementDepense[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([siteId])
  @@index([siteId, categorieDepense])
  @@index([siteId, statut])
  @@index([commandeId])
  @@index([vagueId])
  @@index([listeBesoinsId])
  @@index([date])
}

model PaiementDepense {
  id        String       @id @default(cuid())
  depenseId String
  depense   Depense      @relation(fields: [depenseId], references: [id], onDelete: Cascade)
  montant   Float
  mode      ModePaiement
  reference String?
  date      DateTime     @default(now())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  siteId    String
  site      Site         @relation(fields: [siteId], references: [id])
  createdAt DateTime     @default(now())

  @@index([depenseId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Dépenses Récurrentes (Sprint 18)
// ──────────────────────────────────────────

model DepenseRecurrente {
  id                  String              @id @default(cuid())
  description         String
  categorieDepense    CategorieDepense
  montantEstime       Float
  frequence           FrequenceRecurrence
  /** Jour du mois de génération (1-28, contraint par CHECK côté SQL) */
  jourDuMois          Int                 @default(1)
  isActive            Boolean             @default(true)
  derniereGeneration  DateTime?
  userId              String
  user                User                @relation(fields: [userId], references: [id])
  siteId              String
  site                Site                @relation(fields: [siteId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([siteId])
  @@index([siteId, isActive])
  @@index([siteId, frequence])
}

// ──────────────────────────────────────────
// Modèles — Besoins (Sprint 17)
// ──────────────────────────────────────────

model ListeBesoins {
  id             String         @id @default(cuid())
  /** Numéro auto-généré format BES-YYYY-NNN */
  numero         String         @unique
  titre          String
  demandeurId    String
  demandeur      User           @relation("ListeBesoinsCreees", fields: [demandeurId], references: [id])
  valideurId     String?
  valideur       User?          @relation("ListeBesoinsValidees", fields: [valideurId], references: [id])
  vagueId        String?
  vague          Vague?         @relation(fields: [vagueId], references: [id], onDelete: SetNull)
  statut         StatutBesoins  @default(SOUMISE)
  /** Somme estimée des besoins (SUM quantite * prixEstime) */
  montantEstime  Float          @default(0)
  /** Montant réel après clôture (nullable) */
  montantReel    Float?
  /** Motif de rejet (nullable, rempli si REJETEE) */
  motifRejet     String?
  notes          String?
  siteId         String
  site           Site           @relation(fields: [siteId], references: [id])
  lignes         LigneBesoin[]
  depenses       Depense[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([siteId])
  @@index([siteId, statut])
  @@index([demandeurId])
  @@index([vagueId])
}

model LigneBesoin {
  id               String        @id @default(cuid())
  listeBesoinsId   String
  listeBesoins     ListeBesoins  @relation(fields: [listeBesoinsId], references: [id], onDelete: Cascade)
  /** Désignation libre de l'article */
  designation      String
  /** Produit en stock lié (nullable — libre si null) */
  produitId        String?
  produit          Produit?      @relation(fields: [produitId], references: [id], onDelete: SetNull)
  quantite         Float
  /** Unité libre (nullable si produit avec unité définie) */
  unite            String?
  /** Prix unitaire estimé */
  prixEstime       Float         @default(0)
  /** Prix unitaire réel après clôture (nullable) */
  prixReel         Float?
  /** Commande générée lors du traitement (nullable) */
  commandeId       String?
  commande         Commande?     @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())

  @@index([listeBesoinsId])
  @@index([produitId])
  @@index([commandeId])
}

// ──────────────────────────────────────────
// Modèles — Phase 3 : Packs & Provisioning (Sprint 20)
// ──────────────────────────────────────────

/**
 * Pack — Kit de démarrage vendu aux clients pisciculteurs.
 *
 * Un Pack regroupe une ConfigElevage + une liste de Produits (aliments, intrants)
 * et configure la vague initiale (nombre d'alevins, poids initial).
 * Basé sur la section 3.2 du REQ-STARTER-PACKS.md.
 */
model Pack {
  id                  String         @id @default(cuid())
  /** Nom commercial du pack — ex: "Starter 300" */
  nom                 String
  description         String?
  /** Nombre d'alevins fournis (> 0) */
  nombreAlevins       Int
  /** Poids moyen initial des alevins (g) */
  poidsMoyenInitial   Float          @default(5)
  /** Prix total du pack en FCFA (>= 0) */
  prixTotal           Float          @default(0)
  /** ConfigElevage recommandée pour ce pack */
  configElevageId     String?
  configElevage       ConfigElevage? @relation(fields: [configElevageId], references: [id], onDelete: SetNull)
  isActive            Boolean        @default(true)
  /** Créateur du pack (ADMIN DKFarm) */
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  /** Site DKFarm propriétaire du pack — R8 */
  siteId              String
  site                Site           @relation(fields: [siteId], references: [id])

  produits    PackProduit[]
  activations PackActivation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([configElevageId])
  @@index([userId])
}

/**
 * PackProduit — Ligne de produit incluse dans un Pack.
 *
 * Un même Produit ne peut figurer qu'une fois par Pack (contrainte unique).
 * onDelete: Restrict sur Produit pour éviter les suppressions orphelines (EC-1.6).
 */
model PackProduit {
  id        String  @id @default(cuid())
  packId    String
  pack      Pack    @relation(fields: [packId], references: [id], onDelete: Cascade)
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id], onDelete: Restrict)
  /** Quantité incluse dans le pack (> 0) */
  quantite  Float

  @@unique([packId, produitId])
  @@index([packId])
  @@index([produitId])
}

/**
 * PackActivation — Enregistrement d'une vente de pack à un client.
 *
 * Créée lors du provisioning transactionnel.
 * - siteId = site DKFarm vendeur (R8)
 * - clientSiteId = site créé pour le client
 * IMPORTANT : Pas de @unique sur clientSiteId (un client peut acheter plusieurs packs — F-05)
 * IMPORTANT : Pas de @unique sur vagueId (une vague peut être splitée après tri — F-06)
 */
model PackActivation {
  id            String           @id @default(cuid())
  /** Code d'activation généré ACT-YYYY-NNN */
  code          String           @unique
  packId        String
  pack          Pack             @relation(fields: [packId], references: [id], onDelete: Restrict)
  /** Utilisateur ayant activé le pack (ingénieur ou admin DKFarm) */
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  /** Site DKFarm vendeur — R8 */
  siteId        String
  site          Site             @relation("PackActivationsVendeur", fields: [siteId], references: [id])
  /** Site client créé lors du provisioning */
  clientSiteId  String
  clientSite    Site             @relation("PackActivationsClient", fields: [clientSiteId], references: [id])
  statut        StatutActivation @default(ACTIVE)
  dateActivation DateTime        @default(now())
  dateExpiration DateTime?
  notes         String?

  /** Vagues créées lors du provisioning pour cette activation */
  vagues        Vague[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([siteId])
  @@index([clientSiteId])
  @@index([packId])
  @@index([userId])
  @@index([code])
  @@index([statut])
}
