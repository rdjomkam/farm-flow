generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// Enums PostgreSQL natifs
// ──────────────────────────────────────────

enum StatutVague {
  EN_COURS
  TERMINEE
  ANNULEE
}

enum TypeReleve {
  BIOMETRIE
  MORTALITE
  ALIMENTATION
  QUALITE_EAU
  COMPTAGE
  OBSERVATION
}

enum TypeAliment {
  ARTISANAL
  COMMERCIAL
  MIXTE
}

enum CauseMortalite {
  MALADIE
  QUALITE_EAU
  STRESS
  PREDATION
  CANNIBALISME
  INCONNUE
  AUTRE
}

enum MethodeComptage {
  DIRECT
  ESTIMATION
  ECHANTILLONNAGE
}

enum Role {
  ADMIN
  GERANT
  PISCICULTEUR
  INGENIEUR
}

enum CategorieProduit {
  ALIMENT
  INTRANT
  EQUIPEMENT
}

enum UniteStock {
  GRAMME
  KG
  MILLILITRE
  LITRE
  UNITE
  SACS
}

enum TypeMouvement {
  ENTREE
  SORTIE
}

enum StatutCommande {
  BROUILLON
  ENVOYEE
  LIVREE
  ANNULEE
}

enum StatutFacture {
  BROUILLON
  ENVOYEE
  PAYEE_PARTIELLEMENT
  PAYEE
  ANNULEE
}

enum ModePaiement {
  ESPECES
  MOBILE_MONEY
  VIREMENT
  CHEQUE
}

enum Permission {
  // Administration (2)
  SITE_GERER
  MEMBRES_GERER
  // Élevage (8)
  VAGUES_VOIR
  VAGUES_CREER
  VAGUES_MODIFIER
  BACS_GERER
  BACS_MODIFIER
  RELEVES_VOIR
  RELEVES_CREER
  RELEVES_MODIFIER
  // Stock (4)
  STOCK_VOIR
  STOCK_GERER
  APPROVISIONNEMENT_VOIR
  APPROVISIONNEMENT_GERER
  // Clients (2)
  CLIENTS_VOIR
  CLIENTS_GERER
  // Ventes (4)
  VENTES_VOIR
  VENTES_CREER
  FACTURES_VOIR
  FACTURES_GERER
  // Paiements (1)
  PAIEMENTS_CREER
  // Alevins (6)
  ALEVINS_VOIR
  ALEVINS_GERER
  ALEVINS_CREER
  ALEVINS_MODIFIER
  ALEVINS_SUPPRIMER
  // Planning (2)
  PLANNING_VOIR
  PLANNING_GERER
  // Finances (2)
  FINANCES_VOIR
  FINANCES_GERER
  // Général (3)
  DASHBOARD_VOIR
  ALERTES_VOIR
  EXPORT_DONNEES
  // Alertes (1)
  ALERTES_CONFIGURER
  // Dépenses (3)
  DEPENSES_VOIR
  DEPENSES_CREER
  DEPENSES_PAYER
  // Besoins (3)
  BESOINS_SOUMETTRE
  BESOINS_APPROUVER
  BESOINS_TRAITER
  // Phase 3 — Packs & Ingénieur (6)
  GERER_PACKS
  ACTIVER_PACKS
  GERER_CONFIG_ELEVAGE
  GERER_REGLES_ACTIVITES
  MONITORING_CLIENTS
  ENVOYER_NOTES
}

// ──────────────────────────────────────────
// Enums — Alertes & Planning
// ──────────────────────────────────────────

