// ──────────────────────────────────────────
// Modèles — Alertes & Planning
// ──────────────────────────────────────────

model ConfigAlerte {
  id                String     @id @default(cuid())
  typeAlerte        TypeAlerte
  seuilValeur       Float?
  seuilPourcentage  Float?
  enabled           Boolean    @default(true)
  userId            String
  user              User       @relation(fields: [userId], references: [id])
  siteId            String
  site              Site       @relation(fields: [siteId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([userId, siteId, typeAlerte])
  @@index([siteId])
}

model Notification {
  id         String         @id @default(cuid())
  typeAlerte TypeAlerte
  titre      String
  message    String
  statut     StatutAlerte   @default(ACTIVE)
  lien       String?
  /** Severite de l'alerte pour le tri visuel */
  severite   SeveriteAlerte @default(INFO)
  /** Action directe recommandee (null si notification informative seulement)
   *  Format : JSON { type: "CREER_RELEVE", typeReleve?, bacId?, vagueId? }
   *         ou { type: "MODIFIER_BAC", bacId, champsAModifier? }
   *         ou { type: "VOIR_VAGUE", vagueId }
   *         ou { type: "VOIR_STOCK", produitId? } */
  actionPayload Json?
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  siteId     String
  site       Site           @relation(fields: [siteId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([userId, siteId, statut])
  @@index([siteId])
  @@index([siteId, severite, statut])
}

model Activite {
  id           String         @id @default(cuid())
  titre        String
  description  String?
  typeActivite TypeActivite
  statut       StatutActivite @default(PLANIFIEE)
  dateDebut    DateTime
  dateFin      DateTime?
  recurrence   Recurrence?
  vagueId      String?
  vague        Vague?         @relation(fields: [vagueId], references: [id])
  bacId        String?
  bac          Bac?           @relation(fields: [bacId], references: [id])
  assigneAId   String?
  assigneA     User?          @relation("ActivitesAssignees", fields: [assigneAId], references: [id])
  userId       String
  user         User           @relation("ActivitesCreees", fields: [userId], references: [id])
  siteId       String
  site         Site           @relation(fields: [siteId], references: [id])
  releveId       String?        @unique
  releve         Releve?        @relation(fields: [releveId], references: [id])
  dateTerminee   DateTime?
  noteCompletion String?
  // Sprint 21 — Moteur d'activités
  regleId                String?
  regle                  RegleActivite? @relation(fields: [regleId], references: [id], onDelete: SetNull)
  instructionsDetaillees String?
  conseilIA              String?
  produitRecommandeId    String?
  produitRecommande      Produit?       @relation("ActiviteProduitRecommande", fields: [produitRecommandeId], references: [id], onDelete: SetNull)
  quantiteRecommandee    Float?
  priorite               Int?
  isAutoGenerated        Boolean        @default(false)
  phaseElevage           PhaseElevage?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([siteId, dateDebut])
  @@index([siteId, statut])
  @@index([assigneAId])
  @@index([releveId])
  @@index([regleId])
  @@index([isAutoGenerated])
}

// ──────────────────────────────────────────
// Modèles — Moteur d'activités (Sprint 21)
// ──────────────────────────────────────────

/**
 * RegleActivite — Règle de déclenchement automatique d'activités planifiées.
 *
 * siteId est nullable (F-15) : null = règle globale DKFarm applicable à tous les sites.
 * Un site peut surcharger une règle globale en créant sa propre règle avec le même
 * typeActivite + typeDeclencheur.
 */
model RegleActivite {
  id          String           @id @default(cuid())
  nom         String
  description String?
  typeActivite     TypeActivite
  typeDeclencheur  TypeDeclencheur
  /** Seuil de déclenchement selon le type (ex: poids en g, % mortalité, FCR) */
  conditionValeur  Float?
  /** Seuil haut pour SEUIL_QUALITE (ex: pH max) */
  conditionValeur2 Float?
  /** Phase d'élevage minimale (null = toutes phases) */
  phaseMin         PhaseElevage?
  /** Phase d'élevage maximale (null = borne haute non contrainte) */
  phaseMax         PhaseElevage?
  /** Intervalle en jours entre déclenchements (pour RECURRENT) */
  intervalleJours  Int?
  /** Template du titre de l'activité générée */
  titreTemplate         String
  /** Template de la description de l'activité générée */
  descriptionTemplate   String?
  /** Template des instructions détaillées de l'activité générée */
  instructionsTemplate  String?
  /** Priorité de l'activité générée (1=haute, 10=basse) */
  priorite     Int             @default(5)
  isActive     Boolean         @default(true)
  /** EC-3.2 : one-shot pour les seuils — désactivé après premier déclenchement */
  firedOnce    Boolean         @default(false)
  /** Logique d'évaluation des conditions composées : ET = toutes, OU = au moins une.
   *  N'a d'effet que si conditions.length > 0 (sinon evaluation legacy via typeDeclencheur). */
  logique      LogiqueCondition @default(ET)
  /** Action à effectuer quand la règle se déclenche (Sprint 29) */
  actionType   ActionRegle     @default(ACTIVITE)
  /** Sévérité de la notification (requis si actionType = NOTIFICATION ou LES_DEUX) */
  severite     SeveriteAlerte?
  /** Template du titre de la notification (requis si actionType = NOTIFICATION ou LES_DEUX) */
  titreNotificationTemplate         String?
  /** Template de la description de la notification (optionnel) */
  descriptionNotificationTemplate   String?
  /** Type du CTA dans la notification : null = aucun bouton d'action */
  actionPayloadType                 String?
  /** F-15 : null = règle globale DKFarm, non null = règle propre au site */
  siteId       String?
  site         Site?           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  activites    Activite[]
  /** Conditions composées (Sprint 27-28). Si vide, évaluation legacy via typeDeclencheur. */
  conditions   ConditionRegle[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([siteId])
  @@index([typeActivite])
  @@index([typeDeclencheur])
  @@index([isActive])
}

// ──────────────────────────────────────────
// Modèles — Densité & Conditions composées (Sprint 27-28)
// ──────────────────────────────────────────

/**
 * ConditionRegle — Condition élémentaire d'une règle à conditions composées.
 *
 * Une RegleActivite peut avoir N ConditionRegle enfants.
 * Si conditions.length > 0, l'évaluation utilise la logique ET/OU définie sur la règle.
 * Si conditions.length == 0, l'évaluation legacy (typeDeclencheur + conditionValeur) s'applique.
 *
 * Backward compatible : toutes les règles existantes ont 0 conditions.
 */
model ConditionRegle {
  id               String             @id @default(cuid())
  regleId          String
  regle            RegleActivite      @relation(fields: [regleId], references: [id], onDelete: Cascade)
  typeDeclencheur  TypeDeclencheur
  operateur        OperateurCondition @default(SUPERIEUR)
  /** Seuil de déclenchement (ex: 50 pour 50 kg/m3, 3 pour 3 jours) */
  conditionValeur  Float?
  /** Seuil haut — utilisé uniquement par l'opérateur ENTRE */
  conditionValeur2 Float?
  /** Ordre d'évaluation dans la liste de conditions (0 = premier) */
  ordre            Int                @default(0)

  @@index([regleId])
}

// ──────────────────────────────────────────
// Modèles — Dépenses
// ──────────────────────────────────────────

model Depense {
  id               String           @id @default(cuid())
  /** Numéro auto-généré format DEP-YYYY-NNN */
  numero           String           @unique
  description      String
  categorieDepense CategorieDepense
  montantTotal     Float
  montantPaye      Float            @default(0)
  statut           StatutDepense    @default(NON_PAYEE)
  date             DateTime
  dateEcheance     DateTime?
  /** URL facture fournisseur sur Hetzner Object Storage */
  factureUrl       String?
  notes            String?
  /** Lien optionnel vers la commande d'origine */
  commandeId       String?
  commande         Commande?        @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  /** Lien optionnel vers la vague concernée */
  vagueId          String?
  vague            Vague?           @relation(fields: [vagueId], references: [id], onDelete: SetNull)
  /** Lien optionnel vers la liste de besoins d'origine */
  listeBesoinsId   String?
  listeBesoins     ListeBesoins?    @relation(fields: [listeBesoinsId], references: [id], onDelete: SetNull)
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  siteId           String
  site             Site             @relation(fields: [siteId], references: [id])
  paiements        PaiementDepense[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([siteId])
  @@index([siteId, categorieDepense])
  @@index([siteId, statut])
  @@index([commandeId])
  @@index([vagueId])
  @@index([listeBesoinsId])
  @@index([date])
}

model PaiementDepense {
  id        String       @id @default(cuid())
  depenseId String
  depense   Depense      @relation(fields: [depenseId], references: [id], onDelete: Cascade)
  montant   Float
  mode      ModePaiement
  reference String?
  date      DateTime     @default(now())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  siteId    String
  site      Site         @relation(fields: [siteId], references: [id])
  createdAt DateTime     @default(now())

  @@index([depenseId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèles — Dépenses Récurrentes (Sprint 18)
// ──────────────────────────────────────────

model DepenseRecurrente {
  id                  String              @id @default(cuid())
  description         String
  categorieDepense    CategorieDepense
  montantEstime       Float
  frequence           FrequenceRecurrence
  /** Jour du mois de génération (1-28, contraint par CHECK côté SQL) */
  jourDuMois          Int                 @default(1)
  isActive            Boolean             @default(true)
  derniereGeneration  DateTime?
  userId              String
  user                User                @relation(fields: [userId], references: [id])
  siteId              String
  site                Site                @relation(fields: [siteId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([siteId])
  @@index([siteId, isActive])
  @@index([siteId, frequence])
}

// ──────────────────────────────────────────
// Modèles — Besoins (Sprint 17)
// ──────────────────────────────────────────

model ListeBesoins {
  id             String         @id @default(cuid())
  /** Numéro auto-généré format BES-YYYY-NNN */
  numero         String         @unique
  titre          String
  demandeurId    String
  demandeur      User           @relation("ListeBesoinsCreees", fields: [demandeurId], references: [id])
  valideurId     String?
  valideur       User?          @relation("ListeBesoinsValidees", fields: [valideurId], references: [id])
  statut         StatutBesoins  @default(SOUMISE)
  /** Somme estimée des besoins (SUM quantite * prixEstime) */
  montantEstime  Float          @default(0)
  /** Montant réel après clôture (nullable) */
  montantReel    Float?
  /** Motif de rejet (nullable, rempli si REJETEE) */
  motifRejet     String?
  notes          String?
  /** Date limite de traitement (optionnelle — R7 nullabilite explicite) */
  dateLimite     DateTime?
  siteId         String
  site           Site           @relation(fields: [siteId], references: [id])
  lignes         LigneBesoin[]
  depenses       Depense[]
  /** Vagues associées avec leurs ratios de répartition (remplace vagueId direct) */
  vagues         ListeBesoinsVague[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([siteId])
  @@index([siteId, statut])
  @@index([demandeurId])
  @@index([dateLimite])
}

/** Table de jonction entre ListeBesoins et Vague avec ratio de répartition des coûts */
model ListeBesoinsVague {
  id             String       @id @default(cuid())
  listeBesoinsId String
  listeBesoins   ListeBesoins @relation(fields: [listeBesoinsId], references: [id], onDelete: Cascade)
  vagueId        String
  vague          Vague        @relation(fields: [vagueId], references: [id], onDelete: Cascade)
  /// Fraction du coût imputée à cette vague. Doit être > 0 et <= 1.
  /// La somme des ratio pour un même listeBesoinsId doit être = 1.0
  ratio          Float        @default(1.0)
  /** ID du site (ferme) — R8 */
  siteId         String
  createdAt      DateTime     @default(now())

  @@unique([listeBesoinsId, vagueId])
  @@index([vagueId])
  @@index([siteId])
}

model LigneBesoin {
  id               String        @id @default(cuid())
  listeBesoinsId   String
  listeBesoins     ListeBesoins  @relation(fields: [listeBesoinsId], references: [id], onDelete: Cascade)
  /** Désignation libre de l'article */
  designation      String
  /** Produit en stock lié (nullable — libre si null) */
  produitId        String?
  produit          Produit?      @relation(fields: [produitId], references: [id], onDelete: SetNull)
  quantite         Float
  /** Unité libre (nullable si produit avec unité définie) */
  unite            String?
  /** Prix unitaire estimé */
  prixEstime       Float         @default(0)
  /** Prix unitaire réel après clôture (nullable) */
  prixReel         Float?
  /** Commande générée lors du traitement (nullable) */
  commandeId       String?
  commande         Commande?     @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())

  @@index([listeBesoinsId])
  @@index([produitId])
  @@index([commandeId])
}

// ──────────────────────────────────────────
// Modèles — Phase 3 : Packs & Provisioning (Sprint 20)
// ──────────────────────────────────────────

/**
 * Pack — Kit de démarrage vendu aux clients pisciculteurs.
 *
 * Un Pack regroupe une ConfigElevage + une liste de Produits (aliments, intrants)
 * et configure la vague initiale (nombre d'alevins, poids initial).
 * Basé sur la section 3.2 du REQ-STARTER-PACKS.md.
 */
model Pack {
  id                  String         @id @default(cuid())
  /** Nom commercial du pack — ex: "Starter 300" */
  nom                 String
  description         String?
  /** Nombre d'alevins fournis (> 0) */
  nombreAlevins       Int
  /** Poids moyen initial des alevins (g) */
  poidsMoyenInitial   Float          @default(5)
  /** Prix total du pack en FCFA (>= 0) */
  prixTotal           Float          @default(0)
  /** ConfigElevage recommandée pour ce pack */
  configElevageId     String?
  configElevage       ConfigElevage? @relation(fields: [configElevageId], references: [id], onDelete: SetNull)
  isActive            Boolean        @default(true)
  /** Créateur du pack (ADMIN DKFarm) */
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  /** Site DKFarm propriétaire du pack — R8 */
  siteId              String
  site                Site           @relation(fields: [siteId], references: [id])

  /** Plan d'abonnement associé à ce pack */
  planId              String
  plan                PlanAbonnement @relation(fields: [planId], references: [id])

  produits    PackProduit[]
  bacs        PackBac[]
  activations PackActivation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([configElevageId])
  @@index([userId])
  @@index([planId])
}

/**
 * PackProduit — Ligne de produit incluse dans un Pack.
 *
 * Un même Produit ne peut figurer qu'une fois par Pack (contrainte unique).
 * onDelete: Restrict sur Produit pour éviter les suppressions orphelines (EC-1.6).
 */
model PackProduit {
  id        String  @id @default(cuid())
  packId    String
  pack      Pack    @relation(fields: [packId], references: [id], onDelete: Cascade)
  produitId String
  produit   Produit @relation(fields: [produitId], references: [id], onDelete: Restrict)
  /** Quantité incluse dans le pack (> 0) */
  quantite  Float
  /** Unité choisie (NULL = unité par défaut du produit) */
  unite     UniteStock?

  @@unique([packId, produitId])
  @@index([packId])
  @@index([produitId])
}

/**
 * PackBac — Bac modele inclus dans un Pack.
 *
 * Decrit le nombre et la configuration des bacs fournis dans le pack.
 * Un meme nom de bac ne peut figurer qu'une fois par Pack.
 */
model PackBac {
  id                String  @id @default(cuid())
  packId            String
  pack              Pack    @relation(fields: [packId], references: [id], onDelete: Cascade)
  nom               String
  volume            Float?
  nombreAlevins     Int
  poidsMoyenInitial Float   @default(5)
  position          Int     @default(0)

  @@unique([packId, nom])
  @@index([packId])
}

/**
 * PackActivation — Enregistrement d'une vente de pack à un client.
 *
 * Créée lors du provisioning transactionnel.
 * - siteId = site DKFarm vendeur (R8)
 * - clientSiteId = site créé pour le client
 * IMPORTANT : Pas de @unique sur clientSiteId (un client peut acheter plusieurs packs — F-05)
 * IMPORTANT : Pas de @unique sur vagueId (une vague peut être splitée après tri — F-06)
 */
model PackActivation {
  id            String           @id @default(cuid())
  /** Code d'activation généré ACT-YYYY-NNN */
  code          String           @unique
  packId        String
  pack          Pack             @relation(fields: [packId], references: [id], onDelete: Restrict)
  /** Utilisateur ayant activé le pack (ingénieur ou admin DKFarm) */
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  /** Site DKFarm vendeur — R8 */
  siteId        String
  site          Site             @relation("PackActivationsVendeur", fields: [siteId], references: [id])
  /** Site client créé lors du provisioning */
  clientSiteId  String
  clientSite    Site             @relation("PackActivationsClient", fields: [clientSiteId], references: [id])
  statut        StatutActivation @default(ACTIVE)
  dateActivation DateTime        @default(now())
  dateExpiration DateTime?
  notes         String?

  /** Vagues créées lors du provisioning pour cette activation */
  vagues        Vague[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([siteId])
  @@index([clientSiteId])
  @@index([packId])
  @@index([userId])
  @@index([code])
  @@index([statut])
}

// ──────────────────────────────────────────
// Modèles — Monitoring Ingénieur (Sprint 23)
// ──────────────────────────────────────────

/**
 * NoteIngenieur — note ou observation envoyee par un ingenieur DKFarm vers un site client.
 *
 * Deux usages :
 * 1. Note de suivi (isFromClient=false) : l'ingenieur redige une note technique (PUBLIC ou INTERNE).
 * 2. Observation client (isFromClient=true) : le client remonte une observation via observationTexte.
 *
 * Deux relations vers Site :
 * - siteId : site DKFarm de l'ingenieur (R8 — chaque modele a un siteId)
 * - clientSiteId : site client destinataire de la note
 */
model NoteIngenieur {
  id               String         @id @default(cuid())
  /** Titre court de la note */
  titre            String
  /** Contenu en Markdown */
  contenu          String
  /** Visibilite : PUBLIC (visible client) ou INTERNE (DKFarm uniquement) */
  visibility       VisibiliteNote
  /** Marquer la note comme urgente */
  isUrgent         Boolean        @default(false)
  /** Marquer la note comme lue par le destinataire */
  isRead           Boolean        @default(false)
  /** True si cette note est une observation soumise par le client */
  isFromClient     Boolean        @default(false)
  /** Texte libre de l'observation client (nullable, utilise si isFromClient=true) */
  observationTexte String?

  /** Ingenieur auteur de la note */
  ingenieurId   String
  ingenieur     User   @relation("NotesEnvoyees", fields: [ingenieurId], references: [id])

  /** Site client destinataire */
  clientSiteId  String
  clientSite    Site   @relation("NotesRecues", fields: [clientSiteId], references: [id])

  /** Vague concernee (nullable) */
  vagueId       String?
  vague         Vague? @relation(fields: [vagueId], references: [id], onDelete: SetNull)

  /** Site DKFarm de l'ingenieur — R8 */
  siteId        String
  site          Site   @relation("NotesDKFarm", fields: [siteId], references: [id])

  /** Reponse a une note parente (thread one-level deep) */
  replyToId     String?
  replyTo       NoteIngenieur?  @relation("NoteReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       NoteIngenieur[] @relation("NoteReplies")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([siteId])
  @@index([clientSiteId])
  @@index([ingenieurId])
  @@index([vagueId])
  @@index([visibility])
  @@index([isFromClient])
  @@index([isRead])
  @@index([clientSiteId, isRead])
  @@index([clientSiteId, visibility])
  @@index([replyToId])
}

// ──────────────────────────────────────────
// Modèles — Calibrage (Sprint 24)
// ──────────────────────────────────────────

model Calibrage {
  id            String            @id @default(cuid())
  date          DateTime
  vagueId       String
  vague         Vague             @relation(fields: [vagueId], references: [id])
  sourceBacIds  String[]
  nombreMorts   Int               @default(0)
  notes         String?
  siteId        String
  site          Site              @relation(fields: [siteId], references: [id])
  userId        String
  user          User              @relation("CalibrageUser", fields: [userId], references: [id])
  groupes       CalibrageGroupe[]

  // Traçabilité modification (Sprint 26, ADR-015)
  modifie       Boolean                @default(false)
  modifications CalibrageModification[]

  // Relevés auto-créés lors du calibrage
  releves       Releve[]          @relation("CalibrageReleves")

  // Snapshots — état vague+bacs avant création / avant modification (Fix 5)
  snapshotAvant      Json?
  snapshotAvantModif Json?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([vagueId])
  @@index([siteId])
}

model CalibrageGroupe {
  id               String             @id @default(cuid())
  calibrageId      String
  calibrage        Calibrage          @relation(fields: [calibrageId], references: [id], onDelete: Cascade)
  categorie        CategorieCalibrage
  destinationBacId String
  destinationBac   Bac                @relation("GroupeDestBac", fields: [destinationBacId], references: [id])
  nombrePoissons   Int
  poidsMoyen       Float
  tailleMoyenne    Float?
  createdAt        DateTime           @default(now())

  @@index([calibrageId])
}

// ──────────────────────────────────────────
// Modèles — Traçabilité modification (Sprint 26, ADR-014/ADR-015)
// ──────────────────────────────────────────

/**
 * ReleveModification — trace d'une modification de relevé avec raison d'audit.
 *
 * Une ligne par champ modifié.
 * Cascade DELETE avec Releve (si un relevé est supprimé, ses traces le sont aussi).
 */
model ReleveModification {
  id             String   @id @default(cuid())
  releveId       String
  releve         Releve   @relation(fields: [releveId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  raison         String
  champModifie   String
  ancienneValeur String?
  nouvelleValeur String?
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id])
  createdAt      DateTime @default(now())

  @@index([releveId])
  @@index([userId])
  @@index([siteId])
}

/**
 * CalibrageModification — trace d'une modification de calibrage avec raison d'audit.
 *
 * Une ligne par champ modifié (nombreMorts, notes, groupes).
 * Pour "groupes" : ancienneValeur/nouvelleValeur contiennent du JSON sérialisé.
 * Cascade DELETE avec Calibrage.
 */
model CalibrageModification {
  id             String    @id @default(cuid())
  calibrageId    String
  calibrage      Calibrage @relation(fields: [calibrageId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  raison         String
  champModifie   String
  ancienneValeur String?
  nouvelleValeur String?
  siteId         String
  site           Site      @relation(fields: [siteId], references: [id])
  createdAt      DateTime  @default(now())

  @@index([calibrageId])
  @@index([userId])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Enums — CustomPlaceholder (Sprint 26)
// ──────────────────────────────────────────

enum PlaceholderMode {
  MAPPING
  FORMULA
}

enum PlaceholderFormat {
  NUMBER
  TEXT
}

// ──────────────────────────────────────────
// Enums — Abonnements & Paiements (Sprint 30)
// ──────────────────────────────────────────

enum TypePlan {
  DECOUVERTE
  ELEVEUR
  PROFESSIONNEL
  ENTREPRISE
  INGENIEUR_STARTER
  INGENIEUR_PRO
  INGENIEUR_EXPERT
}

enum PeriodeFacturation {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum StatutAbonnement {
  ACTIF
  EN_GRACE
  SUSPENDU
  EXPIRE
  ANNULE
  EN_ATTENTE_PAIEMENT
}

enum StatutPaiementAbo {
  EN_ATTENTE
  INITIE
  CONFIRME
  ECHEC
  REMBOURSE
  EXPIRE
}

enum TypeRemise {
  EARLY_ADOPTER
  SAISONNIERE
  PARRAINAGE
  COOPERATIVE
  VOLUME
  MANUELLE
}

enum StatutCommissionIng {
  EN_ATTENTE
  DISPONIBLE
  DEMANDEE
  PAYEE
  ANNULEE
}

enum FournisseurPaiement {
  SMOBILPAY
  MTN_MOMO
  ORANGE_MONEY
  MANUEL
}

// ──────────────────────────────────────────
// Modèle — CustomPlaceholder (Sprint 26)
// ──────────────────────────────────────────

/**
 * CustomPlaceholder — variable personnalisee utilisable dans les templates de regles d'activites.
 *
 * Deux modes :
 * - MAPPING : le placeholder pointe vers un champ de la base via sourcePath
 * - FORMULA : le placeholder est calcule via une formule mathematique (formula)
 *
 * Ces placeholders sont globaux (pas de siteId) — geres par DKFarm.
 */
model CustomPlaceholder {
  id          String            @id @default(cuid())
  /** Cle unique du placeholder — ex: "poids_moyen", "fcr_actuel" */
  key         String            @unique
  /** Libelle affiche dans l'editeur de regles */
  label       String
  /** Description de l'usage du placeholder (nullable) */
  description String?
  /** Exemple de valeur affichee dans l'interface */
  example     String

  /** Mode de resolution : MAPPING (champ DB) ou FORMULA (calcul) */
  mode        PlaceholderMode
  /** Chemin vers le champ source (mode MAPPING) — ex: "vague.poidsMoyen" */
  sourcePath  String?
  /** Expression de calcul (mode FORMULA) — ex: "alimentation / biomasse" */
  formula     String?

  /** Format de la valeur resolue */
  format      PlaceholderFormat @default(NUMBER)
  /** Nombre de decimales pour le format NUMBER */
  decimals    Int               @default(2)

  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ──────────────────────────────────────────
// Modèle — PlanAbonnement (Sprint 30)
// ──────────────────────────────────────────

/**
 * PlanAbonnement — Définition immuable d'un palier tarifaire.
 * Global (non lié à un site spécifique) — pas de siteId (exception documentée R8).
 * Prix null = plan gratuit ou période non disponible.
 */
model PlanAbonnement {
  id               String             @id @default(cuid())
  nom              String
  typePlan         TypePlan           @unique
  description      String?
  prixMensuel      Decimal?
  prixTrimestriel  Decimal?
  prixAnnuel       Decimal?
  limitesSites     Int                @default(1)
  limitesBacs      Int                @default(3)
  limitesVagues    Int                @default(1)
  limitesIngFermes Int?
  isActif          Boolean            @default(true)
  isPublic         Boolean            @default(true)
  /** Modules fonctionnels inclus dans ce plan — COMMISSIONS/REMISES exclus (platform-only) */
  modulesInclus    SiteModule[]       @default([])

  abonnements      Abonnement[]
  remises          Remise[]
  packs            Pack[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([typePlan])
}

// ──────────────────────────────────────────
// Modèle — Abonnement (Sprint 30)
// ──────────────────────────────────────────

/**
 * Abonnement — Instance d'un abonnement liant un site à un PlanAbonnement.
 * R8 : siteId obligatoire.
 * R7 : dateFinGrace nullable (absent pour plan gratuit).
 */
model Abonnement {
  id                          String             @id @default(cuid())
  siteId                      String
  site                        Site               @relation("AbonnementsSite", fields: [siteId], references: [id])
  planId                      String
  plan                        PlanAbonnement     @relation(fields: [planId], references: [id])
  periode                     PeriodeFacturation
  statut                      StatutAbonnement   @default(EN_ATTENTE_PAIEMENT)
  dateDebut                   DateTime
  dateFin                     DateTime
  dateProchainRenouvellement  DateTime
  dateFinGrace                DateTime?
  prixPaye                    Decimal
  userId                      String
  user                        User               @relation("AbonnementsUser", fields: [userId], references: [id])
  remiseId                    String?
  remise                      Remise?            @relation(fields: [remiseId], references: [id])

  paiements                   PaiementAbonnement[]
  remisesAppliquees           RemiseApplication[]
  commissions                 CommissionIngenieur[]

  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  @@index([siteId])
  @@index([statut])
  @@index([planId])
  @@index([dateFin])
}

// ──────────────────────────────────────────
// Modèle — PaiementAbonnement (Sprint 30)
// ──────────────────────────────────────────

/**
 * PaiementAbonnement — Transaction de paiement pour un abonnement.
 * Idempotence : referenceExterne (unique côté gateway).
 * R8 : siteId obligatoire.
 */
model PaiementAbonnement {
  id               String              @id @default(cuid())
  abonnementId     String
  abonnement       Abonnement          @relation(fields: [abonnementId], references: [id])
  montant          Decimal
  fournisseur      FournisseurPaiement
  statut           StatutPaiementAbo   @default(EN_ATTENTE)
  referenceExterne String?
  phoneNumber      String?
  metadata         Json?
  initiePar        String
  user             User                @relation("PaiementsAboUser", fields: [initiePar], references: [id])
  dateInitiation   DateTime
  dateConfirmation DateTime?
  siteId           String
  site             Site                @relation("PaiementsAboSite", fields: [siteId], references: [id])

  commissions      CommissionIngenieur[]

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([abonnementId])
  @@index([siteId])
  @@index([statut])
  @@index([referenceExterne])
}

// ──────────────────────────────────────────
// Modèle — Remise (Sprint 30)
// ──────────────────────────────────────────

/**
 * Remise — Définition d'une remise ou code promotionnel.
 * R8 : siteId nullable car remise peut être globale (DKFarm).
 * R7 : dateFin nullable pour remises sans expiration.
 */
model Remise {
  id                 String          @id @default(cuid())
  nom                String
  code               String          @unique
  type               TypeRemise
  valeur             Decimal
  estPourcentage     Boolean         @default(false)
  dateDebut          DateTime
  dateFin            DateTime?
  limiteUtilisations Int?
  nombreUtilisations Int             @default(0)
  isActif            Boolean         @default(true)
  siteId             String?
  site               Site?           @relation("RemisesSite", fields: [siteId], references: [id])
  userId             String
  user               User            @relation("RemisesUser", fields: [userId], references: [id])
  planId             String?
  plan               PlanAbonnement? @relation(fields: [planId], references: [id])

  abonnements        Abonnement[]
  applications       RemiseApplication[]

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([siteId])
  @@index([code])
}

// ──────────────────────────────────────────
// Modèle — RemiseApplication (Sprint 30)
// ──────────────────────────────────────────

/**
 * RemiseApplication — Enregistrement d'une remise appliquée à un abonnement.
 * Contrainte unique : une remise ne peut être appliquée qu'une fois par abonnement.
 */
model RemiseApplication {
  id            String     @id @default(cuid())
  remiseId      String
  remise        Remise     @relation(fields: [remiseId], references: [id])
  abonnementId  String
  abonnement    Abonnement @relation(fields: [abonnementId], references: [id])
  montantReduit Decimal
  appliqueLe    DateTime   @default(now())
  userId        String
  user          User       @relation("RemisesApplicationsUser", fields: [userId], references: [id])

  @@unique([remiseId, abonnementId])
  @@index([remiseId])
  @@index([abonnementId])
}

// ──────────────────────────────────────────
// Modèle — CommissionIngenieur (Sprint 30)
// ──────────────────────────────────────────

/**
 * CommissionIngenieur — Commission calculée pour un ingénieur
 * suite à la confirmation d'un paiement d'abonnement d'un site supervisé.
 * R8 : siteId obligatoire.
 */
model CommissionIngenieur {
  id                   String               @id @default(cuid())
  ingenieurId          String
  ingenieur            User                 @relation("CommissionsIngenieur", fields: [ingenieurId], references: [id])
  siteClientId         String
  siteClient           Site                 @relation("CommissionsSiteClient", fields: [siteClientId], references: [id])
  abonnementId         String
  abonnement           Abonnement           @relation(fields: [abonnementId], references: [id])
  paiementAbonnementId String
  paiementAbonnement   PaiementAbonnement   @relation(fields: [paiementAbonnementId], references: [id])
  montant              Decimal
  taux                 Decimal
  statut               StatutCommissionIng  @default(EN_ATTENTE)
  periodeDebut         DateTime
  periodeFin           DateTime
  siteId               String
  site                 Site                 @relation("CommissionsDKFarm", fields: [siteId], references: [id])

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([ingenieurId])
  @@index([abonnementId])
  @@index([siteId])
  @@index([statut])
}

// ──────────────────────────────────────────
// Modèle — PortefeuilleIngenieur (Sprint 30)
// ──────────────────────────────────────────

/**
 * PortefeuilleIngenieur — Portefeuille financier de l'ingénieur.
 * Un ingénieur a exactement un portefeuille (@@unique sur ingenieurId).
 * R8 : siteId obligatoire (site DKFarm gestionnaire).
 */
model PortefeuilleIngenieur {
  id             String               @id @default(cuid())
  ingenieurId    String               @unique
  ingenieur      User                 @relation("PortefeuilleIngenieur", fields: [ingenieurId], references: [id])
  solde          Decimal              @default(0)
  soldePending   Decimal              @default(0)
  totalGagne     Decimal              @default(0)
  totalPaye      Decimal              @default(0)
  siteId         String
  site           Site                 @relation("PortefeuillesSite", fields: [siteId], references: [id])

  retraits       RetraitPortefeuille[]

  updatedAt      DateTime             @updatedAt

  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèle — RetraitPortefeuille (Sprint 30)
// ──────────────────────────────────────────

/**
 * RetraitPortefeuille — Demande de virement du portefeuille ingénieur vers Mobile Money.
 * Traitée par ADMIN DKFarm. Seuil minimum : 5 000 FCFA.
 * R8 : siteId obligatoire.
 */
model RetraitPortefeuille {
  id               String               @id @default(cuid())
  portefeuilleId   String
  portefeuille     PortefeuilleIngenieur @relation(fields: [portefeuilleId], references: [id])
  montant          Decimal
  fournisseur      FournisseurPaiement
  phoneNumber      String
  statut           StatutPaiementAbo    @default(EN_ATTENTE)
  referenceExterne String?
  demandeLeBy      String
  demandeur        User                 @relation("RetraitDemandeur", fields: [demandeLeBy], references: [id])
  traitePar        String?
  traiteur         User?                @relation("RetraitTraiteur", fields: [traitePar], references: [id])
  dateTraitement   DateTime?
  siteId           String
  site             Site                 @relation("RetraitsSite", fields: [siteId], references: [id])

  createdAt        DateTime             @default(now())

  @@index([portefeuilleId])
  @@index([siteId])
  @@index([statut])
}

// ──────────────────────────────────────────
// Modèle — IdempotencyRecord (Sprint 30.4)
// ──────────────────────────────────────────

/**
 * IdempotencyRecord — Cache des réponses de mutations pour la protection contre les replays.
 * Prevents duplicate mutations when an offline-queued request is retried after a network timeout.
 * R8 : siteId obligatoire.
 * R7 : expiresAt non-nullable (TTL 48h).
 */
model IdempotencyRecord {
  id         String   @id @default(uuid())
  key        String   @unique
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id])
  response   Json
  statusCode Int
  bodyHash   String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([siteId])
  @@index([expiresAt])
}

// ──────────────────────────────────────────
// Modèle — ModuleDefinition (ADR-021)
// ──────────────────────────────────────────

/**
 * ModuleDefinition — Registre des métadonnées des modules de la plateforme.
 *
 * Approche hybride : l'enum SiteModule reste la clé forte (type-safety).
 * Ce modèle compléte l'enum avec les métadonnées (label, icône, visibilité, catégorie).
 *
 * Note R8 : pas de siteId — registre global, exception documentée dans ADR-021 section 2.2.
 */
model ModuleDefinition {
  id          String   @id @default(cuid())
  /** Clé unique — valeur de l'enum SiteModule. Source de vérité. */
  key         String   @unique
  /** Label affiché dans l'UI */
  label       String
  /** Description de ce que le module offre */
  description String?
  /** Nom de l'icône Lucide (ex: "Fish", "Package") */
  iconName    String   @default("Package")
  /** Ordre d'affichage dans les interfaces d'administration */
  sortOrder   Int      @default(0)
  /** platform = réservé au site DKFarm, site = activable par sites clients */
  level       String   @default("site")
  /** Modules requis pour activer celui-ci (dépendances, valeurs SiteModule) */
  dependsOn   String[] @default([])
  /** Si false : masqué dans les interfaces sans le supprimer */
  isVisible   Boolean  @default(true)
  /** Si false : ne peut plus être assigné à de nouveaux plans ou sites */
  isActive    Boolean  @default(true)
  /** Catégorie fonctionnelle pour regroupement UI */
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────
// Modèle — SiteAuditLog (ADR-021)
// ──────────────────────────────────────────

/**
 * SiteAuditLog — Journal d'audit des actions admin sur les sites.
 *
 * Toute action admin (suspension, blocage, modification de modules) est loguée ici
 * dans la même transaction que la mutation principale (R4).
 * R8 : siteId obligatoire.
 */
model SiteAuditLog {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  actorId   String
  actor     User     @relation("AuditLogActor", fields: [actorId], references: [id])
  /** ex: SITE_SUSPENDED, MODULE_ADDED, ABONNEMENT_FORCED */
  action    String
  /** Payload before/after pour l'action */
  details   Json?
  createdAt DateTime @default(now())

  @@index([siteId])
  @@index([actorId])
  @@index([createdAt])
}

// ──────────────────────────────────────────
// Modèle — HistoriqueNutritionnel (Sprint FD.6)
// ──────────────────────────────────────────

/**
 * HistoriqueNutritionnel — Matérialisation des données nutritionnelles par vague et phase.
 *
 * Table de cache analytique : évite de recalculer FCR, SGR, ADG, PER à chaque requête.
 * Les données peuvent être recalculées à tout moment depuis les relevés bruts.
 * R8 : siteId obligatoire.
 * @@unique([vagueId, phase]) : un seul enregistrement par vague et par phase.
 */
model HistoriqueNutritionnel {
  id      String       @id @default(cuid())
  vagueId String
  vague   Vague        @relation(fields: [vagueId], references: [id])
  phase   PhaseElevage

  // Métriques agrégées pour cette phase
  /** FCR moyen sur la phase (kg aliment / kg gain) */
  fcrMoyen          Float?
  /** SGR moyen sur la phase (% poids vif / jour) */
  sgrMoyen          Float?
  /** ADG moyen sur la phase (g / jour) — Gain Quotidien Moyen */
  adgMoyen          Float?
  /** PER moyen sur la phase (kg gain / kg protéines) */
  perMoyen          Float?
  /** Quantité totale d'aliment distribué sur la phase (kg) */
  quantiteAlimentKg Float?
  /** Poids moyen des poissons au début de la phase (g) */
  poidsMoyenDebut   Float?
  /** Poids moyen des poissons à la fin de la phase (g) */
  poidsMoyenFin     Float?
  /** Taux de survie sur la phase (%) */
  tauxSurvie        Float?
  /** Durée effective de la phase en jours */
  dureeJours        Int?

  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vagueId, phase])
  @@index([siteId])
}

// ──────────────────────────────────────────
// Modèle — GompertzVague (Sprint Gompertz)
// ──────────────────────────────────────────

/**
 * GompertzVague — Parametres du modele de croissance de Gompertz calibres sur les
 * releves biometriques d'une vague.
 *
 * W(t) = W∞ × exp(−exp(−k × (t − ti)))
 *
 * Un seul enregistrement par vague (@@unique vagueId).
 * Supprime en cascade avec la vague (onDelete: Cascade).
 * R8 : siteId obligatoire.
 */
model GompertzVague {
  id             String   @id @default(cuid())

  vagueId        String   @unique
  vague          Vague    @relation(fields: [vagueId], references: [id], onDelete: Cascade)

  /** W∞ — Poids asymptotique (g) */
  wInfinity      Float
  /** k — Constante de taux de croissance (1/jour) */
  k              Float
  /** ti — Point d'inflexion (jours depuis le debut de la vague) */
  ti             Float
  /** R² — Coefficient de determination (0-1) */
  r2             Float
  /** RMSE — Erreur quadratique moyenne (g) */
  rmse           Float
  /** Nombre de releves biometriques utilises pour le calibrage */
  biometrieCount Int

  /**
   * Niveau de confiance du calibrage.
   * INSUFFICIENT_DATA = < minPoints
   * LOW               = minPoints to minPoints+1
   * MEDIUM            = minPoints+2 to minPoints+4
   * HIGH              = >= minPoints+5 AND R² > 0.95
   */
  confidenceLevel String

  /** The configElevage.gompertzWInfDefault value used during this calibration */
  configWInfUsed Float?

  siteId         String
  site           Site     @relation(fields: [siteId], references: [id])

  calculatedAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([siteId])
  @@index([vagueId])
}
